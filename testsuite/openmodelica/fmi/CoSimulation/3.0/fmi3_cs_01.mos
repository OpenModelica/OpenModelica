// name: fmi3_cs_01.mos
// keywords: FMI 3.0 export CoSimulation
// status: correct
// teardown_command: rm -rf fmi3_cs_01.fmu fmi3_cs_01.xml fmi3_cs_01_tmp.xml fmi3_cs_01.fmutmp/

setCommandLineOptions("-d=newInst"); getErrorString();

loadString("
model fmi3_cs_01
  Real x(start=1.0);
  output Real y;
  parameter Real a = 2.0;
equation
  der(x) = -a*x;
  y = 2*x + a;
end fmi3_cs_01;
"); getErrorString();

buildModelFMU(fmi3_cs_01, version="3.0", fmuType="cs"); getErrorString();

system("unzip -cqq fmi3_cs_01.fmu modelDescription.xml > fmi3_cs_01_tmp.xml"); getErrorString();
system("sed -n \"/<CoSimulation/,/\\/>/p\" fmi3_cs_01_tmp.xml > fmi3_cs_01.xml"); getErrorString();
readFile("fmi3_cs_01.xml"); getErrorString();


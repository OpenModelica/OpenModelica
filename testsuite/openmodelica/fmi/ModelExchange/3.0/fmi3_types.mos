// name: fmi3_types.mos
// keywords: FMI 3.0 export typed variables
// status: correct
// teardown_command: rm -rf fmi3_types.fmu fmi3_types.xml fmi3_types_tmp.xml fmi3_types.fmutmp/

setCommandLineOptions("-d=newInst"); getErrorString();

loadString("
model fmi3_types
  Real x(start=3.0);
  output Real ro = 2.0*x;
  parameter Real rp = 1.5;
  parameter Integer ip = 7;
  parameter Boolean bp = true;
  parameter String sp = \"hello\";
  Integer ic(start=4);
equation
  der(x) = -x;
  when sample(0,1) then
    ic = pre(ic) + 1;
  end when;
end fmi3_types;
"); getErrorString();

buildModelFMU(fmi3_types, version="3.0", fmuType="me"); getErrorString();

system("unzip -cqq fmi3_types.fmu modelDescription.xml > fmi3_types_tmp.xml"); getErrorString();
system("sed -n \"/<ModelVariables>/,/<\\/ModelVariables>/p\" fmi3_types_tmp.xml > fmi3_types.xml"); getErrorString();
readFile("fmi3_types.xml"); getErrorString();


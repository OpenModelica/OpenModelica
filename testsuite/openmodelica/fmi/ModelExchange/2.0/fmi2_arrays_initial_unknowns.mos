// name: fmi2_arrays_initial_unknowns.mos
// keywords: FMI 2.0 export array InitialUnknowns NewBackend
// status: correct
// teardown_command: rm -rf fmi2_arrays_initial_unknowns.fmu fmi2_arrays_initial_unknowns.xml fmi2_arrays_initial_unknowns_tmp.xml fmi2_arrays_initial_unknowns.fmutmp/ fmi2_arrays_initial_unknowns.log fmi2_arrays_initial_unknowns_info.json index.html
//
// FMI 2.0 requires the <InitialUnknowns> element of <ModelStructure> to list
// all variables that are unknowns during initialization. Regression test for
// the new backend (non-scalarized) FMU export, which previously emitted an
// empty <InitialUnknowns>. The fixed-start state x is initial="exact" (a known)
// and must be excluded; the output y and the state derivative der(x) are
// calculated and must be listed.

setCommandLineOptions("--newBackend --simCodeScalarize=false"); getErrorString();

loadString("
model fmi2_arrays_initial_unknowns
  Real x[3](start = {1.0, 2.0, 3.0}, each fixed = true);
  output Real y;
  parameter Real a = 2.0;
equation
  der(x) = -a*x;
  y = sum(x);
end fmi2_arrays_initial_unknowns;
"); getErrorString();

buildModelFMU(fmi2_arrays_initial_unknowns, version="2.0", fmuType="me"); getErrorString();

// unzip to console, quiet, extra quiet
system("unzip -cqq fmi2_arrays_initial_unknowns.fmu modelDescription.xml > fmi2_arrays_initial_unknowns_tmp.xml"); getErrorString();
system("sed -n \"/<ModelStructure>/,/<\\/ModelStructure>/p\" fmi2_arrays_initial_unknowns_tmp.xml > fmi2_arrays_initial_unknowns.xml"); getErrorString();
readFile("fmi2_arrays_initial_unknowns.xml"); getErrorString();


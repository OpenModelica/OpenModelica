// name: FlowAlias12
// status: correct

loadFile("TestAliasStream.mo"); getErrorString();

loadString("
  model Test12
    import TestAliasStream.*;
    Pump pump1(w = sin(time));
    Pump pump2(w = min(sin(2*time), 0));
    Pipe pipe(inlet.w(max = 0));
    Tank tank;
  equation
    connect(pump1.outlet, tank.port);
    connect(pump2.outlet, pipe.inlet);
    connect(pipe.outlet, tank.port);
  end Test12;
");

setCommandLineOptions("-f -d=flowAliasElimination"); getErrorString();
instantiateModel(Test12); getErrorString();


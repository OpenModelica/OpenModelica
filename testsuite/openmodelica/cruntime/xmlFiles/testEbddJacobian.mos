// name:     testEbddJacobian
// keywords: EBDD runtime info dbg.json LOG_EBDD Jacobian
// status: correct
// teardown_command: rm -rf EbddJac* ebddjaccheck.txt
//
// Item 3 of the EBDD runtime-information work package: simulating with
// -lv=LOG_EBDD must emit a per-Newton-iteration Jacobian record into
// <model>_dbg.json, keyed by eqIndex, carrying the column labels and the dense
// matrix of partial derivatives d f_row / d x_col.
// See https://github.com/OpenModelica/OpenModelica/issues/15955

loadString("
model EbddJac \"small model with a nonlinear algebraic loop\"
  Real x(start = 1.0);
  Real y(start = 1.0);
  Real u = 1.0 + time;
equation
  x^2 + y = 3 + u;
  x - y^2 = -1 - u;
end EbddJac;
"); getErrorString();

simulate(EbddJac, stopTime = 1.0, numberOfIntervals = 2, simflags = "-lv=LOG_EBDD"); getErrorString();

// Structural checks (no dependence on iteration count or solver values):
//  - the file has at least one jacobian record
//  - that record carries an "iteration" index and a "rows" matrix
//  - it carries the iteration variable label 'y'
system("f=EbddJac_dbg.json; if [ -f \"$f\" ] && [ $(grep -c '\"kind\":\"jacobian\"' \"$f\") -ge 1 ] && grep -q '\"rows\":\\[' \"$f\" && grep -q '\"y\"' \"$f\"; then echo OK; else echo FAIL; fi", outputFile="ebddjaccheck.txt"); getErrorString();
readFile("ebddjaccheck.txt");


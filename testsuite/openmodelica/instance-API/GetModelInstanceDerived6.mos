// name: GetModelInstanceDerived5
// keywords:
// status: correct
// cflags: -d=newInst
//
//

loadString("
package MWE
  package Pack1
    record Data
    end Data;
  end Pack1;

  package Pack2
    record Data
    end Data;
  end Pack2;

  model test
    model obj
      replaceable package ActualPackage = Pack1;
      parameter ActualPackage.Data data;
    end obj;

    obj obj1(redeclare package ActualPackage = MWE.Pack2);
  end test;
end MWE;
");

getModelInstance(MWE.test, prettyPrint = true); getErrorString();


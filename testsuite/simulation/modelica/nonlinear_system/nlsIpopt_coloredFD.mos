// name: nlsIpopt_coloredFD
// status: correct
// teardown_command: rm -f IpoptSys3* _IpoptSys3* output.log
// cflags: -d=-newInst
//
// Tests the IPOPT colored sparse finite-difference Jacobian path (ticket #14104).
// Disabling the symbolic NLS Jacobian (-d=-NLSanalyticJacobian) leaves the system
// with a sparsity pattern but no analytic Jacobian, so IPOPT builds the Jacobian
// by colored sparse finite differences. The same coupled 3x3 system must still be
// solved correctly (residuals driven to zero, min respected). val() is inlined so
// the raw irrational root is not echoed into the result.

setCommandLineOptions("-d=-NLSanalyticJacobian"); getErrorString();

loadString("
model IpoptSys3
  // asymmetric start values keep the initial Jacobian non-singular (a symmetric
  // start x=y=z makes all rows [1,1,1] at x=0.5, which is solver-version fragile)
  Real x(start = 0.5, min = 0);
  Real y(start = 1.2);
  Real z(start = 2.0);
equation
  x^2 + y + z = 7;
  x + y^2 + z = 7;
  x + y + z^2 = 7;
end IpoptSys3;
"); getErrorString();

rIp := simulate(IpoptSys3, stopTime = 0.0, simflags = "-initNlsIpopt"); getErrorString();
print("x>=min   = " + String(val(x,0.0) >= 0.0) + "\n");
print("res1 ~ 0 = " + String(abs(val(x,0.0)*val(x,0.0) + val(y,0.0) + val(z,0.0) - 7.0) < 1e-6) + "\n");
print("res2 ~ 0 = " + String(abs(val(x,0.0) + val(y,0.0)*val(y,0.0) + val(z,0.0) - 7.0) < 1e-6) + "\n");
print("res3 ~ 0 = " + String(abs(val(x,0.0) + val(y,0.0) + val(z,0.0)*val(z,0.0) - 7.0) < 1e-6) + "\n");

// Result:
// true
// ""
// true
// ""
// record SimulationResult
//     resultFile = "IpoptSys3_res.mat",
//     simulationOptions = "startTime = 0.0, stopTime = 0.0, numberOfIntervals = 500, tolerance = 1e-6, method = 'dassl', fileNamePrefix = 'IpoptSys3', options = '', outputFormat = 'mat', variableFilter = '.*', cflags = '', simflags = '-initNlsIpopt'",

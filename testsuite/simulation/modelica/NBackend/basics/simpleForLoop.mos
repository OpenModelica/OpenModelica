// name: simpleForLoop
// keywords: NewBackend
// status: correct

setCommandLineOptions("--newBackend --simCodeScalarize=false"); getErrorString();

loadString("
model simpleForLoop
  parameter Integer N=100 \"Size of array x.\";
  Real[N] x (each start=1, each fixed = true) \"Array with states\";
equation
  for i in 1:N loop
    der(x[i]) = 1/i * x[i];
   end for;
end simpleForLoop;
"); getErrorString();

// TODO: these reference results seem to be wrong!
// x[100] at time = 1 => should be e, but it yields values a lot bigger
simulate(simpleForLoop); getErrorString();

val(x[1], 0.0);
val(x[100], 0.0);
val(der(x[1]), 0.0);
val(der(x[100]), 0.0);

val(x[1], 1.0);
val(x[100], 1.0);
val(der(x[1]), 1.0);
val(der(x[100]), 1.0);



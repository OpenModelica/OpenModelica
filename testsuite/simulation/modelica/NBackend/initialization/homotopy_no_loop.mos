// name: homotopy_no_loop
// keywords: NewBackend, initialization, adjacency
// status: correct
// cflags: --newBackend

loadString("
model homotopy_no_loop
  Real u, y;
equation
  homotopy(u, y + y^2) = 1;
  y = u^3 + u;
end homotopy_no_loop;
"); getErrorString();

setCommandLineOptions("-d=dumpSimCode"); getErrorString();
simulate(homotopy_no_loop); getErrorString();


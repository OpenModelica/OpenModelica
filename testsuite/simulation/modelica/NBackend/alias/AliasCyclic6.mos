// name: AliasCyclic
// keywords: NewBackend
// status: correct

loadString("
  model AliasCyclic6
    Integer x0, x1, x2, x3, x4, x5, x6, x7, x8, x9;       // constant simple
  equation
    1 = 3*x0 + 7*x8;
    2 = 5*x1 + 9*x7;
    3 = 4*x2 + 6*x6;
    4 = 8*x3 + x5;
    5 = 2*x0 + 5*x4;
    5 = 3*x2 + 2*x9;
    4 = 7*x1 + 9*x5;
    3 = 4*x4 + x7;
    2 = 5*x3 + 8*x9;
    1 = 3*x6 + 6*x8;
  end AliasCyclic6;
"); getErrorString();

setCommandLineOptions("--newBackend -d=dumprepl");
simulate(AliasCyclic6); getErrorString();
diffSimulationResults("AliasCyclic6_res.mat", "ReferenceFiles/AliasCyclic6_res.mat", "AliasCyclic6_diff.csv", 1e-8);


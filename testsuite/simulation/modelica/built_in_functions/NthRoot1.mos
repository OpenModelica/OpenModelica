// name:     NthRoot1
// status: correct
// teardown_command: rm -rf NthRoot1_* NthRoot1.log NthRoot1.libs NthRoot1 NthRoot1.exe NthRoot1.cpp NthRoot1.makefile output.log
//
//

loadString("
  model NthRoot1
    Real x = 4;
    Real y, z, w;
  equation
    y = nthRoot(x, 2);
    z = nthRoot(x, 3);
    w = nthRoot(-4, 3);
  end NthRoot1;
");
getErrorString();
simulate(NthRoot1, stopTime=1);
getErrorString();
{val(y,0.5)};
{val(z,0.5)};
{val(w,0.5)};


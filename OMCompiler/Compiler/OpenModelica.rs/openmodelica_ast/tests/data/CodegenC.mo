    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           _,
           _,
           _,
           a_auxFunction2,
           a_varDecls3 )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case 6"));
      then (txt, a_auxFunction2, a_varDecls3);

    case ( txt,
           _,
           _,
           _,
           _,
           a_auxFunction2,
           a_varDecls3 )

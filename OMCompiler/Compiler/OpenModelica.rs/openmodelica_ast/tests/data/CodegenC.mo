protected function fun_667
  input Tpl.Text in_txt;
  input SimCode.SparsityPattern in_a_sparsepattern;
  input list<SimCode.JacobianColumn> in_a_jacobianColumn;
  input list<SimCodeVar.SimVar> in_a_seedVars;
  input String in_a_matrixname;
  input list<list<Integer>> in_a_colorList;
  input Integer in_a_maxColor;
  input String in_a_modelNamePrefix;
  input String in_a_fileNamePrefix;
  input Boolean in_a_isAdjoint;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_sparsepattern, in_a_jacobianColumn, in_a_seedVars, in_a_matrixname, in_a_colorList, in_a_maxColor, in_a_modelNamePrefix, in_a_fileNamePrefix, in_a_isAdjoint)
    local
      Tpl.Text txt;
      list<SimCode.JacobianColumn> a_jacobianColumn;
      list<SimCodeVar.SimVar> a_seedVars;
      String a_matrixname;
      list<list<Integer>> a_colorList;
      Integer a_maxColor;
      String a_modelNamePrefix;
      String a_fileNamePrefix;
      Boolean a_isAdjoint;
      SimCode.SparsityPattern i_sparsepattern;
      Integer ret_12;
      Tpl.Text l_sizeCols;
      Tpl.Text l_evalColumn;
      Tpl.Text l_constantEqns;
      Tpl.Text l_tmpvarsSize;
      Tpl.Text l_sizeRows;
      Boolean ret_6;
      Tpl.Text l_availability;
      Integer ret_4;
      Tpl.Text l_sizeleadindex;
      Integer ret_2;
      list<list<Integer>> ret_1;
      Tpl.Text l_sp__size__index;

    case ( txt,
           {},
           _,
           _,
           a_matrixname,
           _,
           _,
           a_modelNamePrefix,
           _,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "initialAnalyticJacobian");
        txt = Tpl.writeStr(txt, a_matrixname);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, threadData_t *threadData, JACOBIAN *jacobian)\n",
                                    "{\n",
                                    "  jacobian->availability = JACOBIAN_NOT_AVAILABLE;\n",
                                    "  return 1;\n",
                                    "}"
                                }, false));
      then txt;

    case ( txt,
           i_sparsepattern,
           a_jacobianColumn,
           a_seedVars,
           a_matrixname,
           a_colorList,
           a_maxColor,
           a_modelNamePrefix,
           a_fileNamePrefix,
           a_isAdjoint )
      equation
        ret_1 = List.unzipSecond(i_sparsepattern);
        ret_2 = List.lengthListElements(ret_1);
        l_sp__size__index = Tpl.writeStr(Tpl.emptyTxt, intString(ret_2));
        ret_4 = listLength(i_sparsepattern);
        l_sizeleadindex = Tpl.writeStr(Tpl.emptyTxt, intString(ret_4));
        ret_6 = SimCodeUtil.jacobianColumnsAreEmpty(a_jacobianColumn);
        l_availability = fun_662(Tpl.emptyTxt, ret_6);
        l_sizeRows = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        l_sizeRows = lm_663(l_sizeRows, a_jacobianColumn);
        l_sizeRows = Tpl.popIter(l_sizeRows);
        l_tmpvarsSize = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        l_tmpvarsSize = lm_664(l_tmpvarsSize, a_jacobianColumn);
        l_tmpvarsSize = Tpl.popIter(l_tmpvarsSize);
        l_constantEqns = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING("")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        l_constantEqns = lm_666(l_constantEqns, a_jacobianColumn, a_matrixname, a_modelNamePrefix);
        l_constantEqns = Tpl.popIter(l_constantEqns);
        l_evalColumn = CodegenUtil.symbolName(Tpl.emptyTxt, a_modelNamePrefix, "functionJac");
        l_evalColumn = Tpl.writeStr(l_evalColumn, a_matrixname);
        l_evalColumn = Tpl.writeTok(l_evalColumn, Tpl.ST_STRING("_column"));
        ret_12 = listLength(a_seedVars);
        l_sizeCols = Tpl.writeStr(Tpl.emptyTxt, intString(ret_12));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "OMC_DISABLE_OPT\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "initialAnalyticJacobian");
        txt = Tpl.writeStr(txt, a_matrixname);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, threadData_t *threadData, JACOBIAN *jacobian)\n",
                                    "{\n",
                                    "  size_t count;\n",
                                    "\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("FILE* pFile = openSparsePatternFile(data, threadData, \""));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_Jac"));
        txt = Tpl.writeStr(txt, a_matrixname);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ".bin\");\n",
                                    "\n",
                                    "initJacobian(jacobian, "
                                }, false));
        txt = Tpl.writeText(txt, l_sizeCols);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_sizeRows);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_tmpvarsSize);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", NULL, "));
        txt = Tpl.writeText(txt, l_evalColumn);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_constantEqns);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", NULL);\n",
                                    "jacobian->sparsePattern = allocSparsePattern("
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(a_maxColor));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "jacobian->availability = "
                                }, false));
        txt = Tpl.writeText(txt, l_availability);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "jacobian->isRowEval = "
                                }, false));
        txt = CodegenCFunctions.boolStrC(txt, a_isAdjoint);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "\n",
                                    "/* read lead index of compressed sparse column */\n",
                                    "count = omc_fread(jacobian->sparsePattern->leadindex, sizeof(unsigned int), "
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1, pFile, FALSE);\n",
                                    "if (count != "
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("+1) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("throwStreamPrint(threadData, \"Error while reading lead index list of sparsity pattern. Expected %d, got %zu\", "));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("+1, count);\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "/* read sparse index */\n",
                                    "count = omc_fread(jacobian->sparsePattern->index, sizeof(unsigned int), "
                                }, false));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", pFile, FALSE);\n",
                                    "if (count != "
                                }, false));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(") {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("throwStreamPrint(threadData, \"Error while reading row index list of sparsity pattern. Expected %d, got %zu\", "));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(", count);\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "/* write color array */\n"
                                }, true));
        txt = readSPColors(txt, a_colorList, "jacobian->sparsePattern->colorCols", Tpl.textString(l_sizeleadindex));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "omc_fclose(pFile);\n",
                                    "\n",
                                    "return 0;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;
  end match;
end fun_667;


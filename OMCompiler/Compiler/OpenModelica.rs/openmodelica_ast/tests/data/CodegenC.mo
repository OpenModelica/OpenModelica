protected function fun_422
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input String in_a_modelNamePrefix;
  input Boolean in_a_static;
  input Tpl.Text in_a_OMC__NO__OPT;
  input SimCodeFunction.Context in_a_context;
  input String in_a_attribute;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_modelNamePrefix, in_a_static, in_a_OMC__NO__OPT, in_a_context, in_a_attribute)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      Boolean a_static;
      Tpl.Text a_OMC__NO__OPT;
      SimCodeFunction.Context a_context;
      String a_attribute;
      SimCode.SimEqSystem i_eq;
      list<SimCode.SimEqSystem> ret_5;
      list<SimCode.SimEqSystem> ret_4;
      Tpl.Text l_body;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDecls;
      Tpl.Text l_ix;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN(exp = DAE.CALL(path = Absyn.IDENT(name = "fail"))),
           _,
           _,
           _,
           _,
           _ )
      equation
        txt = CodegenCFunctions.generateThrow(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(exp = DAE.CALL(path = Absyn.IDENT(name = "fail"))),
           _,
           _,
           _,
           _,
           _ )
      equation
        txt = CodegenCFunctions.generateThrow(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           (i_eq as SimCode.SES_SIMPLE_ASSIGN(index = _)),
           a_modelNamePrefix,
           a_static,
           a_OMC__NO__OPT,
           a_context,
           a_attribute )
      equation
        l_ix = CodegenUtilSimulation.equationIndex(Tpl.emptyTxt, i_eq);
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_body, l_varDecls, l_auxFunction) = functionUpdateBoundVariableAttributesFunctionsSimpleAssign(Tpl.emptyTxt, i_eq, a_attribute, a_context, l_varDecls, l_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/*\n"));
        ret_4 = List.fill(i_eq, 1);
        txt = CodegenUtilSimulation.dumpEqs(txt, ret_4);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("*/\n"));
        txt = Tpl.writeText(txt, a_OMC__NO__OPT);
        txt = fun_420(txt, a_static);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("void "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "eqFunction");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt = Tpl.writeText(txt, l_ix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA *data, threadData_t *threadData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeText(txt, l_ix);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = equation_withProfile(txt, Tpl.textString(l_ix), Tpl.textString(l_body));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n"
                                }, true));
      then txt;

    case ( txt,
           (i_eq as SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(index = _)),
           a_modelNamePrefix,
           a_static,
           a_OMC__NO__OPT,
           a_context,
           a_attribute )
      equation
        l_ix = CodegenUtilSimulation.equationIndex(Tpl.emptyTxt, i_eq);
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_body, l_varDecls, l_auxFunction) = functionUpdateBoundVariableAttributesFunctionsSimpleAssign(Tpl.emptyTxt, i_eq, a_attribute, a_context, l_varDecls, l_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/*\n"));
        ret_5 = List.fill(i_eq, 1);
        txt = CodegenUtilSimulation.dumpEqs(txt, ret_5);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("*/\n"));
        txt = Tpl.writeText(txt, a_OMC__NO__OPT);
        txt = fun_421(txt, a_static);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("void "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "eqFunction");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt = Tpl.writeText(txt, l_ix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA *data, threadData_t *threadData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeText(txt, l_ix);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = equation_withProfile(txt, Tpl.textString(l_ix), Tpl.textString(l_body));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n"
                                }, true));
      then txt;

    case ( txt,
           _,
           _,
           _,
           _,
           _,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION equation_"));
      then txt;
  end match;
end fun_422;

public function functionUpdateBoundVariableAttributesFunctions
  input Tpl.Text txt;
  input SimCode.SimEqSystem a_eq;
  input String a_attribute;
  input SimCodeFunction.Context a_context;
  input String a_modelNamePrefix;
  input Boolean a_static;
  input Boolean a_noOpt;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_OMC__NO__OPT;
algorithm
  l_OMC__NO__OPT := fun_419(Tpl.emptyTxt, a_noOpt, a_eq);
  out_txt := fun_422(txt, a_eq, a_modelNamePrefix, a_static, l_OMC__NO__OPT, a_context, a_attribute);
end functionUpdateBoundVariableAttributesFunctions;


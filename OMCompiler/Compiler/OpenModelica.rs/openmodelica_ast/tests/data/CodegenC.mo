      equation
        x_i0 = Tpl.getIteri_i0(txt);
        (txt, a_auxFunctions) = CodegenCFunctions.contextCrefNoPrevExp(txt, i_name, a_context, a_auxFunctions);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = aux_x["));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("];"));
        txt = Tpl.nextIter(txt);
        (txt, a_auxFunctions) = lm_779(txt, rest, a_auxFunctions, a_context);
      then (txt, a_auxFunctions);

    case ( txt,
           _ :: rest,
           a_auxFunctions,
           a_context )
      equation
        (txt, a_auxFunctions) = lm_779(txt, rest, a_auxFunctions, a_context);
      then (txt, a_auxFunctions);
  end match;
end lm_779;


protected function fun_393
  input Tpl.Text in_txt;
  input SimCode.NonlinearPattern in_a_nonlinearpattern;
  input String in_a_indexName;
  input String in_a_systemType;
  input SimCode.NonlinearPattern in_a_nonlinearpatternT;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_nonlinearpattern, in_a_indexName, in_a_systemType, in_a_nonlinearpatternT)
    local
      Tpl.Text txt;
      String a_indexName;
      String a_systemType;
      SimCode.NonlinearPattern a_nonlinearpatternT;
      SimCode.NonlinearPattern i_nonlinearpattern;
      Integer ret_16;
      list<list<Integer>> ret_15;
      Tpl.Text l_rows;
      Integer ret_13;
      list<list<Integer>> ret_12;
      Tpl.Text l_columns;
      Integer ret_10;
      Tpl.Text l_index__eqn;
      Integer ret_8;
      Tpl.Text l_index__var;
      Integer ret_6;
      list<list<Integer>> ret_5;
      Tpl.Text l_number__nonlinear;
      Integer ret_3;
      Tpl.Text l_number__eqns;
      Integer ret_1;
      Tpl.Text l_number__vars;

    case ( txt,
           {},
           a_indexName,
           a_systemType,
           _ )
      equation
        txt = generateStaticEmptyNonlinearData(txt, a_indexName, a_systemType);
      then txt;

    case ( txt,
           i_nonlinearpattern,
           a_indexName,
           a_systemType,
           a_nonlinearpatternT )
      equation
        ret_1 = listLength(a_nonlinearpatternT);
        l_number__vars = Tpl.writeStr(Tpl.emptyTxt, intString(ret_1));
        ret_3 = listLength(i_nonlinearpattern);
        l_number__eqns = Tpl.writeStr(Tpl.emptyTxt, intString(ret_3));
        ret_5 = List.unzipSecond(i_nonlinearpattern);
        ret_6 = List.lengthListElements(ret_5);
        l_number__nonlinear = Tpl.writeStr(Tpl.emptyTxt, intString(ret_6));
        ret_8 = listLength(a_nonlinearpatternT);
        l_index__var = genSPCRSPtr(Tpl.emptyTxt, ret_8, a_nonlinearpatternT, "index_var");
        ret_10 = listLength(a_nonlinearpatternT);
        l_index__eqn = genSPCRSPtr(Tpl.emptyTxt, ret_10, a_nonlinearpatternT, "index_eqn");
        ret_12 = List.unzipSecond(a_nonlinearpatternT);
        ret_13 = List.lengthListElements(ret_12);
        l_columns = genSPCRSRows(Tpl.emptyTxt, ret_13, a_nonlinearpatternT, "columns");
        ret_15 = List.unzipSecond(i_nonlinearpattern);
        ret_16 = List.lengthListElements(ret_15);
        l_rows = genSPCRSRows(Tpl.emptyTxt, ret_16, i_nonlinearpattern, "rows");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "OMC_DISABLE_OPT\n",
                                    "void initializeNonlinearPattern"
                                }, false));
        txt = Tpl.writeStr(txt, a_indexName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("("));
        txt = Tpl.writeStr(txt, a_systemType);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "* inSysData)\n",
                                    "{\n",
                                    "  int i=0;\n",
                                    "  inSysData->nonlinearPattern = (NONLINEAR_PATTERN*) malloc(sizeof(NONLINEAR_PATTERN));\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("inSysData->nonlinearPattern->numberOfVars = "));
        txt = Tpl.writeText(txt, l_number__vars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "inSysData->nonlinearPattern->numberOfEqns = "
                                }, false));
        txt = Tpl.writeText(txt, l_number__eqns);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "inSysData->nonlinearPattern->numberOfNonlinear = "
                                }, false));
        txt = Tpl.writeText(txt, l_number__nonlinear);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "inSysData->nonlinearPattern->indexVar = (unsigned int*) malloc(("
                                }, false));
        txt = Tpl.writeText(txt, l_number__vars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1)*sizeof(unsigned int));\n",
                                    "inSysData->nonlinearPattern->indexEqn = (unsigned int*) malloc(("
                                }, false));
        txt = Tpl.writeText(txt, l_number__eqns);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1)*sizeof(unsigned int));\n",
                                    "inSysData->nonlinearPattern->columns = (unsigned int*) malloc("
                                }, false));
        txt = Tpl.writeText(txt, l_number__nonlinear);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "*sizeof(unsigned int));\n",
                                    "inSysData->nonlinearPattern->rows = (unsigned int*) malloc("
                                }, false));
        txt = Tpl.writeText(txt, l_number__nonlinear);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "*sizeof(unsigned int));\n",
                                    "/* initialize and accumulate index vectors */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_index__var);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_index__eqn);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("memcpy(inSysData->nonlinearPattern->indexVar, index_var, ("));
        txt = Tpl.writeText(txt, l_number__vars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1)*sizeof(unsigned int));\n",
                                    "memcpy(inSysData->nonlinearPattern->indexEqn, index_eqn, ("
                                }, false));
        txt = Tpl.writeText(txt, l_number__eqns);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1)*sizeof(unsigned int));\n",
                                    "for(i=2;i<"
                                }, false));
        txt = Tpl.writeText(txt, l_number__vars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1;++i)\n",
                                    "  inSysData->nonlinearPattern->indexVar[i] += inSysData->nonlinearPattern->indexVar[i-1];\n",
                                    "for(i=2;i<"
                                }, false));
        txt = Tpl.writeText(txt, l_number__eqns);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1;++i)\n",
                                    "  inSysData->nonlinearPattern->indexEqn[i] += inSysData->nonlinearPattern->indexEqn[i-1];\n",
                                    "/* initialize columns and rows */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_columns);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_rows);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("memcpy(inSysData->nonlinearPattern->columns, columns, "));
        txt = Tpl.writeText(txt, l_number__nonlinear);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "*sizeof(unsigned int));\n",
                                    "memcpy(inSysData->nonlinearPattern->rows, rows, "
                                }, false));
        txt = Tpl.writeText(txt, l_number__nonlinear);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("*sizeof(unsigned int));\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;
  end match;
end fun_393;

public function generateStaticNonlinearData
  input Tpl.Text txt;
  input String a_indexName;
  input String a_systemType;
  input SimCode.NonlinearPattern a_nonlinearpattern;
  input SimCode.NonlinearPattern a_nonlinearpatternT;

  output Tpl.Text out_txt;
algorithm
  out_txt := fun_393(txt, a_nonlinearpattern, a_indexName, a_systemType, a_nonlinearpatternT);
end generateStaticNonlinearData;

protected function fun_395
  input Tpl.Text in_txt;
  input BackendDAE.VarKind in_a_varKind;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_varKind)
    local
      Tpl.Text txt;

    case ( txt,
           BackendDAE.PARAM() )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("VAR_KIND_PARAMETER"));
      then txt;

    case ( txt,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("VAR_KIND_VARIABLE"));
      then txt;
  end match;
end fun_395;

protected function fun_396
  input Tpl.Text in_txt;
  input SimCodeVar.SimVar in_mArg;
  input DAE.ComponentRef in_a_cr;
  input Tpl.Text in_a_cComment;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg, in_a_cr, in_a_cComment)
    local
      Tpl.Text txt;
      DAE.ComponentRef a_cr;
      Tpl.Text a_cComment;
      BackendDAE.VarKind i_varKind;
      Tpl.Text l_kind;

    case ( txt,
           SimCodeVar.SIMVAR(type_ = DAE.T_REAL(varLst = _), varKind = i_varKind),
           a_cr,
           a_cComment )
      equation
        l_kind = fun_395(Tpl.emptyTxt, i_varKind);
        txt = Tpl.writeText(txt, a_cComment);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("sysData->nominal[i] = getNominalFromScalarIdx(data->simulationInfo, data->modelData, "));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "sysData->min[i]     = getMinFromScalarIdx(data->simulationInfo, data->modelData, VAR_TYPE_REAL, "
                                }, false));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "sysData->max[i++]   = getMaxFromScalarIdx(data->simulationInfo, data->modelData, VAR_TYPE_REAL, "
                                }, false));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(");"));
      then txt;

    case ( txt,
           _,
           a_cr,
           a_cComment )
      equation
        txt = Tpl.writeText(txt, a_cComment);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("sysData->nominal[i] = "));
        txt = CodegenCFunctions.crefAttributes(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ".nominal;\n",
                                    "sysData->min[i]     = "
                                }, false));
        txt = CodegenCFunctions.crefAttributes(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ".min;\n",
                                    "sysData->max[i++]   = "
                                }, false));
        txt = CodegenCFunctions.crefAttributes(txt, a_cr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(".max;"));
      then txt;
  end match;
end fun_396;

protected function lm_397
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      DAE.ComponentRef i_cr;
      SimCodeVar.SimVar ret_3;
      SimCode.SimCode ret_2;
      DAE.ComponentRef ret_1;
      Tpl.Text l_cComment;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_cr :: rest )
      equation
        l_cComment = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("/* static nls data for "));
        l_cComment = CodegenUtil.crefStrNoUnderscore(l_cComment, i_cr);
        l_cComment = Tpl.writeTok(l_cComment, Tpl.ST_STRING(" */"));
        ret_1 = ComponentReference.crefRemovePrePrefix(i_cr);
        ret_2 = SimCodeUtil.getSimCode();
        ret_3 = SimCodeUtil.cref2simvar(ret_1, ret_2);
        txt = fun_396(txt, ret_3, i_cr, l_cComment);
        txt = Tpl.nextIter(txt);
        txt = lm_397(txt, rest);
      then txt;
  end match;
end lm_397;

public function generateStaticInitialData
  input Tpl.Text txt;
  input list<DAE.ComponentRef> a_crefs;
  input String a_indexName;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_bodyStaticData;
  Tpl.Text l_systemType;
algorithm
  l_systemType := Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NONLINEAR_SYSTEM_DATA"));
  l_bodyStaticData := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_bodyStaticData := lm_397(l_bodyStaticData, a_crefs);
  l_bodyStaticData := Tpl.popIter(l_bodyStaticData);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                   "\n",
                                   "OMC_DISABLE_OPT\n",
                                   "void initializeStaticData"
                               }, false));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA* data, threadData_t *threadData, NONLINEAR_SYSTEM_DATA *sysData, modelica_boolean initSparsePattern, modelica_boolean initNonlinearPattern)\n",
                                       "{\n",
                                       "  int i=0;\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_bodyStaticData);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "/* initial sparse pattern */\n",
                                       "if (initSparsePattern) {\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("initializeSparsePattern"));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("(sysData);\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "}\n",
                                       "if (initNonlinearPattern) {\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("initializeNonlinearPattern"));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("(sysData);\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("}\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "}\n",
                                       "\n",
                                       "OMC_DISABLE_OPT\n",
                                       "void freeStaticData"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA* data, threadData_t *threadData, NONLINEAR_SYSTEM_DATA *sysData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("freeSparsePattern"));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("(sysData);\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end generateStaticInitialData;

protected function lm_399
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_items, in_a_sub)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      Tpl.Text a_sub;
      Integer x_i0;
      DAE.ComponentRef i_cr;

    case ( txt,
           {},
           a_sub )
      then (txt, a_sub);

    case ( txt,
           i_cr :: rest,
           a_sub )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("array["));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = "));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_cr, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
        txt = Tpl.nextIter(txt);
        (txt, a_sub) = lm_399(txt, rest, a_sub);
      then (txt, a_sub);
  end match;
end lm_399;

public function getIterationVars
  input Tpl.Text txt;
  input list<DAE.ComponentRef> a_crefs;
  input String a_indexName;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_vars;
  Tpl.Text l_sub;
algorithm
  l_sub := Tpl.emptyTxt;
  l_vars := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (l_vars, l_sub) := lm_399(l_vars, a_crefs, l_sub);
  l_vars := Tpl.popIter(l_vars);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                   "\n",
                                   "OMC_DISABLE_OPT\n",
                                   "void getIterationVars"
                               }, false));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA* data, double *array)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_vars);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end getIterationVars;

protected function fun_401
  input Tpl.Text in_txt;
  input SimCode.JacobianMatrix in_a_jacobianMatrix;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_jacobianMatrix, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      String i_name;

    case ( txt,
           SimCode.JAC_MATRIX(matrixName = i_name),
           a_modelNamePrefix )
      equation
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "functionJac");
        txt = Tpl.writeStr(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_column"));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_401;

protected function fun_402
  input Tpl.Text in_txt;
  input SimCode.JacobianMatrix in_a_jacobianMatrix;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_jacobianMatrix, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      String i_name;

    case ( txt,
           SimCode.JAC_MATRIX(matrixName = i_name),
           a_modelNamePrefix )
      equation
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "initialAnalyticJacobian");
        txt = Tpl.writeStr(txt, i_name);
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_402;

protected function fun_403
  input Tpl.Text in_txt;
  input SimCode.JacobianMatrix in_a_jacobianMatrix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_jacobianMatrix)
    local
      Tpl.Text txt;
      Integer i_jacindex;

    case ( txt,
           SimCode.JAC_MATRIX(jacobianIndex = i_jacindex) )
      equation
        txt = Tpl.writeStr(txt, intString(i_jacindex));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_403;

protected function lm_404
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;
  input Integer in_a_i1;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_i1)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      Integer a_i1;
      Integer x_i2;
      DAE.ComponentRef i_s;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_s :: rest,
           a_i1 )
      equation
        x_i2 = Tpl.getIteri_i0(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("statesetData["));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].states["));
        txt = Tpl.writeStr(txt, intString(x_i2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = &"));
        txt = CodegenCFunctions.crefVarInfo(txt, i_s);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
        txt = Tpl.nextIter(txt);
        txt = lm_404(txt, rest, a_i1);
      then txt;
  end match;
end lm_404;

protected function lm_405
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;
  input Integer in_a_i1;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_i1)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      Integer a_i1;
      Integer x_i2;
      DAE.ComponentRef i_cstate;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_cstate :: rest,
           a_i1 )
      equation
        x_i2 = Tpl.getIteri_i0(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("statesetData["));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].statescandidates["));
        txt = Tpl.writeStr(txt, intString(x_i2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = &"));
        txt = CodegenCFunctions.crefVarInfo(txt, i_cstate);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
        txt = Tpl.nextIter(txt);
        txt = lm_405(txt, rest, a_i1);
      then txt;
  end match;
end lm_405;

protected function fun_406
  input Tpl.Text in_txt;
  input SimCode.StateSet in_a_set;
  input Integer in_a_i1;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_set, in_a_i1, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      Integer a_i1;
      String a_modelNamePrefix;
      DAE.ComponentRef i_crA;
      Integer i_nStates;
      Integer i_nCandidates;
      list<DAE.ComponentRef> i_statescandidates;
      list<DAE.ComponentRef> i_states;
      SimCode.JacobianMatrix i_jacobianMatrix;
      Tpl.Text l_statescandidatesvars;
      Tpl.Text l_statesvars;
      Tpl.Text l_jacIndex;
      Tpl.Text l_initialJac;
      Tpl.Text l_generatedJac;

    case ( txt,
           SimCode.SES_STATESET(jacobianMatrix = i_jacobianMatrix, states = i_states, statescandidates = i_statescandidates, nCandidates = i_nCandidates, nStates = i_nStates, crA = i_crA),
           a_i1,
           a_modelNamePrefix )
      equation
        l_generatedJac = fun_401(Tpl.emptyTxt, i_jacobianMatrix, a_modelNamePrefix);
        l_initialJac = fun_402(Tpl.emptyTxt, i_jacobianMatrix, a_modelNamePrefix);
        l_jacIndex = fun_403(Tpl.emptyTxt, i_jacobianMatrix);
        l_statesvars = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        l_statesvars = lm_404(l_statesvars, i_states, a_i1);
        l_statesvars = Tpl.popIter(l_statesvars);
        l_statescandidatesvars = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        l_statescandidatesvars = lm_405(l_statescandidatesvars, i_statescandidates, a_i1);
        l_statescandidatesvars = Tpl.popIter(l_statescandidatesvars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("assertStreamPrint(NULL, nStateSets > "));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", \"Internal Error: nStateSets mismatch!\");\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].nCandidates = "));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].nStates = "));
        txt = Tpl.writeStr(txt, intString(i_nStates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].nDummyStates = "));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-"));
        txt = Tpl.writeStr(txt, intString(i_nStates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].states = (VAR_INFO**) calloc("));
        txt = Tpl.writeStr(txt, intString(i_nStates));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",sizeof(VAR_INFO));\n"));
        txt = Tpl.writeText(txt, l_statesvars);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("statesetData["));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].statescandidates = (VAR_INFO**) calloc("));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",sizeof(VAR_INFO));\n"));
        txt = Tpl.writeText(txt, l_statescandidatesvars);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("statesetData["));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].A = &"));
        txt = CodegenCFunctions.crefVarInfo(txt, i_crA);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].rowPivot = (modelica_integer*) calloc("));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-"));
        txt = Tpl.writeStr(txt, intString(i_nStates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",sizeof(modelica_integer));\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].colPivot = (modelica_integer*) calloc("));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",sizeof(modelica_integer));\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].J = (modelica_real*) calloc("));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("*("));
        txt = Tpl.writeStr(txt, intString(i_nCandidates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-"));
        txt = Tpl.writeStr(txt, intString(i_nStates));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "),sizeof(modelica_real));\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].analyticalJacobianColumn = "));
        txt = Tpl.writeText(txt, l_generatedJac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initialAnalyticalJacobian = "));
        txt = Tpl.writeText(txt, l_initialJac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "statesetData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].jacobianIndex = "));
        txt = Tpl.writeText(txt, l_jacIndex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "\n"
                                }, true));
      then txt;

    case ( txt,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_406;

protected function lm_407
  input Tpl.Text in_txt;
  input list<SimCode.StateSet> in_items;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.StateSet> rest;
      String a_modelNamePrefix;
      Integer x_i1;
      SimCode.StateSet i_set;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_set :: rest,
           a_modelNamePrefix )
      equation
        x_i1 = Tpl.getIteri_i0(txt);
        txt = fun_406(txt, i_set, x_i1, a_modelNamePrefix);
        txt = Tpl.nextIter(txt);
        txt = lm_407(txt, rest, a_modelNamePrefix);
      then txt;
  end match;
end lm_407;

public function functionInitialStateSets
  input Tpl.Text txt;
  input SimCode.SimCode a_simCode;
  input list<SimCode.StateSet> a_stateSets;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected

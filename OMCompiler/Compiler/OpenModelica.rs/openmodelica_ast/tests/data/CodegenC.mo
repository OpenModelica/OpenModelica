        (l_e1, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_exp1, SimCodeFunction.contextZeroCross, a_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("start_index = current_index;\n"));

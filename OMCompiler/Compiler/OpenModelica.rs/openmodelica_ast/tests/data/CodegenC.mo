protected function fun_616
  input Tpl.Text in_txt;
  input DAE.Exp in_a_relation;
  input Integer in_a_index1;
  input Tpl.Text in_a_forTail;
  input Tpl.Text in_a_tmp__;
  input Tpl.Text in_a_forBody;
  input Tpl.Text in_a_forHead;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_a_relation, in_a_index1, in_a_forTail, in_a_tmp__, in_a_forBody, in_a_forHead, in_a_auxFunction, in_a_varDecls, in_a_preExp, in_a_context)
    local
      Tpl.Text txt;
      Integer a_index1;
      Tpl.Text a_forTail;
      Tpl.Text a_tmp__;
      Tpl.Text a_forBody;
      Tpl.Text a_forHead;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      SimCodeFunction.Context a_context;
      DAE.Exp i_exp;
      Tpl.Text l_res;

    case ( txt,
           (i_exp as DAE.RELATION(exp1 = _)),
           _,
           a_forTail,
           a_tmp__,
           a_forBody,
           a_forHead,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           a_context )
      equation
        (l_res, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_exp, a_context, a_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("start_index = current_index;\n"));
        txt = Tpl.writeText(txt, a_forHead);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, a_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, a_forBody);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->relations[start_index"));
        txt = Tpl.writeText(txt, a_tmp__);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = "));
        txt = Tpl.writeText(txt, l_res);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "current_index++;\n"
                                }, true));
        txt = Tpl.writeText(txt, a_forTail);
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_index1,
           a_forTail,
           _,
           _,
           a_forHead,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           _ )
      equation
        txt = Tpl.writeText(txt, a_forHead);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* UNKNOWN Relation for "));
        txt = Tpl.writeStr(txt, intString(a_index1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " */\n",
                                    "current_index++;\n"
                                }, true));
        txt = Tpl.writeText(txt, a_forTail);
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_616;

public function relationTpl
  input Tpl.Text txt;
  input Integer a_index1;
  input DAE.Exp a_relation;
  input Option<list<BackendDAE.SimIterator>> a_iter;
  input SimCodeFunction.Context a_context;
  input Tpl.Text a_varDecls;
  input Tpl.Text a_auxFunction;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_auxFunction;
protected
  Tpl.Text l_forTail;
  Tpl.Text l_tmp__;
  Tpl.Text l_forBody;
  Tpl.Text l_forHead;
  Tpl.Text l_sub;
  Tpl.Text l_preExp;
algorithm
  l_preExp := Tpl.emptyTxt;
  l_sub := Tpl.emptyTxt;
  (l_forHead, l_sub, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_609(Tpl.emptyTxt, a_iter, l_sub, a_auxFunction, a_varDecls, l_preExp);
  (l_forBody, l_sub, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_612(Tpl.emptyTxt, a_iter, l_sub, out_a_auxFunction, out_a_varDecls, l_preExp);
  l_tmp__ := fun_613(Tpl.emptyTxt, a_iter);
  l_forTail := fun_615(Tpl.emptyTxt, a_iter);
  (out_txt, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_616(txt, a_relation, a_index1, l_forTail, l_tmp__, l_forBody, l_forHead, out_a_auxFunction, out_a_varDecls, l_preExp, a_context);
end relationTpl;

protected function fun_618
  input Tpl.Text in_txt;
  input String in_mArg;
  input DAE.ComponentRef in_a_cr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg, in_a_cr)
    local
      Tpl.Text txt;
      DAE.ComponentRef a_cr;
      Tpl.Text txt_0;

    case ( txt,
           "modelica_real",
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("%g"));
      then txt;

    case ( txt,
           "modelica_integer",
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"OMC_INT_FORMAT\""));
      then txt;

    case ( txt,
           "modelica_boolean",
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("%d"));
      then txt;

    case ( txt,
           "modelica_string",
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("%s"));
      then txt;

    case ( txt,
           _,
           a_cr )
      equation
        txt_0 = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("Do not know what printf argument to give "));
        txt_0 = CodegenUtil.crefStr(txt_0, a_cr);
        txt = CodegenUtil.error(txt, Tpl.sourceInfo("CodegenC.tpl", 5213, 14), Tpl.textString(txt_0));
      then txt;
  end match;
end fun_618;

public function crefToPrintfArg
  input Tpl.Text txt;
  input DAE.ComponentRef a_cr;

  output Tpl.Text out_txt;
protected
  String str_1;
  Tpl.Text txt_0;
algorithm
  txt_0 := crefType(Tpl.emptyTxt, a_cr);
  str_1 := Tpl.textString(txt_0);
  out_txt := fun_618(txt, str_1, a_cr);
end crefToPrintfArg;

public function crefType
  input Tpl.Text in_txt;
  input DAE.ComponentRef in_a_cr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_cr)
    local
      Tpl.Text txt;
      DAE.ComponentRef i_componentRef;
      DAE.Type i_identType;

    case ( txt,
           DAE.CREF_IDENT(identType = i_identType) )
      equation
        txt = CodegenCFunctions.expTypeModelica(txt, i_identType);
      then txt;

    case ( txt,
           DAE.CREF_QUAL(componentRef = i_componentRef) )
      equation
        txt = crefType(txt, i_componentRef);
      then txt;

    case ( txt,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("crefType:ERROR"));
      then txt;
  end match;
end crefType;


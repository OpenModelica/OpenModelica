protected function fun_80
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Integer in_a_baseClockIdx;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg, in_a_baseClockIdx)
    local
      Tpl.Text txt;
      Integer a_baseClockIdx;

    case ( txt,
           false,
           _ )
      then txt;

    case ( txt,
           _,
           a_baseClockIdx )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->baseClocks["));
        txt = Tpl.writeStr(txt, intString(a_baseClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].interval = DIVISION((modelica_real)data->simulationInfo->baseClocks["));
        txt = Tpl.writeStr(txt, intString(a_baseClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].intervalCounter, (modelica_real)data->simulationInfo->baseClocks["));
        txt = Tpl.writeStr(txt, intString(a_baseClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].resolution, \"base-clock["));
        txt = Tpl.writeStr(txt, intString(a_baseClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].interval = intervalCounter/resolution\");"));
      then txt;
  end match;
end fun_80;

protected function fun_81
  input Tpl.Text in_txt;

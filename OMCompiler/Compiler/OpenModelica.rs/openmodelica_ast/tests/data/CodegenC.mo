    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION SES_FOR_RESIDUAL"));
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           SimCode.SES_GENERIC_RESIDUAL(index = _),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION SES_GENERIC_RESIDUAL"));
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_MIXED(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_eqfuncs) = equationMixed(txt, i_e, a_context, a_eqfuncs, a_modelNamePrefix, a_init);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);


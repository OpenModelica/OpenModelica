    local
      Tpl.Text txt;
      Integer a_i0;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDeclsRes;
      Integer i_index;
      DAE.Exp i_exp;

    case ( txt,
           SimCode.SES_RESIDUAL(exp = i_exp, index = i_index),
           a_i0,
           a_auxFunction,
           a_varDeclsRes )
      equation
        (txt, a_varDeclsRes, a_auxFunction) = equationResidual(txt, i_exp, a_varDeclsRes, a_auxFunction, i_index, a_i0);
      then (txt, a_auxFunction, a_varDeclsRes);

    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           _,
           a_auxFunction,

protected function fun_977
  input Tpl.Text in_txt;
  input SimCode.SimGenericCall in_a_call;
  input Tpl.Text in_a_jac;
  input Tpl.Text in_a_sub__name;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_call, in_a_jac, in_a_sub__name, in_a_context)
    local
      Tpl.Text txt;
      Tpl.Text a_jac;
      Tpl.Text a_sub__name;
      SimCodeFunction.Context a_context;
      Integer i_index;
      list<BackendDAE.SimIterator> i_iters;
      Boolean i_resizable;
      Tpl.Text l_idx__;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDecls;
      Tpl.Text l_preExp;
      Tpl.Text l_sub;

    case ( txt,
           SimCode.SINGLE_GENERIC_CALL(resizable = i_resizable, iters = i_iters, index = i_index),
           a_jac,
           a_sub__name,
           a_context )
      equation
        l_sub = Tpl.emptyTxt;
        l_preExp = Tpl.emptyTxt;
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_idx__, l_sub, l_auxFunction, l_varDecls, l_preExp) = fun_974(Tpl.emptyTxt, i_resizable, l_sub, l_auxFunction, l_varDecls, l_preExp, a_context, i_iters);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("void genericCall_"));
        txt = Tpl.writeText(txt, a_sub__name);
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("(DATA *data, threadData_t *threadData"));
        txt = Tpl.writeText(txt, a_jac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", const int equationIndexes[2], "));
        txt = Tpl.writeText(txt, l_idx__);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(");"));
      then txt;

    case ( txt,
           SimCode.IF_GENERIC_CALL(resizable = i_resizable, iters = i_iters, index = i_index),
           a_jac,
           a_sub__name,
           a_context )
      equation
        l_sub = Tpl.emptyTxt;
        l_preExp = Tpl.emptyTxt;
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_idx__, l_sub, l_auxFunction, l_varDecls, l_preExp) = fun_976(Tpl.emptyTxt, i_resizable, l_sub, l_auxFunction, l_varDecls, l_preExp, a_context, i_iters);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("void genericCall_"));
        txt = Tpl.writeText(txt, a_sub__name);
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("(DATA *data, threadData_t *threadData"));
        txt = Tpl.writeText(txt, a_jac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", const int equationIndexes[2], "));
        txt = Tpl.writeText(txt, l_idx__);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(");"));
      then txt;

    case ( txt,
           _,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_977;


protected function lm_779
  input Tpl.Text in_txt;
  input list<SimCodeVar.SimVar> in_items;
  input Tpl.Text in_a_auxFunctions;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunctions;
algorithm
  (out_txt, out_a_auxFunctions) :=
  match(in_txt, in_items, in_a_auxFunctions, in_a_context)
    local
      Tpl.Text txt;
      list<SimCodeVar.SimVar> rest;
      Tpl.Text a_auxFunctions;
      SimCodeFunction.Context a_context;
      Integer x_i0;
      DAE.ComponentRef i_name;

    case ( txt,
           {},
           a_auxFunctions,
           _ )
      then (txt, a_auxFunctions);

    case ( txt,
           SimCodeVar.SIMVAR(name = i_name) :: rest,

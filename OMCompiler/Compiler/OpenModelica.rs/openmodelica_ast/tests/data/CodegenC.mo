      equation
        x_i0 = Tpl.getIteri_i0(txt);
        (txt, a_auxFunction, a_varDecls) = fun_287(txt, i_eq, x_i0, i_col, i_row, a_auxFunction, a_varDecls);
        txt = Tpl.nextIter(txt);
        (txt, a_auxFunction, a_varDecls) = lm_288(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);
  end match;
end lm_288;


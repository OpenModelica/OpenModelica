protected function lm_622
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      String a_modelNamePrefix;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_eq :: rest,
           a_modelNamePrefix )
      equation
        txt = equation_impl(txt, -1, -1, i_eq, SimCodeFunction.contextSimulationDiscrete, a_modelNamePrefix, false);
        txt = Tpl.nextIter(txt);
        txt = lm_622(txt, rest, a_modelNamePrefix);
      then txt;
  end match;
end lm_622;

public function functionAssertsforCheck
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_algAndEqAssertsEquations;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_622(out_txt, a_algAndEqAssertsEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "/* function to check assert after a step is done */\n",
                                       "OMC_DISABLE_OPT\n",
                                       "int "
                                   }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "checkForAsserts");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := equations_call(out_txt, a_algAndEqAssertsEquations, a_modelNamePrefix, SimCodeFunction.contextSimulationDiscrete, "");
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "\n",
                                       "return 0;\n"
                                   }, true));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionAssertsforCheck;

public function functionlinearmodel
  input Tpl.Text in_txt;
  input SimCode.ModelInfo in_a_modelInfo;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_modelInfo, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      list<SimCodeVar.SimVar> i_vars_algVars;
      list<SimCodeVar.SimVar> i_vars_outputVars;
      list<SimCodeVar.SimVar> i_vars_inputVars;
      list<SimCodeVar.SimVar> i_vars_stateVars;
      Integer i_varInfo_numAlgVars;
      Integer i_varInfo_numOutVars;
      Integer i_varInfo_numInVars;
      Integer i_varInfo_numStateVars;
      Tpl.Text l_varNameZ;
      Tpl.Text l_varNameY;
      Tpl.Text l_varNameU;
      Tpl.Text l_varNameX;
      Tpl.Text l_vectorZ;
      Tpl.Text l_vectorY;
      Tpl.Text l_vectorU;
      Tpl.Text l_vectorX;
      Tpl.Text l_matrixDz;
      Tpl.Text l_matrixCz;
      Tpl.Text l_matrixD;
      Tpl.Text l_matrixC;
      Tpl.Text l_matrixB;
      Tpl.Text l_matrixA;

    case ( txt,
           SimCode.MODELINFO(varInfo = SimCode.VARINFO(numStateVars = i_varInfo_numStateVars, numInVars = i_varInfo_numInVars, numOutVars = i_varInfo_numOutVars, numAlgVars = i_varInfo_numAlgVars), vars = SimCodeVar.SIMVARS(stateVars = i_vars_stateVars, inputVars = i_vars_inputVars, outputVars = i_vars_outputVars, algVars = i_vars_algVars)),
           a_modelNamePrefix )
      equation
        l_matrixA = genMatrix(Tpl.emptyTxt, "A", "n", "n", i_varInfo_numStateVars, i_varInfo_numStateVars);
        l_matrixB = genMatrix(Tpl.emptyTxt, "B", "n", "m", i_varInfo_numStateVars, i_varInfo_numInVars);
        l_matrixC = genMatrix(Tpl.emptyTxt, "C", "p", "n", i_varInfo_numOutVars, i_varInfo_numStateVars);
        l_matrixD = genMatrix(Tpl.emptyTxt, "D", "p", "m", i_varInfo_numOutVars, i_varInfo_numInVars);
        l_matrixCz = genMatrix(Tpl.emptyTxt, "Cz", "nz", "n", i_varInfo_numAlgVars, i_varInfo_numStateVars);
        l_matrixDz = genMatrix(Tpl.emptyTxt, "Dz", "nz", "m", i_varInfo_numAlgVars, i_varInfo_numInVars);
        l_vectorX = genVector(Tpl.emptyTxt, "x", "n", i_varInfo_numStateVars, 0);
        l_vectorU = genVector(Tpl.emptyTxt, "u", "m", i_varInfo_numInVars, 1);
        l_vectorY = genVector(Tpl.emptyTxt, "y", "p", i_varInfo_numOutVars, 2);
        l_vectorZ = genVector(Tpl.emptyTxt, "z", "nz", i_varInfo_numAlgVars, 2);
        l_varNameX = getVarNameC(Tpl.emptyTxt, i_vars_stateVars, "x");
        l_varNameU = getVarNameC(Tpl.emptyTxt, i_vars_inputVars, "u");
        l_varNameY = getVarNameC(Tpl.emptyTxt, i_vars_outputVars, "y");
        l_varNameZ = getVarNameC(Tpl.emptyTxt, i_vars_algVars, "z");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const char *"));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "linear_model_frame");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "()\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("return \"model linearized_model \\\""));
        txt = Tpl.writeStr(txt, a_modelNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\\\"\\n\"\n",
                                    "\"  parameter Integer n = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numStateVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of states\\\";\\n\"\n",
                                    "\"  parameter Integer m = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numInVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of inputs\\\";\\n\"\n",
                                    "\"  parameter Integer p = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numOutVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of outputs\\\";\\n\"\n",
                                    "\"\\n\"\n",
                                    "\"  parameter Real x0[n] = %s;\\n\"\n",
                                    "\"  parameter Real u0[m] = %s;\\n\"\n",
                                    "\"\\n\"\n"
                                }, true));
        txt = Tpl.writeText(txt, l_matrixA);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixB);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixC);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixD);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("\"\\n\"\n"));
        txt = Tpl.writeText(txt, l_vectorX);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorU);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorY);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("\"\\n\"\n"));
        txt = Tpl.writeText(txt, l_varNameX);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varNameU);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varNameY);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\"equation\\n\"\n",
                                    "\"  der(x) = A * x + B * u;\\n\"\n",
                                    "\"  y = C * x + D * u;\\n\"\n",
                                    "\"end linearized_model;\\n\";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "const char *"
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "linear_model_datarecovery_frame");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "()\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("return \"model linearized_model \\\""));
        txt = Tpl.writeStr(txt, a_modelNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\\\"\\n\"\n",
                                    "\"  parameter Integer n = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numStateVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of states\\\";\\n\"\n",
                                    "\"  parameter Integer m = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numInVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of inputs\\\";\\n\"\n",
                                    "\"  parameter Integer p = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numOutVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"number of outputs\\\";\\n\"\n",
                                    "\"  parameter Integer nz = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numAlgVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " \\\"data recovery variables\\\";\\n\"\n",
                                    "\"\\n\"\n",
                                    "\"  parameter Real x0[n] = %s;\\n\"\n",
                                    "\"  parameter Real u0[m] = %s;\\n\"\n",
                                    "\"  parameter Real z0[nz] = %s;\\n\"\n",
                                    "\"\\n\"\n"
                                }, true));
        txt = Tpl.writeText(txt, l_matrixA);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixB);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixC);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixD);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixCz);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixDz);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("\"\\n\"\n"));
        txt = Tpl.writeText(txt, l_vectorX);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorU);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorY);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorZ);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("\"\\n\"\n"));
        txt = Tpl.writeText(txt, l_varNameX);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varNameU);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varNameY);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varNameZ);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\"equation\\n\"\n",
                                    "\"  der(x) = A * x + B * u;\\n\"\n",
                                    "\"  y = C * x + D * u;\\n\"\n",
                                    "\"  z = Cz * x + Dz * u;\\n\"\n",
                                    "\"end linearized_model;\\n\";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end functionlinearmodel;

public function functionlinearmodelMatlab
  input Tpl.Text in_txt;
  input SimCode.ModelInfo in_a_modelInfo;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_modelInfo, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      list<SimCodeVar.SimVar> i_vars_outputVars;
      list<SimCodeVar.SimVar> i_vars_inputVars;
      list<SimCodeVar.SimVar> i_vars_stateVars;
      Integer i_varInfo_numOutVars;
      Integer i_varInfo_numInVars;
      Integer i_varInfo_numStateVars;
      Tpl.Text l_matrixD;
      Tpl.Text l_matrixC;
      Tpl.Text l_matrixB;
      Tpl.Text l_matrixA;

    case ( txt,
           SimCode.MODELINFO(varInfo = SimCode.VARINFO(numStateVars = i_varInfo_numStateVars, numInVars = i_varInfo_numInVars, numOutVars = i_varInfo_numOutVars), vars = SimCodeVar.SIMVARS(stateVars = i_vars_stateVars, inputVars = i_vars_inputVars, outputVars = i_vars_outputVars)),
           a_modelNamePrefix )
      equation
        l_matrixA = genMatrixMatlab(Tpl.emptyTxt, "A", "n", "n", i_varInfo_numStateVars, i_varInfo_numStateVars);
        l_matrixB = genMatrixMatlab(Tpl.emptyTxt, "B", "n", "m", i_varInfo_numStateVars, i_varInfo_numInVars);
        l_matrixC = genMatrixMatlab(Tpl.emptyTxt, "C", "p", "n", i_varInfo_numOutVars, i_varInfo_numStateVars);
        l_matrixD = genMatrixMatlab(Tpl.emptyTxt, "D", "p", "m", i_varInfo_numOutVars, i_varInfo_numInVars);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const char *"));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "linear_model_frame");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "()\n",
                                    "{\n",
                                    "  return \"function [A, B, C, D, stateVars, inputVars, outputVars] = linearized_model()\\n\"\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"%% "));
        txt = Tpl.writeStr(txt, a_modelNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\\n\"\n",
                                    "\"%% der(x) = A * x + B * u\\n\"\n",
                                    "\"%% y = C * x + D * u\\n\"\n",
                                    "\"  n = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numStateVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "; %% number of states\\n\"\n",
                                    "\"  m = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numInVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "; %% number of inputs\\n\"\n",
                                    "\"  p = "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_varInfo_numOutVars));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "; %% number of outputs\\n\"\n",
                                    "\"\\n\"\n",
                                    "\"  x0 = %s;\\n\"\n",
                                    "\"  u0 = %s;\\n\"\n",
                                    "\"\\n\"\n"
                                }, true));
        txt = Tpl.writeText(txt, l_matrixA);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixB);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixC);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_matrixD);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"  stateVars  = {"));
        txt = getVarNameMatlab(txt, i_vars_stateVars, "x0");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\\n\"\n",
                                    "\"  inputVars  = {"
                                }, false));
        txt = getVarNameMatlab(txt, i_vars_inputVars, "u0");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\\n\"\n",
                                    "\"  outputVars = {"
                                }, false));
        txt = getVarNameMatlab(txt, i_vars_outputVars, "y0");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\\n\"\n",
                                    "\"  Ts = %g; %% stop time\\n\\n\"\n",
                                    "\"end\";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "const char *"
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "linear_model_datarecovery_frame");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "()\n",
                                    "{\n",
                                    "  errorStreamPrint(OMC_LOG_STDOUT, 0, \"Linearization with data recovery not implemented for Matlab.\");\n",
                                    "  return \"\";\n",
                                    "}"
                                }, false));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end functionlinearmodelMatlab;


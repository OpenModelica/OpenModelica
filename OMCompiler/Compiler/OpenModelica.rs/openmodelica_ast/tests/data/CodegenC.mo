protected function fun_724
  input Tpl.Text in_txt;
  input String in_a_selection;
  input Tpl.Text in_a_args;
  input Tpl.Text in_a_nFuncs;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_selection, in_a_args, in_a_nFuncs)
    local
      Tpl.Text txt;
      Tpl.Text a_args;
      Tpl.Text a_nFuncs;
      String i_selection;

    case ( txt,
           "",
           a_args,
           a_nFuncs )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("for (int id = 0; id < "));
        txt = Tpl.writeText(txt, a_nFuncs);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("; id++) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("eqFunctions[id]("));
        txt = Tpl.writeText(txt, a_args);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(");\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           i_selection,
           a_args,
           a_nFuncs )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("if ("));
        txt = Tpl.writeStr(txt, i_selection);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(") {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("for (int i = 0; i < "));
        txt = Tpl.writeStr(txt, i_selection);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("->n; i++) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int id = "));
        txt = Tpl.writeStr(txt, i_selection);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "->idx[i];\n",
                                    "eqFunctions[id]("
                                }, false));
        txt = Tpl.writeText(txt, a_args);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(");\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("}\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("} else {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("for (int id = 0; id < "));
        txt = Tpl.writeText(txt, a_nFuncs);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("; id++) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("eqFunctions[id]("));
        txt = Tpl.writeText(txt, a_args);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(");\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("}\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;
  end match;
end fun_724;

protected function lm_725
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_name;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_name)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_name;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_eq :: rest,
           a_name )
      equation
        txt = Tpl.writeText(txt, a_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt = CodegenUtilSimulation.equationIndexGeneral(txt, i_eq);
        txt = Tpl.nextIter(txt);
        txt = lm_725(txt, rest, a_name);
      then txt;
  end match;
end lm_725;

public function equations_call
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_a_eqs;
  input String in_a_modelNamePrefix;
  input SimCodeFunction.Context in_a_context;
  input String in_a_selection;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eqs, in_a_modelNamePrefix, in_a_context, in_a_selection)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      SimCodeFunction.Context a_context;
      String a_selection;
      list<SimCode.SimEqSystem> i_eqs;
      Tpl.Text l_body;
      Tpl.Text l_argsType;
      Tpl.Text l_args;
      Integer ret_2;
      Tpl.Text l_nFuncs;
      Tpl.Text l_name;

    case ( txt,
           {},
           _,
           _,
           _ )
      then txt;

    case ( txt,
           i_eqs,
           a_modelNamePrefix,
           a_context,
           a_selection )
      equation
        l_name = CodegenUtil.symbolName(Tpl.emptyTxt, a_modelNamePrefix, "eqFunction");
        ret_2 = listLength(i_eqs);
        l_nFuncs = Tpl.writeStr(Tpl.emptyTxt, intString(ret_2));
        l_args = fun_722(Tpl.emptyTxt, a_context);
        l_argsType = fun_723(Tpl.emptyTxt, a_context);
        l_body = fun_724(Tpl.emptyTxt, a_selection, l_args, l_nFuncs);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("static void (*const eqFunctions["));
        txt = Tpl.writeText(txt, l_nFuncs);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("])("));
        txt = Tpl.writeText(txt, l_argsType);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(") = {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_LINE(",\n")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_725(txt, i_eqs, l_name);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "\n"
                                }, true));
        txt = Tpl.writeText(txt, l_body);
      then txt;
  end match;
end equations_call;


protected function fun_177
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Tpl.Text in_a_mainBody;
  input Tpl.Text in_a_mainInit;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_mainBody;
algorithm
  (out_txt, out_a_mainBody) :=
  match(in_txt, in_mArg, in_a_mainBody, in_a_mainInit)
    local
      Tpl.Text txt;
      Tpl.Text a_mainBody;
      Tpl.Text a_mainInit;
      Boolean ret_5;
      Boolean ret_4;
      Integer ret_3;
      Integer ret_2;
      Boolean ret_1;
      Boolean ret_0;

    case ( txt,
           false,
           a_mainBody,
           _ )
      then (txt, a_mainBody);

    case ( txt,
           _,
           a_mainBody,
           a_mainInit )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "#if defined(__MINGW32__) || defined(_MSC_VER)\n",
                                    "\n",
                                    "#if !defined(_UNICODE)\n",
                                    "#define _UNICODE\n",
                                    "#endif\n",
                                    "#if !defined(UNICODE)\n",
                                    "#define UNICODE\n",
                                    "#endif\n",
                                    "\n",
                                    "#include <windows.h>\n",
                                    "char** omc_fixWindowsArgv(int argc, wchar_t **wargv)\n",
                                    "{\n",
                                    "  char** newargv;\n",
                                    "  /* Support for non-ASCII characters\n",
                                    "  * Read the unicode command line arguments and translate it to char*\n",
                                    "  */\n",
                                    "  newargv = (char**)malloc(argc*sizeof(char*));\n",
                                    "  for (int i = 0; i < argc; i++) {\n",
                                    "    newargv[i] = omc_wchar_to_multibyte_str(wargv[i]);\n",
                                    "  }\n",
                                    "  return newargv;\n",
                                    "}\n",
                                    "\n",
                                    "#define OMC_MAIN wmain\n",
                                    "#define OMC_CHAR wchar_t\n",
                                    "#define OMC_EXPORT __declspec(dllexport) extern\n",
                                    "\n",
                                    "#else\n",
                                    "#define omc_fixWindowsArgv(N, A) (A)\n",
                                    "#define OMC_MAIN main\n",
                                    "#define OMC_CHAR char\n",
                                    "#define OMC_EXPORT extern\n",
                                    "#endif\n",
                                    "\n",
                                    "#if defined(threadData)\n",
                                    "#undef threadData\n",
                                    "#endif\n",
                                    "/* call the simulation runtime main from our main! */\n",
                                    "#if defined(OMC_DLL_MAIN_DEFINE)\n",
                                    "OMC_EXPORT int omcDllMain(int argc, OMC_CHAR **argv)\n",
                                    "#else\n",
                                    "int OMC_MAIN(int argc, OMC_CHAR** argv)\n",
                                    "#endif\n",
                                    "{\n",
                                    "  char** newargv = omc_fixWindowsArgv(argc, argv);\n",
                                    "  /*\n",
                                    "    Set the error functions to be used for simulation.\n",
                                    "    The default value for them is \'functions\' version. Change it here to \'simulation\' versions\n",
                                    "  */\n",
                                    "  omc_assert = omc_assert_simulation;\n",
                                    "  omc_assert_withEquationIndexes = omc_assert_simulation_withEquationIndexes;\n",
                                    "\n",
                                    "  omc_assert_warning_withEquationIndexes = omc_assert_warning_simulation_withEquationIndexes;\n",
                                    "  omc_assert_warning = omc_assert_warning_simulation;\n",
                                    "  omc_terminate = omc_terminate_simulation;\n",
                                    "  omc_throw = omc_throw_simulation;\n",
                                    "\n",
                                    "  int res;\n",
                                    "  DATA data;\n",
                                    "  MODEL_DATA modelData;\n",
                                    "  SIMULATION_INFO simInfo;\n",
                                    "  data.modelData = &modelData;\n",
                                    "  data.simulationInfo = &simInfo;\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("measure_time_flag = "));
        ret_0 = Config.profileHtml();
        txt = fun_173(txt, ret_0);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "compiledInDAEMode = "
                                }, false));
        ret_1 = Flags.getConfigBool(Flags.DAE_MODE);
        txt = fun_174(txt, ret_1);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "compiledWithSymSolver = "
                                }, false));
        ret_2 = Flags.getConfigEnum(Flags.SYM_SOLVER);
        ret_3 = intSub(ret_2, 0);
        txt = Tpl.writeStr(txt, intString(ret_3));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.writeText(txt, a_mainInit);
        txt = Tpl.softNewLine(txt);
        (txt, a_mainBody) = CodegenCFunctions.mainTop(txt, a_mainBody, "https://trac.openmodelica.org/OpenModelica/newticket");
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        ret_4 = Flags.isSet(Flags.HPCOM);
        txt = fun_175(txt, ret_4);
        txt = Tpl.softNewLine(txt);
        ret_5 = Flags.getConfigBool(Flags.PARMODAUTO);
        txt = fun_176(txt, ret_5);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "fflush(NULL);\n",
                                    "return res;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "#ifdef __cplusplus\n",
                                    "}\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then (txt, a_mainBody);
  end match;
end fun_177;

public function simulationFile
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;
  input String in_a_guid;
  input String in_a_isModelExchangeFMU;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode, in_a_guid, in_a_isModelExchangeFMU)
    local
      Tpl.Text txt;
      String a_guid;
      String a_isModelExchangeFMU;
      SimCode.DelayedExpression i_delayedExps;
      Option<SimCode.FmiModelStructure> i_modelStructure;
      list<SimCode.SimEqSystem> i_initialEquations__lambda0;
      Integer i_varInfo_numMixedSystems;
      Integer i_varInfo_numLinearSystems;
      Integer i_varInfo_numNonLinearSystems;
      Option<tuple<HpcOmSimCode.Schedule, HpcOmSimCode.Schedule, HpcOmSimCode.Schedule>> i_hpcomData_schedules;
      Option<SimCode.SimulationSettings> i_simulationSettingsOpt;
      list<list<SimCode.SimEqSystem>> i_odeEquations;
      list<SimCode.SimEqSystem> i_localKnownVars;
      list<SimCode.SimEqSystem> i_allEquations;
      SimCode.ModelInfo i_modelInfo;
      String i_simCode_fileNamePrefix;
      String i_fileNamePrefix;
      SimCode.SimCode i_simCode;
      Boolean ret_19;
      Boolean ret_18;
      Integer ret_17;
      Boolean ret_16;
      Boolean ret_15;
      Boolean ret_14;
      Boolean ret_13;
      list<SimCode.SimEqSystem> ret_12;
      Tpl.Text txt_11;
      Boolean ret_10;
      Boolean ret_9;
      Tpl.Text l_mainBody;
      Boolean ret_7;
      Tpl.Text l_pminit;
      Boolean ret_5;
      Boolean ret_4;
      Boolean ret_3;
      Boolean ret_2;
      Tpl.Text l_mainInit;
      Tpl.Text l_modelNamePrefixStr;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(modelInfo = (i_modelInfo as SimCode.MODELINFO(varInfo = SimCode.VARINFO(numNonLinearSystems = i_varInfo_numNonLinearSystems, numLinearSystems = i_varInfo_numLinearSystems, numMixedSystems = i_varInfo_numMixedSystems))), hpcomData = HpcOmSimCode.HPCOMDATA(schedules = i_hpcomData_schedules), fileNamePrefix = (i_simCode_fileNamePrefix as i_fileNamePrefix), allEquations = i_allEquations, localKnownVars = i_localKnownVars, odeEquations = i_odeEquations, simulationSettingsOpt = i_simulationSettingsOpt, initialEquations_lambda0 = i_initialEquations__lambda0, modelStructure = i_modelStructure, delayedExps = i_delayedExps)),
           a_guid,
           a_isModelExchangeFMU )
      equation
        l_modelNamePrefixStr = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        ret_2 = stringEq("", a_isModelExchangeFMU);
        ret_3 = boolNot(ret_2);
        ret_4 = Flags.isSet(Flags.HPCOM);
        ret_5 = boolOr(ret_3, ret_4);
        l_mainInit = fun_147(Tpl.emptyTxt, ret_5);
        ret_7 = Flags.getConfigBool(Flags.PARMODAUTO);
        l_pminit = fun_148(Tpl.emptyTxt, ret_7, i_fileNamePrefix);
        l_mainBody = CodegenUtil.symbolName(Tpl.emptyTxt, Tpl.textString(l_modelNamePrefixStr), "setupDataStruc");
        l_mainBody = Tpl.writeTok(l_mainBody, Tpl.ST_STRING_LIST({
                                                  "(&data, threadData);\n",
                                                  "res = _main_initRuntimeAndSimulation(argc, newargv, &data, threadData);\n",
                                                  "if(res == 0) {\n",
                                                  "  if (omc_flag[FLAG_MOO_OPTIMIZATION]) {\n",
                                                  "    res = _main_OptimizationRuntime(argc, newargv, &data, threadData);\n",
                                                  "  } else {\n"
                                              }, true));
        l_mainBody = Tpl.pushBlock(l_mainBody, Tpl.BT_INDENT(4));
        l_mainBody = Tpl.writeText(l_mainBody, l_pminit);
        l_mainBody = Tpl.softNewLine(l_mainBody);
        l_mainBody = Tpl.writeTok(l_mainBody, Tpl.ST_LINE("res = _main_SimulationRuntime(argc, newargv, &data, threadData);\n"));
        l_mainBody = Tpl.popBlock(l_mainBody);
        l_mainBody = Tpl.writeTok(l_mainBody, Tpl.ST_STRING_LIST({
                                                  "  }\n",
                                                  "}"
                                              }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* Main Simulation File */\n",
                                    "\n",
                                    "#if defined(__cplusplus)\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        txt = simulationFileHeader(txt, i_simCode_fileNamePrefix);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#include \"simulation/solver/events.h\"\n",
                                    "#include \"simulation/arrayIndex.h\"\n",
                                    "\n"
                                }, true));
        ret_9 = stringEq("", a_isModelExchangeFMU);
        txt = fun_149(txt, ret_9, l_modelNamePrefixStr);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        ret_10 = Flags.getConfigBool(Flags.PARMODAUTO);
        txt = fun_150(txt, ret_10);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "/* dummy VARINFO and FILEINFO */\n",
                                    "const VAR_INFO dummyVAR_INFO = omc_dummyVarInfo;\n",
                                    "\n"
                                }, true));
        txt = functionInput(txt, i_simCode, i_modelInfo, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionDataInput(txt, i_simCode, i_modelInfo, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionOutput(txt, i_modelInfo, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionSetC(txt, i_modelInfo, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionSetB(txt, i_modelInfo, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionDAE(txt, i_allEquations, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = functionLocalKnownVars(txt, i_localKnownVars, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt_11 = fun_151(Tpl.emptyTxt, i_simulationSettingsOpt);
        (txt, txt_11) = functionODE(txt, i_odeEquations, txt_11, i_hpcomData_schedules, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        ret_12 = List.flatten(i_odeEquations);
        txt = functionXXX_DAG(txt, ret_12, "ODE", Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "/* forward the main in the simulation runtime */\n",
                                    "extern int _main_SimulationRuntime(int argc, char **argv, DATA *data, threadData_t *threadData);\n",
                                    "extern int _main_OptimizationRuntime(int argc, char **argv, DATA *data, threadData_t *threadData);\n",
                                    "\n",
                                    "#include \""
                                }, false));
        txt = Tpl.writeStr(txt, i_simCode_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_12jac.h\"\n",
                                    "#include \""
                                }, false));
        txt = Tpl.writeStr(txt, i_simCode_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_13opt.h\"\n",
                                    "\n",
                                    "struct OpenModelicaGeneratedFunctionCallbacks "
                                }, false));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(l_modelNamePrefixStr), "callback");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" = {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = fun_152(txt, a_isModelExchangeFMU, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* performSimulation */\n"));
        txt = fun_153(txt, a_isModelExchangeFMU, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* performQSSSimulation */\n"));
        txt = fun_154(txt, a_isModelExchangeFMU, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* updateContinuousSystem */\n"));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(l_modelNamePrefixStr), "callExternalObjectDestructors");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* callExternalObjectDestructors */\n"));
        ret_13 = intEq(i_varInfo_numNonLinearSystems, 0);
        txt = fun_155(txt, ret_13, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* initialNonLinearSystem */\n"));
        ret_14 = intEq(i_varInfo_numLinearSystems, 0);
        txt = fun_156(txt, ret_14, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(",    /* initialLinearSystem */\n"));
        ret_15 = intEq(i_varInfo_numMixedSystems, 0);
        txt = fun_157(txt, ret_15, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",    /* initialMixedSystem */\n",
                                    "#if !defined(OMC_NO_STATESELECTION)\n"

  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=

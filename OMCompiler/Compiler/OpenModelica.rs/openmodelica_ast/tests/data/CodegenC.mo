    local
      Tpl.Text txt;
      Integer a_baseClockIdx;
      DAE.Exp i_intervalCounter;
      Boolean ret_0;

    case ( txt,
           DAE.RATIONAL_CLOCK(intervalCounter = i_intervalCounter),
           a_baseClockIdx )
      equation
        ret_0 = Expression.isConst(i_intervalCounter);
        txt = fun_80(txt, ret_0, a_baseClockIdx);
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_81;

protected function lm_82
  input Tpl.Text in_txt;
  input list<SimCode.SubPartition> in_items;
  input Integer in_a_baseClockIdx;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_baseClockIdx)
    local
      Tpl.Text txt;
      list<SimCode.SubPartition> rest;
      Integer a_baseClockIdx;
      Integer x_subClockIdx;
      SimCode.SubPartition i_subPartition;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_subPartition :: rest,
           a_baseClockIdx )
      equation
        x_subClockIdx = Tpl.getIteri_i0(txt);
        txt = subPartitionStr(txt, i_subPartition, a_baseClockIdx, x_subClockIdx);
        txt = Tpl.nextIter(txt);
        txt = lm_82(txt, rest, a_baseClockIdx);
      then txt;
  end match;
end lm_82;

protected function fun_83
  input Tpl.Text in_txt;

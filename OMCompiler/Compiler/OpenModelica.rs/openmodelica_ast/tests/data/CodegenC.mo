      Integer x_baseClockIdx;
      SimCode.ClockedPartition i_partition;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDecls;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_partition :: rest )
      equation
        x_baseClockIdx = Tpl.getIteri_i0(txt);
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (txt, l_auxFunction, l_varDecls) = fun_71(txt, i_partition, l_auxFunction, l_varDecls, x_baseClockIdx);
        txt = Tpl.nextIter(txt);
        txt = lm_72(txt, rest);
      then txt;
  end match;
end lm_72;

public function functionInitSynchronous
  input Tpl.Text txt;
  input list<SimCode.ClockedPartition> a_clockedPartitions;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Integer ret_2;
  Integer ret_1;
  Tpl.Text l_body;
algorithm
  l_body := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), NONE(), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_body := lm_72(l_body, a_clockedPartitions);
  l_body := Tpl.popIter(l_body);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                   "/* Initializes the clocks of model. */\n",
                                   "void "
                               }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "function_initSynchronous");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("assertStreamPrint(threadData, data->modelData->nBaseClocks=="));
  ret_1 := listLength(a_clockedPartitions);
  out_txt := Tpl.writeStr(out_txt, intString(ret_1));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ", \"Number of base clocks doesn\'t match number of clocks that are initialized! Code generation error!\");\n",
                                       "data->simulationInfo->baseClocks = calloc("
                                   }, false));
  ret_2 := listLength(a_clockedPartitions);
  out_txt := Tpl.writeStr(out_txt, intString(ret_2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ", sizeof(BASECLOCK_DATA));\n",
                                       "\n"
                                   }, true));
  out_txt := Tpl.writeText(out_txt, l_body);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionInitSynchronous;

protected function fun_74
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;
  input DAE.Exp in_a_intervalCounter;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_mArg, in_a_auxFunction, in_a_varDecls, in_a_preExp, in_a_intervalCounter)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp a_intervalCounter;

    case ( txt,
           false,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-1 /* Interval set in _updateSynchronous */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           a_intervalCounter )
      equation
        (txt, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(txt, a_intervalCounter, SimCodeFunction.contextOther, a_preExp, a_varDecls, a_auxFunction);
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_74;

protected function fun_75
  input Tpl.Text in_txt;
  input DAE.ClockKind in_a_baseClock;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_a_baseClock, in_a_auxFunction, in_a_varDecls, in_a_preExp)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp i_intervalCounter;
      Boolean ret_0;

    case ( txt,
           DAE.RATIONAL_CLOCK(intervalCounter = i_intervalCounter),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        ret_0 = Expression.isConst(i_intervalCounter);
        (txt, a_auxFunction, a_varDecls, a_preExp) = fun_74(txt, ret_0, a_auxFunction, a_varDecls, a_preExp, i_intervalCounter);
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           DAE.INFERRED_CLOCK(),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("1"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-1"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_75;


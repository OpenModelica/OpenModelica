        l_body__ = Tpl.popIter(l_body__);
        txt = Tpl.writeText(txt, l_condition__);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("{\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_body__);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then (txt, a_preExp, a_varDecls, a_auxFunction);

    case ( txt,
           SimCode.SIM_BRANCH_STMT(condition = i_condition, body = i_body_1),
           a_context,
           a_preExp,
           a_varDecls,
           a_auxFunction )
      equation

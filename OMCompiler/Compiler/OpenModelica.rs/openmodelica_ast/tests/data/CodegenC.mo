  input Integer in_a_ls_index;
  input Integer in_a_ls_indexLinearSystem;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_ls_jacobianMatrix, in_a_modelNamePrefix, in_a_ls_simJac, in_a_ls_vars, in_a_ls_index, in_a_ls_indexLinearSystem)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> a_ls_simJac;
      list<SimCodeVar.SimVar> a_ls_vars;
      Integer a_ls_index;
      Integer a_ls_indexLinearSystem;
      Integer i_jacIndex;
      String i_name;
      Tpl.Text txt_4;
      Integer ret_3;
      Integer ret_2;
      Integer ret_1;
      Integer ret_0;

    case ( txt,
           NONE(),
           _,
           a_ls_simJac,
           a_ls_vars,
           a_ls_index,
           a_ls_indexLinearSystem )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("assertStreamPrint(NULL, nLinearSystems > "));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", \"Internal Error: nLinearSystems mismatch!\");\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].equationIndex = "));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].size = "));
        ret_0 = listLength(a_ls_vars);
        txt = Tpl.writeStr(txt, intString(ret_0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].nnz = "));
        ret_1 = listLength(a_ls_simJac);
        txt = Tpl.writeStr(txt, intString(ret_1));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].method = 0;   /* No symbolic Jacobian available */\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].strictTearingFunctionCall = NULL;\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].setA = setLinearMatrixA"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].setb = setLinearVectorb"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initializeStaticLSData = initializeStaticLSData"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(matrixName = i_name, jacobianIndex = i_jacIndex)),
           a_modelNamePrefix,
           a_ls_simJac,
           a_ls_vars,
           a_ls_index,
           a_ls_indexLinearSystem )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("assertStreamPrint(NULL, nLinearSystems > "));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", \"Internal Error: indexlinearSystem mismatch!\");\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].equationIndex = "));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].size = "));
        ret_2 = listLength(a_ls_vars);
        txt = Tpl.writeStr(txt, intString(ret_2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].nnz = "));
        ret_3 = listLength(a_ls_simJac);
        txt = Tpl.writeStr(txt, intString(ret_3));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].method = 1;   /* Symbolic Jacobian available */\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].residualFunc = residualFunc"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].strictTearingFunctionCall = NULL;\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].analyticalJacobianColumn = "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "functionJac");
        txt = Tpl.writeStr(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_column;\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initialAnalyticalJacobian = "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "initialAnalyticJacobian");
        txt = Tpl.writeStr(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].jacobianIndex = "));
        txt = Tpl.writeStr(txt, intString(i_jacIndex));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " /*jacInx*/;\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].setA = NULL;  //setLinearMatrixA"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].setb = NULL;  //setLinearVectorb"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "linearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initializeStaticLSData = initializeStaticLSData"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;

    case ( txt,
           _,
           _,
           _,
           _,
           a_ls_index,
           _ )
      equation
        txt_4 = Tpl.pushBlock(Tpl.emptyTxt, Tpl.BT_INDENT(1));
        txt_4 = Tpl.writeTok(txt_4, Tpl.ST_STRING("No jacobian create for linear system "));
        txt_4 = Tpl.writeStr(txt_4, intString(a_ls_index));
        txt_4 = Tpl.writeTok(txt_4, Tpl.ST_STRING("."));
        txt_4 = Tpl.popBlock(txt_4);
        txt = CodegenUtil.error(txt, Tpl.sourceInfo("CodegenC.tpl", 2398, 17), Tpl.textString(txt_4));
      then txt;
  end match;
end fun_271;

protected function fun_272
  input Tpl.Text in_txt;
  input Option<SimCode.JacobianMatrix> in_a_at_jacobianMatrix;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_at_jacobianMatrix, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      String i_name;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(matrixName = i_name)),
           a_modelNamePrefix )
      equation
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "functionJac");
        txt = Tpl.writeStr(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_column"));
      then txt;

    case ( txt,
           NONE(),
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NULL"));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_272;

protected function fun_273

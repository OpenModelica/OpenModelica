public function functionSavePreSynchronous
  input Tpl.Text txt;
  input list<SimCode.SubPartition> a_subPartitions;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_preVars;
algorithm
  l_preVars := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_preVars := lm_62(l_preVars, a_subPartitions);
  l_preVars := Tpl.popIter(l_preVars);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                   "/* %v% = pre(%v%)*/\n",
                                   "void "
                               }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "function_savePreSynchronous");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_preVars);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionSavePreSynchronous;


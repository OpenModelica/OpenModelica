      Integer i_index;

    case ( txt,
           {},
           a_auxFunction,
           a_varDecls )
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           BackendDAE.ZERO_CROSSING(index = i_index, relation_ = i_relation__, iter = i_iter) :: rest,
           a_auxFunction,
           a_varDecls )
      equation
        (txt, a_varDecls, a_auxFunction) = zeroCrossingTpl(txt, i_index, i_relation__, i_iter, a_varDecls, a_auxFunction);
        txt = Tpl.nextIter(txt);
        (txt, a_auxFunction, a_varDecls) = lm_591(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           _ :: rest,
           a_auxFunction,
           a_varDecls )
      equation
        (txt, a_auxFunction, a_varDecls) = lm_591(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);
  end match;

public function genericCallHeaders
  input Tpl.Text txt;
  input list<SimCode.SimGenericCall> a_genericCalls;
  input SimCodeFunction.Context a_context;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_sub__name;
  Tpl.Text l_jac;
algorithm
  l_jac := fun_971(Tpl.emptyTxt, a_context);
  l_sub__name := fun_972(Tpl.emptyTxt, a_context);
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING_LIST({
                                                                    "\n",
                                                                    "\n"
                                                                }, true)), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_978(out_txt, a_genericCalls, l_jac, l_sub__name, a_context);
  out_txt := Tpl.popIter(out_txt);
end genericCallHeaders;


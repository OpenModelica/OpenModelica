public function functionXXX_systemPartial
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_derivativEquations;
  input String a_name;
  input Integer a_n;
  input String a_modelNamePrefixStr;
  input SimCode.ModelInfo a_modelInfo;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_code;
algorithm
  l_code := fun_917(Tpl.emptyTxt, a_modelInfo, a_modelNamePrefixStr, a_derivativEquations);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING("static void "));
  out_txt := Tpl.writeStr(out_txt, a_modelNamePrefixStr);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("_function"));
  out_txt := Tpl.writeStr(out_txt, a_name);
  out_txt := Tpl.writeStr(out_txt, intString(a_n));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData, int i)\n",

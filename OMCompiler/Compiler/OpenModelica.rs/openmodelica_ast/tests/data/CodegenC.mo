protected function fun_800
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_context)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      Option<SimCode.NonlinearSystem> i_at;
      Integer i_nls_indexNonLinearSystem;
      list<DAE.ComponentRef> i_nls_crefs;
      Integer i_nls_index;
      Boolean ret_1;
      Boolean ret_0;

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = SimCode.NONLINEARSYSTEM(index = i_nls_index, crefs = i_nls_crefs, indexNonLinearSystem = i_nls_indexNonLinearSystem), alternativeTearing = i_at),
           a_context )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "int retValue;\n",
                                    "infoStreamPrint(OMC_LOG_DT, 0, \"Solving nonlinear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" (STRICT TEARING SET if tearing enabled) at time = %18.10e\", data->localData[0]->timeValue);\n"));
        ret_0 = Config.profileSome();
        txt = fun_794(txt, ret_0, i_nls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* get old value */\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_795(txt, i_nls_crefs, i_nls_indexNonLinearSystem, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("retValue = solve_nonlinear_system(data, threadData, "));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "/* check if solution process was successful */\n",
                                    "if (retValue > 0){\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int indexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "throwStreamPrintWithEquationIndexes(threadData, omc_dummyFileInfo, indexes, \"Solving non-linear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" failed at time=%.15g.\\nFor more information please use -lv LOG_NLS.\", data->localData[0]->timeValue);\n"));
        txt = fun_796(txt, i_at);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "/* write solution */\n"
                                }, true));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_797(txt, i_nls_crefs, i_nls_indexNonLinearSystem, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        ret_1 = Config.profileSome();
        txt = fun_798(txt, ret_1, i_nls_index);
        txt = Tpl.softNewLine(txt);
        txt = fun_799(txt, i_at);
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_800;


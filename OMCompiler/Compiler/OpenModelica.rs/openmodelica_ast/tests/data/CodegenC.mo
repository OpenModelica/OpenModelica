public function optimizationComponents1
  input Tpl.Text in_txt;
  input DAE.ClassAttributes in_a_classAttribute;
  input SimCode.SimCode in_a_simCode;
  input String in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_classAttribute, in_a_simCode, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      SimCode.SimCode a_simCode;
      String a_modelNamePrefixStr;
      Option<DAE.Exp> i_objectiveIntegrandE;
      Option<DAE.Exp> i_startTimeE;
      Option<DAE.Exp> i_objetiveE;
      Tpl.Text l_inputIndices;
      Tpl.Text l_inputBounds;
      Tpl.Text l_getTG;
      Tpl.Text l_setInput;
      Tpl.Text l_objectiveIntegrand;
      Tpl.Text l_startTimeOpt;
      Tpl.Text l_objectiveFunction;
      Tpl.Text l_auxFunction;
      Tpl.Text l_preExp1;
      Tpl.Text l_varDecls1;
      Tpl.Text l_preExp;
      Tpl.Text l_varDecls;
      Tpl.Text l_sub;

    case ( txt,
           DAE.OPTIMIZATION_ATTRS(objetiveE = i_objetiveE, startTimeE = i_startTimeE, objectiveIntegrandE = i_objectiveIntegrandE),
           a_simCode,
           a_modelNamePrefixStr )
      equation
        l_sub = Tpl.emptyTxt;
        l_varDecls = Tpl.emptyTxt;
        l_preExp = Tpl.emptyTxt;
        l_varDecls1 = Tpl.emptyTxt;
        l_preExp1 = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_objectiveFunction, l_sub) = fun_896(Tpl.emptyTxt, i_objetiveE, l_sub);
        (l_startTimeOpt, l_auxFunction, l_varDecls, l_preExp) = fun_897(Tpl.emptyTxt, i_startTimeE, l_auxFunction, l_varDecls, l_preExp);
        (l_objectiveIntegrand, l_sub) = fun_899(Tpl.emptyTxt, i_objectiveIntegrandE, l_sub);
        (l_setInput, l_sub) = fun_903(Tpl.emptyTxt, a_simCode, l_sub);
        (l_getTG, l_sub) = fun_907(Tpl.emptyTxt, a_simCode, l_sub);
        l_inputBounds = fun_911(Tpl.emptyTxt, a_simCode);
        l_inputIndices = fun_914(Tpl.emptyTxt, a_simCode);
        txt = Tpl.writeText(txt, l_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* objectiveFunction */\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "mayer");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, modelica_real** res, short * index_Dres)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_objectiveFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return  -1;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "/* objectiveIntegrand */\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "lagrange");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, modelica_real** res, short * index_DresB, short *index_DresC)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_varDecls1);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_preExp1);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_objectiveIntegrand);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return -1;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "/* fill buffer with optimization input indices */\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "getInputVarIndicesInOptimization");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, int* input_var_indices)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_inputIndices);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 0;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "/* opt vars  */\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "pickUpBoundsForInputsInOptimization");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, modelica_real* min, modelica_real* max, modelica_real*nominal, modelica_boolean *useNominal, char ** name, modelica_real * start, modelica_real* startTimeOpt)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_inputBounds);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("*startTimeOpt = data->simulationInfo->startTime - 1.0;\n"));
        txt = Tpl.writeText(txt, l_startTimeOpt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 0;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "setInputData");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA *data, const modelica_boolean file)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_setInput);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 0;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "getTimeGrid");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA *data, modelica_integer * nsi, modelica_real**t){\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_getTG);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 0;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _,
           _,
           _ )
      equation
        txt = CodegenUtil.error(txt, Tpl.sourceInfo("CodegenC.tpl", 7364, 16), "Unknown Constraint List");
      then txt;
  end match;
end optimizationComponents1;

protected function lm_916
  input Tpl.Text in_txt;

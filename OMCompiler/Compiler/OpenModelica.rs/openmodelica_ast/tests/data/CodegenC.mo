      Tpl.Text txt;
      Tpl.Text a_sub;
      Tpl.Text a_varDecls;
      list<DAE.ComponentRef> i_alg_knownOutputCrefs;
      Tpl.Text l_body;

    case ( txt,
           SimCode.SES_INVERSE_ALGORITHM(knownOutputCrefs = i_alg_knownOutputCrefs) :: {},
           a_sub,
           a_varDecls )
      equation
        l_body = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_body, a_sub, a_varDecls) = lm_357(l_body, i_alg_knownOutputCrefs, a_sub, a_varDecls);
        l_body = Tpl.popIter(l_body);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* backup outputs of the algorithm */\n"));
        txt = Tpl.writeText(txt, l_body);
      then (txt, a_sub, a_varDecls);

    case ( txt,
           _,
           a_sub,
           a_varDecls )
      then (txt, a_sub, a_varDecls);
  end match;
end fun_358;


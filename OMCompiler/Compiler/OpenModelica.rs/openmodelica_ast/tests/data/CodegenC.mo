    case ( txt,
           {} )
      then txt;

    case ( txt,
           SimCodeVar.SIMVAR(type_ = DAE.T_REAL(varLst = _), varKind = i_varKind, name = i_name) :: rest )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        l_kind = fun_908(Tpl.emptyTxt, i_varKind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("start["));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = getStartFromScalarIdx(data->simulationInfo, data->modelData, VAR_TYPE_REAL, "));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "min["
                                }, false));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = getMinFromScalarIdx(data->simulationInfo, data->modelData, VAR_TYPE_REAL, "));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "max["
                                }, false));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = getMaxFromScalarIdx(data->simulationInfo, data->modelData, VAR_TYPE_REAL, "));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "nominal["
                                }, false));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = getNominalFromScalarIdx(data->simulationInfo, data->modelData, "));
        txt = Tpl.writeText(txt, l_kind);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = CodegenCFunctions.crefIndexWithComment(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "useNominal["
                                }, false));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = "));
        txt = CodegenCFunctions.crefAttributes(txt, i_name);

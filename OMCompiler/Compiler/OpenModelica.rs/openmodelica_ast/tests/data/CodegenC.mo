  input list<SimCodeVar.SimVar> in_a_ls_vars;
  input Integer in_a_ls_index;
  input Integer in_a_ls_indexLinearSystem;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_ls_jacobianMatrix, in_a_at_jacobianMatrix, in_a_modelNamePrefix, in_a_at_simJac, in_a_at_vars, in_a_at_index, in_a_at_indexLinearSystem, in_a_ls_simJac, in_a_ls_vars, in_a_ls_index, in_a_ls_indexLinearSystem)

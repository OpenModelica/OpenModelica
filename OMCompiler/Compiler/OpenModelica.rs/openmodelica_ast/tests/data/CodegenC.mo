        ret_0 = SimCodeUtil.computeDependencies(a_derivativEquations, i_name);
        txt_1 = CodegenUtil.crefStr(Tpl.emptyTxt, i_name);
        txt = equationNames_Partial(txt, ret_0, a_modelNamePrefixStr, x_i0, Tpl.textString(txt_1));
        txt = Tpl.nextIter(txt);
        txt = lm_916(txt, rest, a_modelNamePrefixStr, a_derivativEquations);
      then txt;

    case ( txt,
           _ :: rest,
           a_modelNamePrefixStr,
           a_derivativEquations )
      equation
        txt = lm_916(txt, rest, a_modelNamePrefixStr, a_derivativEquations);
      then txt;
  end match;
end lm_916;


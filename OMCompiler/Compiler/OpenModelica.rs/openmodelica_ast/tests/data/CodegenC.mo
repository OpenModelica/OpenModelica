    case ( txt,
           {},
           a_sub )
      then (txt, a_sub);

    case ( txt,
           i_cr :: rest,
           a_sub )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_cr, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = OLD_"));

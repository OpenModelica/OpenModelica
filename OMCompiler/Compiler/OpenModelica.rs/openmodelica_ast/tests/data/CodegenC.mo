                                    ".useNominal;\n",
                                    "name["
                                }, false));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] =(char *) "));
        txt = CodegenCFunctions.crefVarInfo(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(".name;"));
        txt = Tpl.nextIter(txt);
        txt = lm_909(txt, rest);
      then txt;

    case ( txt,

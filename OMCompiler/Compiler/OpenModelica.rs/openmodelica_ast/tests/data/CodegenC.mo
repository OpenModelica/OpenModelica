      SimCode.ModelInfo i_modelInfo;

    case ( txt,
           SimCode.SIMCODE(modelInfo = i_modelInfo),
           a_sub )
      equation
        (txt, a_sub) = fun_902(txt, i_modelInfo, a_sub);
      then (txt, a_sub);

    case ( txt,
           _,

public function simulationFile_lnz
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode)
    local
      Tpl.Text txt;
      SimCode.SimCode i_simCode;
      SimCode.ModelInfo i_modelInfo;
      Integer i_na;
      Integer i_no;
      Integer i_ni;
      Integer i_ns;
      String i_simCode_fileNamePrefix;
      Boolean ret_1;
      String ret_0;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(modelInfo = (i_modelInfo as SimCode.MODELINFO(varInfo = SimCode.VARINFO(numStateVars = i_ns, numInVars = i_ni, numOutVars = i_no, numAlgVars = i_na))), fileNamePrefix = i_simCode_fileNamePrefix)) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* Linearization */\n"));
        txt = simulationFileHeader(txt, i_simCode_fileNamePrefix);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#if defined(__cplusplus)\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        ret_0 = Flags.getConfigString(Flags.LINEARIZATION_DUMP_LANGUAGE);
        ret_1 = stringEq(ret_0, "none");
        txt = fun_132(txt, ret_1, i_simCode, i_modelInfo, i_na, i_no, i_ni, i_ns);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "#if defined(__cplusplus)\n",
                                    "}\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simulationFile_lnz;

protected function fun_134
  input Tpl.Text in_txt;
  input SimCodeVar.SimVar in_a_simVar;
  input String in_a_arrayName;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_simVar, in_a_arrayName, in_a_sub)
    local
      Tpl.Text txt;
      String a_arrayName;
      Tpl.Text a_sub;
      DAE.ComponentRef i_name;
      Integer i_index;
      DAE.ComponentRef i_c;

    case ( txt,
           SimCodeVar.SIMVAR(arrayCref = SOME(i_c), aliasvar = SimCodeVar.NOALIAS(), index = i_index, name = i_name),
           a_arrayName,
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* "));
        txt = CodegenUtil.crefStrNoUnderscore(txt, i_c);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " */\n",
                                    "// #define "
                                }, false));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_c, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" data->simulationInfo->daeModeData->"));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]\n",
                                    "\n",
                                    "/* "
                                }, false));
        txt = CodegenUtil.crefStrNoUnderscore(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " */\n",
                                    "// #define "
                                }, false));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_name, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" data->simulationInfo->daeModeData->"));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]\n",
                                    "\n"
                                }, true));
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.SIMVAR(aliasvar = SimCodeVar.NOALIAS(), name = i_name, index = i_index),
           a_arrayName,
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* "));
        txt = CodegenUtil.crefStrNoUnderscore(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " */\n",
                                    "// #define "
                                }, false));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_name, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" data->simulationInfo->daeModeData->"));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]\n",
                                    "\n"
                                }, true));
      then (txt, a_sub);

    case ( txt,
           _,
           _,
           a_sub )
      then (txt, a_sub);
  end match;
end fun_134;

public function defineSimVarArray
  input Tpl.Text txt;
  input SimCodeVar.SimVar a_simVar;
  input String a_arrayName;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_sub;
algorithm
  l_sub := Tpl.emptyTxt;
  (out_txt, l_sub) := fun_134(txt, a_simVar, a_arrayName, l_sub);
end defineSimVarArray;

protected function lm_136
  input Tpl.Text in_txt;
  input list<SimCodeVar.SimVar> in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      list<SimCodeVar.SimVar> rest;
      SimCodeVar.SimVar i_var;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_var :: rest )
      equation
        txt = defineSimVarArray(txt, i_var, "residualVars");
        txt = Tpl.nextIter(txt);
        txt = lm_136(txt, rest);
      then txt;
  end match;
end lm_136;

protected function lm_137
  input Tpl.Text in_txt;
  input list<SimCodeVar.SimVar> in_items;

  output Tpl.Text out_txt;
algorithm

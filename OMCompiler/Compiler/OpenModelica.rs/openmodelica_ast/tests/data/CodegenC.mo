public function equationAlgorithm
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input SimCodeFunction.Context in_a_context;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_auxFunction;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_auxFunction;
algorithm
  (out_txt, out_a_varDecls, out_a_auxFunction) :=
  match(in_txt, in_a_eq, in_a_context, in_a_varDecls, in_a_auxFunction)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      Tpl.Text a_varDecls;
      Tpl.Text a_auxFunction;
      list<DAE.ComponentRef> i_alg_knownOutputCrefs;
      list<DAE.Statement> i_statements;
      Tpl.Text l_restoreKnownVars;
      Tpl.Text l_stmts;
      Tpl.Text l_backupKnown;
      Tpl.Text l_sub;

    case ( txt,
           SimCode.SES_INVERSE_ALGORITHM(insideNonLinearSystem = true, statements = i_statements),
           a_context,
           a_varDecls,
           a_auxFunction )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_auxFunction, a_varDecls) = lm_768(txt, i_statements, a_auxFunction, a_varDecls, a_context);
        txt = Tpl.popIter(txt);
      then (txt, a_varDecls, a_auxFunction);

    case ( txt,
           SimCode.SES_ALGORITHM(statements = i_statements),
           a_context,
           a_varDecls,
           a_auxFunction )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_auxFunction, a_varDecls) = lm_769(txt, i_statements, a_auxFunction, a_varDecls, a_context);
        txt = Tpl.popIter(txt);
      then (txt, a_varDecls, a_auxFunction);

    case ( txt,
           SimCode.SES_INVERSE_ALGORITHM(knownOutputCrefs = i_alg_knownOutputCrefs, statements = i_statements),
           a_context,
           a_varDecls,
           a_auxFunction )
      equation
        l_sub = Tpl.emptyTxt;
        l_backupKnown = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_backupKnown, l_sub, a_varDecls) = lm_770(l_backupKnown, i_alg_knownOutputCrefs, l_sub, a_varDecls);
        l_backupKnown = Tpl.popIter(l_backupKnown);
        l_stmts = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_stmts, a_auxFunction, a_varDecls) = lm_771(l_stmts, i_statements, a_auxFunction, a_varDecls, a_context);
        l_stmts = Tpl.popIter(l_stmts);
        l_restoreKnownVars = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_restoreKnownVars, l_sub) = lm_772(l_restoreKnownVars, i_alg_knownOutputCrefs, l_sub);
        l_restoreKnownVars = Tpl.popIter(l_restoreKnownVars);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* backup outputs of the algorithm */\n"));
        txt = Tpl.writeText(txt, l_backupKnown);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* algrithm it self */\n"));
        txt = Tpl.writeText(txt, l_stmts);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* restore outputs of the algorithm */\n"));
        txt = Tpl.writeText(txt, l_restoreKnownVars);
      then (txt, a_varDecls, a_auxFunction);

    case ( txt,
           _,
           _,
           a_varDecls,
           a_auxFunction )
      then (txt, a_varDecls, a_auxFunction);
  end match;
end equationAlgorithm;


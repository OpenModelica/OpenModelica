protected function fun_880
  input Tpl.Text in_txt;
  input String in_mArg;
  input String in_a_target;
  input SimCode.SimCode in_a_simCode;
  input list<String> in_a_extraFiles;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg, in_a_target, in_a_simCode, in_a_extraFiles)
    local
      Tpl.Text txt;
      String a_target;
      SimCode.SimCode a_simCode;
      list<String> a_extraFiles;
      Tpl.Text txt_0;

    case ( txt,
           "msvc",
           _,
           a_simCode,
           a_extraFiles )
      equation
        txt = fun_853(txt, a_simCode, a_extraFiles);
      then txt;

    case ( txt,
           "gcc",
           _,
           a_simCode,
           a_extraFiles )
      equation
        txt = fun_879(txt, a_simCode, a_extraFiles);
      then txt;

    case ( txt,
           _,
           a_target,
           _,
           _ )
      equation
        txt_0 = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("Target "));
        txt_0 = Tpl.writeStr(txt_0, a_target);
        txt_0 = Tpl.writeTok(txt_0, Tpl.ST_STRING(" is not handled!"));
        txt = CodegenUtil.error(txt, Tpl.sourceInfo("CodegenC.tpl", 7089, 9), Tpl.textString(txt_0));
      then txt;
  end match;
end fun_880;


      list<DAE.Statement> i_body_1;
      list<tuple<DAE.Exp, DAE.Exp>> i_body;
      Option<DAE.Exp> i_condition;
      Tpl.Text l_body__;
      Tpl.Text l_condition__;

    case ( txt,
           SimCode.SIM_BRANCH(condition = i_condition, body = i_body),
           a_context,
           a_preExp,
           a_varDecls,
           a_auxFunction )
      equation
        (l_condition__, a_auxFunction, a_varDecls, a_preExp) = fun_951(Tpl.emptyTxt, i_condition, a_auxFunction, a_varDecls, a_preExp, a_context);
        l_body__ = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));

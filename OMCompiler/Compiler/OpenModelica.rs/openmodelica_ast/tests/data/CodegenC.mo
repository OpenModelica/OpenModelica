                                                                    "\n",
                                                                    "\n"
                                                                }, true)), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (out_txt, out_a_globalConstraintsFunctions) := lm_326(out_txt, a_nonlinearSystems, a_globalConstraintsFunctions, a_modelPrefixName);
  out_txt := Tpl.popIter(out_txt);
end functionInitialNonLinearSystemsTemp;

protected function fun_328
  input Tpl.Text in_txt;
  input Option<SimCode.JacobianMatrix> in_a_nls_jacobianMatrix;
  input String in_a_modelPrefixName;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_nls_jacobianMatrix, in_a_modelPrefixName)
    local
      Tpl.Text txt;
      String a_modelPrefixName;
      String i_name;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(columns = {})),
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NULL"));
      then txt;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(matrixName = i_name)),
           a_modelPrefixName )
      equation
        txt = CodegenUtil.symbolName(txt, a_modelPrefixName, "functionJac");
        txt = Tpl.writeStr(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_column"));
      then txt;

    case ( txt,
           NONE(),
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NULL"));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_328;


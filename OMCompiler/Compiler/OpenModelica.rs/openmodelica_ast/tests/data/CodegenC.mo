protected function fun_333
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Integer in_a_nls_index;
  input Integer in_a_nls_indexNonLinearSystem;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg, in_a_nls_index, in_a_nls_indexNonLinearSystem)
    local
      Tpl.Text txt;
      Integer a_nls_index;
      Integer a_nls_indexNonLinearSystem;

    case ( txt,
           false,
           a_nls_index,
           a_nls_indexNonLinearSystem )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("nonLinearSystemData["));
        txt = Tpl.writeStr(txt, intString(a_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].residualFuncConstraints = residualFuncConstraints"));
        txt = Tpl.writeStr(txt, intString(a_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;

    case ( txt,
           _,
           a_nls_index,
           a_nls_indexNonLinearSystem )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("nonLinearSystemData["));
        txt = Tpl.writeStr(txt, intString(a_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].residualFunc = residualFunc"));
        txt = Tpl.writeStr(txt, intString(a_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;
  end match;
end fun_333;

protected function lm_334
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_eq :: rest )
      equation
        txt = CodegenUtilSimulation.equationIndex(txt, i_eq);
        txt = Tpl.nextIter(txt);
        txt = lm_334(txt, rest);
      then txt;
  end match;
end lm_334;

public function generateNonLinearSystemData
  input Tpl.Text in_txt;
  input SimCode.NonlinearSystem in_a_system;
  input Integer in_a_indexStrict;
  input String in_a_modelPrefixName;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_system, in_a_indexStrict, in_a_modelPrefixName)
    local
      Tpl.Text txt;
      Integer a_indexStrict;
      String a_modelPrefixName;
      Boolean i_nls_mixedSystem;
      Boolean i_nls_homotopySupport;
      Integer i_nls_indexNonLinearSystem;
      Integer i_nls_index;
      list<SimCode.SimEqSystem> i_nls_eqs;
      Option<SimCode.JacobianMatrix> i_nls_jacobianMatrix;
      list<DAE.ComponentRef> i_nls_crefs;
      Integer ret_15;
      Integer ret_14;
      Integer ret_13;
      Integer ret_12;
      Boolean ret_11;
      Tpl.Text l_residualCall;
      Boolean ret_9;
      Tpl.Text l_constraintsCall;
      Boolean ret_7;
      Tpl.Text l_casualCall;
      Tpl.Text l_innerSystems;
      Tpl.Text l_jacIndex;
      Tpl.Text l_initialJac;
      Tpl.Text l_generatedJac;
      Integer ret_1;
      Tpl.Text l_size;

    case ( txt,
           SimCode.NONLINEARSYSTEM(crefs = i_nls_crefs, jacobianMatrix = i_nls_jacobianMatrix, eqs = i_nls_eqs, index = i_nls_index, indexNonLinearSystem = i_nls_indexNonLinearSystem, homotopySupport = i_nls_homotopySupport, mixedSystem = i_nls_mixedSystem),
           a_indexStrict,
           a_modelPrefixName )
      equation
        ret_1 = listLength(i_nls_crefs);
        l_size = Tpl.writeStr(Tpl.emptyTxt, intString(ret_1));
        l_generatedJac = fun_328(Tpl.emptyTxt, i_nls_jacobianMatrix, a_modelPrefixName);
        l_initialJac = fun_329(Tpl.emptyTxt, i_nls_jacobianMatrix, a_modelPrefixName);
        l_jacIndex = fun_330(Tpl.emptyTxt, i_nls_jacobianMatrix);
        (l_innerSystems, _) = functionInitialNonLinearSystemsTemp(Tpl.emptyTxt, i_nls_eqs, a_modelPrefixName, Tpl.strTokText(Tpl.ST_STRING("")));
        ret_7 = intEq(a_indexStrict, 0);
        l_casualCall = fun_331(Tpl.emptyTxt, ret_7, a_indexStrict, a_modelPrefixName);
        ret_9 = intEq(a_indexStrict, 0);
        l_constraintsCall = fun_332(Tpl.emptyTxt, ret_9, i_nls_index);
        ret_11 = intEq(a_indexStrict, 0);
        l_residualCall = fun_333(Tpl.emptyTxt, ret_11, i_nls_index, i_nls_indexNonLinearSystem);
        txt = Tpl.writeText(txt, l_innerSystems);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].equationIndex = "));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].size = "));
        txt = Tpl.writeText(txt, l_size);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].homotopySupport = "));
        txt = CodegenCFunctions.boolStrC(txt, i_nls_homotopySupport);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].mixedSystem = "));
        txt = CodegenCFunctions.boolStrC(txt, i_nls_mixedSystem);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.writeText(txt, l_residualCall);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("nonLinearSystemData["));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].strictTearingFunctionCall = "));
        txt = Tpl.writeText(txt, l_casualCall);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].analyticalJacobianColumn = "));
        txt = Tpl.writeText(txt, l_generatedJac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initialAnalyticalJacobian = "));
        txt = Tpl.writeText(txt, l_initialJac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].jacobianIndex = "));
        txt = Tpl.writeText(txt, l_jacIndex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].initializeStaticNLSData = initializeStaticDataNLS"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].freeStaticNLSData = freeStaticDataNLS"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].getIterationVars = getIterationVarsNLS"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].checkConstraints = "));
        txt = Tpl.writeText(txt, l_constraintsCall);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "\n",
                                    "const int tmp_eqn_indices_"
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        ret_12 = listLength(i_nls_eqs);
        txt = Tpl.writeStr(txt, intString(ret_12));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = {"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING(", ")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_334(txt, i_nls_eqs);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].eqn_simcode_indices = malloc("));
        ret_13 = listLength(i_nls_eqs);
        txt = Tpl.writeStr(txt, intString(ret_13));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " * sizeof(int));\n",
                                    "memcpy(nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].eqn_simcode_indices, tmp_eqn_indices_"));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        ret_14 = listLength(i_nls_eqs);
        txt = Tpl.writeStr(txt, intString(ret_14));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " * sizeof(int));\n",
                                    "nonLinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].torn_plus_residual_size = "));
        ret_15 = listLength(i_nls_eqs);
        txt = Tpl.writeStr(txt, intString(ret_15));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;

    case ( txt,
           _,
           _,
           _ )
      then txt;
  end match;
end generateNonLinearSystemData;

public function createGlobalConstraintsFunction
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_system;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_system)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> i_at_residual;
      Integer i_at_index;
      list<SimCode.SimEqSystem> i_at_eqs;
      Tpl.Text l_constraints;

    case ( txt,
           SimCode.SES_NONLINEAR(alternativeTearing = SOME(SimCode.NONLINEARSYSTEM(eqs = i_at_eqs, index = i_at_index))) )
      equation
        l_constraints = createGlobalConstraints(Tpl.emptyTxt, i_at_eqs);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int checkConstraints"));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA *data, threadData_t *threadData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = equation_withProfile(txt, intString(i_at_index), Tpl.textString(l_constraints));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 1;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n"
                                }, true));
      then txt;

    case ( txt,
           SimCode.SES_LINEAR(alternativeTearing = SOME(SimCode.LINEARSYSTEM(residual = i_at_residual, index = i_at_index))) )
      equation
        l_constraints = createGlobalConstraints(Tpl.emptyTxt, i_at_residual);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int checkConstraints"));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA *data, threadData_t *threadData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = equation_withProfile(txt, intString(i_at_index), Tpl.textString(l_constraints));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("return 1;\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n"
                                }, true));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end createGlobalConstraintsFunction;

protected function fun_337
  input Tpl.Text in_txt;
  input Boolean in_a_localCon;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_localCon)
    local
      Tpl.Text txt;

    case ( txt,
           false )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("global"));
      then txt;

    case ( txt,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("local"));
      then txt;
  end match;
end fun_337;

protected function fun_338
  input Tpl.Text in_txt;
  input DAE.Constraint in_a_con;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_con)
    local
      Tpl.Text txt;
      Boolean i_localCon;
      DAE.Exp i_c;
      Tpl.Text l_condition;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDecls;
      Tpl.Text l_preExp;

    case ( txt,
           DAE.CONSTRAINT_DT(constraint = i_c, localCon = i_localCon) )
      equation
        l_preExp = Tpl.emptyTxt;
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_condition, l_preExp, l_varDecls, l_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_c, SimCodeFunction.contextSimulationDiscrete, l_preExp, l_varDecls, l_auxFunction);
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("if (!"));
        txt = Tpl.writeText(txt, l_condition);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("){\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("debugString(OMC_LOG_DT_CONS, \"The following "));
        txt = fun_337(txt, i_localCon);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" constraint is violated:\\n"));
        txt = ExpressionDumpTpl.dumpExp(txt, i_c, "\"");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\");\n",
                                    "return 0;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_338;

protected function lm_339
  input Tpl.Text in_txt;
  input BackendDAE.Constraints in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      BackendDAE.Constraints rest;
      DAE.Constraint i_con;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_con :: rest )
      equation
        txt = fun_338(txt, i_con);
        txt = Tpl.nextIter(txt);
        txt = lm_339(txt, rest);
      then txt;
  end match;
end lm_339;

protected function fun_340
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_innerEqn;

  output Tpl.Text out_txt;
algorithm
  out_txt :=

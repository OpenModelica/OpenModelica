        txt_3 = Tpl.writeStr(Tpl.emptyTxt, i_fileNamePrefix);
        txt_3 = Tpl.writeTok(txt_3, Tpl.ST_STRING("_functions.h"));
        l_functionsHeader = Tpl.redirectToFile(l_functionsHeader, Tpl.textString(txt_3));
        l_functionsHeader = simulationFunctionsHeaderFile(l_functionsHeader, i_fileNamePrefix, i_modelInfo_functions, i_recordDecls, i_sc_generic__loop__calls);
        l_functionsHeader = Tpl.closeFile(l_functionsHeader);

      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           SimCode.SPATIAL_DISTRIBUTION(index = i_index, initPnts = i_initPnts, initVals = i_initVals, initSize = i_initSize) :: rest,
           a_auxFunction,

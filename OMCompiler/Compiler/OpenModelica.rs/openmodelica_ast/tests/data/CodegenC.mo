protected function fun_287
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input Integer in_a_i0;
  input Integer in_a_col;
  input Integer in_a_row;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls) :=
  match(in_txt, in_a_eq, in_a_i0, in_a_col, in_a_row, in_a_auxFunction, in_a_varDecls)
    local
      Tpl.Text txt;
      Integer a_i0;
      Integer a_col;
      Integer a_row;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      DAE.Exp i_exp;
      Tpl.Text l_expPart;
      Tpl.Text l_preExp;

    case ( txt,
           SimCode.SES_RESIDUAL(exp = i_exp),
           a_i0,
           a_col,
           a_row,
           a_auxFunction,
           a_varDecls )
      equation
        l_preExp = Tpl.emptyTxt;
        (l_expPart, l_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_exp, SimCodeFunction.contextSimulationDiscrete, l_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeText(txt, l_preExp);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("linearSystemData->setAElement("));
        txt = Tpl.writeStr(txt, intString(a_row));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(a_col));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_expPart);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(a_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", linearSystemData, threadData);"));
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           _,
           _,
           _,
           a_auxFunction,
           a_varDecls )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case 2"));
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           _,
           _,
           _,
           _,
           a_auxFunction,
           a_varDecls )
      then (txt, a_auxFunction, a_varDecls);
  end match;
end fun_287;

protected function lm_288

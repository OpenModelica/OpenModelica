protected function lm_219
  input Tpl.Text in_txt;
  input list<SimCode.JacobianMatrix> in_items;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.JacobianMatrix> rest;
      String a_modelNamePrefix;
      Option<HashTableCrefSimVar.HashTable> i_jac_crefsHT;
      list<SimCode.SimGenericCall> i_jac_generic__loop__calls;
      Integer i_jac_jacobianIndex;
      String i_jac_matrixName;
      SimCodeFunction.Context ret_0;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           SimCode.JAC_MATRIX(matrixName = i_jac_matrixName, jacobianIndex = i_jac_jacobianIndex, generic_loop_calls = i_jac_generic__loop__calls, crefsHT = i_jac_crefsHT) :: rest,
           a_modelNamePrefix )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#define "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "INDEX_JAC_");
        txt = Tpl.writeStr(txt, i_jac_matrixName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" "));
        txt = Tpl.writeStr(txt, intString(i_jac_jacobianIndex));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "functionJac");
        txt = Tpl.writeStr(txt, i_jac_matrixName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_column(DATA* data, threadData_t *threadData, JACOBIAN *thisJacobian, JACOBIAN *parentJacobian);\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "initialAnalyticJacobian");
        txt = Tpl.writeStr(txt, i_jac_matrixName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, threadData_t *threadData, JACOBIAN *jacobian);\n",
                                    "void "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "Jac");
        txt = Tpl.writeStr(txt, i_jac_matrixName);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("_DAG(DATA* data, threadData_t *threadData, JACOBIAN *jacobian);\n"));
        ret_0 = SimCodeUtil.createJacContext(i_jac_matrixName, i_jac_crefsHT);
        txt = genericCallHeaders(txt, i_jac_generic__loop__calls, ret_0);
        txt = Tpl.nextIter(txt);
        txt = lm_219(txt, rest, a_modelNamePrefix);
      then txt;

    case ( txt,
           _ :: rest,
           a_modelNamePrefix )
      equation
        txt = lm_219(txt, rest, a_modelNamePrefix);
      then txt;
  end match;
end lm_219;

public function symJacDefinition
  input Tpl.Text txt;
  input list<SimCode.JacobianMatrix> a_JacobianMatrices;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_symbolicJacsDefine;
algorithm
  l_symbolicJacsDefine := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, SOME(Tpl.ST_STRING("")), SOME(Tpl.ST_STRING_LIST({
                                                                                                           "\n",
                                                                                                           "\n"
                                                                                                       }, true)), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_symbolicJacsDefine := lm_219(l_symbolicJacsDefine, a_JacobianMatrices, a_modelNamePrefix);
  l_symbolicJacsDefine := Tpl.popIter(l_symbolicJacsDefine);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                   "#if defined(__cplusplus)\n",
                                   "extern \"C\" {\n",
                                   "#endif\n",
                                   "\n",
                                   "/* Jacobian Variables */\n"
                               }, true));
  out_txt := Tpl.writeText(out_txt, l_symbolicJacsDefine);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "\n",
                                       "#if defined(__cplusplus)\n",
                                       "}\n",
                                       "#endif"
                                   }, false));
end symJacDefinition;

protected function fun_221
  input Tpl.Text in_txt;
  input SimCodeVar.AliasVariable in_a_var;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_var, in_a_sub)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      DAE.ComponentRef i_varName;

    case ( txt,
           SimCodeVar.NOALIAS(),
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("0,0"));
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.ALIAS(varName = i_varName),
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("&"));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_varName, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(",0"));
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.NEGATEDALIAS(varName = i_varName),
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("&"));

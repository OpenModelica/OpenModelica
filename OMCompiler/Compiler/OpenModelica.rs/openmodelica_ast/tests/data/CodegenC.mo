  Integer ret_4;
  Tpl.Text l_fncalls;
  Tpl.Text l_auxFunction;
  Tpl.Text l_eqFuncs;
  Tpl.Text l_sub;
algorithm
  l_sub := Tpl.emptyTxt;
  l_eqFuncs := Tpl.emptyTxt;
  l_auxFunction := Tpl.emptyTxt;
  ret_4 := listLength(a_parameterEquations);
  ret_5 := Flags.getConfigInt(Flags.EQUATIONS_PER_FILE);
  (l_fncalls, l_eqFuncs) := functionEquationsMultiFiles(Tpl.emptyTxt, a_parameterEquations, ret_4, ret_5, a_fileNamePrefix, a_fullPathPrefix, a_modelNamePrefix, "updateBoundParameters", "08bnd", l_eqFuncs, true, true, false);
  out_txt := Tpl.writeText(txt, l_eqFuncs);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "OMC_DISABLE_OPT\n",
                                       "int "
                                   }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "updateBoundParameters");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  ret_6 := SimCodeUtil.sortSimpleAssignmentBasedOnLhs(a_simpleParameterEquations);
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (out_txt, l_sub) := lm_430(out_txt, ret_6, a_simCode, l_sub);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeText(out_txt, l_fncalls);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("return 0;\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));

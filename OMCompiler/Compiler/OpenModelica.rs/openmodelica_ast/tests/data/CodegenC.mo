protected function fun_736
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Tpl.Text in_a_sub;
  input DAE.ComponentRef in_a_cref;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_mArg, in_a_sub, in_a_cref)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      DAE.ComponentRef a_cref;
      DAE.ComponentRef ret_4;
      DAE.ComponentRef ret_3;
      DAE.ComponentRef ret_2;
      DAE.ComponentRef ret_1;
      Tpl.Text l_name;

    case ( txt,
           false,
           a_sub,
           _ )
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub,
           a_cref )
      equation
        l_name = fun_735(Tpl.emptyTxt, a_cref);
        ret_1 = ComponentReference.popCref(a_cref);
        (txt, a_sub) = CodegenCFunctions.cref(txt, ret_1, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = "));
        (txt, a_sub) = CodegenCFunctions.cref(txt, a_cref, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "infoStreamPrint(OMC_LOG_INIT_V, 0,\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(16));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"updated start value: %s(start="));
        ret_2 = ComponentReference.popCref(a_cref);
        txt = crefToPrintfArg(txt, ret_2);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(")\",\n"));
        txt = Tpl.writeText(txt, l_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",\n",
                                    "("
                                }, false));
        ret_3 = ComponentReference.popCref(a_cref);
        txt = crefType(txt, ret_3);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(") "));
        ret_4 = ComponentReference.popCref(a_cref);
        (txt, a_sub) = CodegenCFunctions.cref(txt, ret_4, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(");"));
        txt = Tpl.popBlock(txt);
      then (txt, a_sub);
  end match;
end fun_736;

protected function fun_737

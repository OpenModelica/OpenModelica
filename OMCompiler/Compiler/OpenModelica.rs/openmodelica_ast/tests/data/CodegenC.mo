      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case 1"));
      then (txt, a_auxFunction, a_varDeclsRes);

    case ( txt,
           _,
           _,
           a_auxFunction,
           a_varDeclsRes )

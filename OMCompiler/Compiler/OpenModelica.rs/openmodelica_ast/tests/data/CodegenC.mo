    case ( txt,
           SimCode.SES_ALGORITHM(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_LINEAR(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_NONLINEAR(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_MIXED(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_WHEN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_FOR_LOOP(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributesEval(txt, i_eqAttr);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simEqAttrEval;

public function eqAttributesEval
  input Tpl.Text in_txt;
  input BackendDAE.EquationAttributes in_a_eqAtt;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eqAtt)
    local
      Tpl.Text txt;
      BackendDAE.EvaluationStages i_evalStages;

    case ( txt,
           BackendDAE.EQUATION_ATTRIBUTES(evalStages = i_evalStages) )
      equation
        txt = eqEval(txt, i_evalStages);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end eqAttributesEval;


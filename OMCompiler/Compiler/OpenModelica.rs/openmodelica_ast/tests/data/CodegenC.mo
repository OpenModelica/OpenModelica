           _,
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = CodegenUtil.error(txt, Tpl.sourceInfo("CodegenC.tpl", 5928, 11), "NOT IMPLEMENTED EQUATION equation_");
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_clock)
    local
      Tpl.Text txt;

    case ( txt,
           DAE.EVENT_CLOCK(condition = _) )
      equation
        txt = CodegenCFunctions.boolStrC(txt, true);
      then txt;

    case ( txt,
           _ )
      equation
        txt = CodegenCFunctions.boolStrC(txt, false);
      then txt;
  end match;
end isEventClock;

protected function fun_71
  input Tpl.Text in_txt;
  input SimCode.ClockedPartition in_a_partition;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Integer in_a_baseClockIdx;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls) :=
  match(in_txt, in_a_partition, in_a_auxFunction, in_a_varDecls, in_a_baseClockIdx)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Integer a_baseClockIdx;
      list<SimCode.SubPartition> i_subPartitions;
      DAE.ClockKind i_baseClock;
      Tpl.Text l_baseClockStr;

    case ( txt,
           SimCode.CLOCKED_PARTITION(baseClock = i_baseClock, subPartitions = i_subPartitions),
           a_auxFunction,
           a_varDecls,
           a_baseClockIdx )
      equation
        (l_baseClockStr, a_varDecls, a_auxFunction) = baseClockInit(Tpl.emptyTxt, i_baseClock, a_baseClockIdx, i_subPartitions, a_varDecls, a_auxFunction);
        txt = Tpl.writeText(txt, a_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, a_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_baseClockStr);
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           _ )
      then (txt, a_auxFunction, a_varDecls);
  end match;
end fun_71;


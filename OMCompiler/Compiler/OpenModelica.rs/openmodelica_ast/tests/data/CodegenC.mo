  input String in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_context, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      String a_modelNamePrefixStr;
      SimCode.SimEqSystem i_eq;
      Tpl.Text l_body;
      Tpl.Text l_ix;

    case ( txt,
           SimCode.SES_ALGORITHM(statements = {}),
           _,
           _ )
      then txt;

    case ( txt,
           i_eq,
           a_context,
           a_modelNamePrefixStr )
      equation
        l_ix = CodegenUtilSimulation.equationIndexGeneral(Tpl.emptyTxt, i_eq);
        l_body = CodegenUtil.symbolName(Tpl.emptyTxt, a_modelNamePrefixStr, "eqFunction");
        l_body = Tpl.writeTok(l_body, Tpl.ST_STRING("_"));
        l_body = Tpl.writeText(l_body, l_ix);
        l_body = Tpl.writeTok(l_body, Tpl.ST_STRING("(data, threadData);"));
        txt = fun_732(txt, a_context, i_eq);
        txt = Tpl.softNewLine(txt);
        txt = fun_733(txt, a_context, i_eq);
        txt = Tpl.softNewLine(txt);

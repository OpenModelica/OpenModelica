protected function lm_143
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_modelNamePrefixStr;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_eq :: rest,
           a_modelNamePrefixStr )
      equation
        txt = equationNames_(txt, i_eq, SimCodeFunction.contextSimulationNonDiscrete, Tpl.textString(a_modelNamePrefixStr));
        txt = lm_143(txt, rest, a_modelNamePrefixStr);
      then txt;
  end match;
end lm_143;

protected function lm_144
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_modelNamePrefixStr;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_eq :: rest,
           a_modelNamePrefixStr )
      equation
        txt = equation_impl(txt, -1, -1, i_eq, SimCodeFunction.contextSimulationNonDiscrete, Tpl.textString(a_modelNamePrefixStr), false);
        txt = Tpl.nextIter(txt);
        txt = lm_144(txt, rest, a_modelNamePrefixStr);
      then txt;
  end match;
end lm_144;

public function simulationFile_inl
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> i_inlineEquations;
      SimCode.SimCode i_simCode;
      Tpl.Text txt_7;
      Tpl.Text l_funcNames;
      Boolean ret_5;
      Integer ret_4;
      Boolean ret_3;
      Integer ret_2;
      Tpl.Text txt_1;
      Tpl.Text l_modelNamePrefixStr;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(modelInfo = SimCode.MODELINFO(vars = SimCodeVar.SIMVARS(stateVars = _)), inlineEquations = {})) )
      equation
        l_modelNamePrefixStr = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* Inline equation file is empty */\n"));
        txt_1 = CodegenUtilSimulation.fileNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = simulationFileHeader(txt, Tpl.textString(txt_1));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#ifdef __cplusplus\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(l_modelNamePrefixStr), "symbolicInlineSystem");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA *data, threadData_t *threadData){\n"));
        ret_2 = Flags.getConfigEnum(Flags.SYM_SOLVER);
        ret_3 = intEq(ret_2, 0);
        txt = fun_141(txt, ret_3);
        txt = Tpl.softNewLine(txt);
        ret_4 = Flags.getConfigEnum(Flags.SYM_SOLVER);
        ret_5 = intGt(ret_4, 0);
        txt = fun_142(txt, ret_5);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "#ifdef __cplusplus\n",
                                    "}\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(modelInfo = SimCode.MODELINFO(vars = SimCodeVar.SIMVARS(stateVars = _)), inlineEquations = i_inlineEquations)) )
      equation
        l_modelNamePrefixStr = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        l_funcNames = lm_143(Tpl.emptyTxt, i_inlineEquations, l_modelNamePrefixStr);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* Inline equation file */\n"));
        txt_7 = CodegenUtilSimulation.fileNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = simulationFileHeader(txt, Tpl.textString(txt_7));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "#ifdef __cplusplus\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_144(txt, i_inlineEquations, l_modelNamePrefixStr);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "/* inline equations*/\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(l_modelNamePrefixStr), "symbolicInlineSystem");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA *data, threadData_t *threadData){\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_funcNames);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "return 0;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "#ifdef __cplusplus\n",
                                    "}\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simulationFile_inl;


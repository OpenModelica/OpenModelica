algorithm
  (out_txt, out_a_innerEqns, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_items, in_a_innerEqns, in_a_varDecls, in_a_preExp)
    local
      Tpl.Text txt;
      list<tuple<DAE.ComponentRef, DAE.Exp>> rest;
      Tpl.Text a_innerEqns;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      Option<DAE.Exp> i_range_step;
      DAE.Exp i_range_stop;
      DAE.Exp i_range_start;
      DAE.ComponentRef i_cref;
      Tpl.Text l_step;
      Tpl.Text l_stop;
      Tpl.Text l_start;
      DAE.Exp ret_1;
      Tpl.Text l_iter;

    case ( txt,
           {},
           a_innerEqns,
           a_varDecls,
           a_preExp )
      then (txt, a_innerEqns, a_varDecls, a_preExp);

    case ( txt,
           (i_cref, DAE.RANGE(start = i_range_start, stop = i_range_stop, step = i_range_step)) :: rest,
           a_innerEqns,
           a_varDecls,
           a_preExp )
      equation
        ret_1 = Expression.crefExp(i_cref);
        (l_iter, a_preExp, a_varDecls, a_innerEqns) = CodegenCFunctions.daeExp(Tpl.emptyTxt, ret_1, SimCodeFunction.contextSimulationDiscrete, a_preExp, a_varDecls, a_innerEqns);
        (l_start, a_preExp, a_varDecls, a_innerEqns) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_range_start, SimCodeFunction.contextSimulationDiscrete, a_preExp, a_varDecls, a_innerEqns);
        (l_stop, a_preExp, a_varDecls, a_innerEqns) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_range_stop, SimCodeFunction.contextSimulationDiscrete, a_preExp, a_varDecls, a_innerEqns);
        (l_step, a_innerEqns, a_varDecls, a_preExp) = fun_365(Tpl.emptyTxt, i_range_step, a_innerEqns, a_varDecls, a_preExp);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("for(int "));
        txt = Tpl.writeText(txt, l_iter);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("="));
        txt = Tpl.writeText(txt, l_start);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("; "));
        txt = Tpl.writeText(txt, l_iter);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("<="));
        txt = Tpl.writeText(txt, l_stop);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("; "));
        txt = Tpl.writeText(txt, l_iter);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("+="));
        txt = Tpl.writeText(txt, l_step);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("){"));
        txt = Tpl.nextIter(txt);
        (txt, a_innerEqns, a_varDecls, a_preExp) = lm_366(txt, rest, a_innerEqns, a_varDecls, a_preExp);
      then (txt, a_innerEqns, a_varDecls, a_preExp);

    case ( txt,
           _ :: rest,
           a_innerEqns,
           a_varDecls,
           a_preExp )
      equation
        (txt, a_innerEqns, a_varDecls, a_preExp) = lm_366(txt, rest, a_innerEqns, a_varDecls, a_preExp);
      then (txt, a_innerEqns, a_varDecls, a_preExp);
  end match;
end lm_366;


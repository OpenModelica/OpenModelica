protected function fun_697
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input Tpl.Text in_a_eqfuncs;
  input Tpl.Text in_a_OMC__DISABLE__OPT;
  input Boolean in_a_init;
  input String in_a_modelNamePrefix;
  input Tpl.Text in_a_tempeqns;
  input Tpl.Text in_a_varD;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_eqfuncs;
  output Tpl.Text out_a_OMC__DISABLE__OPT;
  output Tpl.Text out_a_tempeqns;
  output Tpl.Text out_a_varD;
algorithm
  (out_txt, out_a_eqfuncs, out_a_OMC__DISABLE__OPT, out_a_tempeqns, out_a_varD) :=
  match(in_txt, in_a_eq, in_a_eqfuncs, in_a_OMC__DISABLE__OPT, in_a_init, in_a_modelNamePrefix, in_a_tempeqns, in_a_varD, in_a_context)
    local
      Tpl.Text txt;
      Tpl.Text a_eqfuncs;
      Tpl.Text a_OMC__DISABLE__OPT;
      Boolean a_init;
      String a_modelNamePrefix;
      Tpl.Text a_tempeqns;
      Tpl.Text a_varD;
      SimCodeFunction.Context a_context;
      list<SimCode.SimEqSystem> i_at_eqs;
      list<SimCode.SimEqSystem> i_nls_eqs;
      SimCode.SimEqSystem i_e;

    case ( txt,
           (i_e as SimCode.SES_SIMPLE_ASSIGN(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationSimpleAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationSimpleAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ARRAY_CALL_ASSIGN(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationArrayCallAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_RESIZABLE_ASSIGN(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationGenericAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_GENERIC_ASSIGN(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationGenericAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ENTWINED_ASSIGN(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationEntwinedAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_IFEQUATION(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationIfEquationAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix, a_init);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ALGORITHM(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationAlgorithm(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_INVERSE_ALGORITHM(index = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationAlgorithm(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_LINEAR(lSystem = _)),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        a_OMC__DISABLE__OPT = Tpl.writeTok(a_OMC__DISABLE__OPT, Tpl.ST_STRING("OMC_DISABLE_OPT"));
        a_OMC__DISABLE__OPT = Tpl.writeTok(a_OMC__DISABLE__OPT, Tpl.ST_NEW_LINE());
        (txt, a_varD) = equationLinear(txt, i_e, a_context, a_varD);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_NONLINEAR(nlSystem = SimCode.NONLINEARSYSTEM(eqs = i_nls_eqs), alternativeTearing = NONE())),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        a_tempeqns = Tpl.pushIter(a_tempeqns, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        a_tempeqns = lm_694(a_tempeqns, i_nls_eqs, a_modelNamePrefix);
        a_tempeqns = Tpl.popIter(a_tempeqns);
        txt = equationNonlinear(txt, i_e, a_context, a_modelNamePrefix, a_init);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_NONLINEAR(nlSystem = SimCode.NONLINEARSYSTEM(eqs = i_nls_eqs), alternativeTearing = SOME(SimCode.NONLINEARSYSTEM(eqs = i_at_eqs)))),
           a_eqfuncs,
           a_OMC__DISABLE__OPT,
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        a_tempeqns = Tpl.pushIter(a_tempeqns, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        a_tempeqns = lm_695(a_tempeqns, i_nls_eqs, a_modelNamePrefix);
        a_tempeqns = Tpl.popIter(a_tempeqns);
        a_tempeqns = Tpl.writeTok(a_tempeqns, Tpl.ST_NEW_LINE());
        a_tempeqns = Tpl.pushIter(a_tempeqns, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        a_tempeqns = lm_696(a_tempeqns, i_at_eqs, a_modelNamePrefix);
        a_tempeqns = Tpl.popIter(a_tempeqns);
        txt = equationNonlinear(txt, i_e, a_context, a_modelNamePrefix, a_init);
      then (txt, a_eqfuncs, a_OMC__DISABLE__OPT, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_WHEN(index = _)),
           a_eqfuncs,

protected function fun_330
  input Tpl.Text in_txt;
  input Option<SimCode.JacobianMatrix> in_a_nls_jacobianMatrix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_nls_jacobianMatrix)
    local
      Tpl.Text txt;
      Integer i_jacindex;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(columns = {})) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-1"));
      then txt;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(jacobianIndex = i_jacindex)) )
      equation
        txt = Tpl.writeStr(txt, intString(i_jacindex));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" /*jacInx*/"));
      then txt;

    case ( txt,
           NONE() )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("-1"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_330;

protected function fun_331
  input Tpl.Text in_txt;

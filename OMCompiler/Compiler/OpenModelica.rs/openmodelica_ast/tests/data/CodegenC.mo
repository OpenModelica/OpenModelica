protected function fun_319
  input Tpl.Text in_txt;
  input Option<SimCode.JacobianMatrix> in_a_ls_jacobianMatrix;
  input list<DAE.Exp> in_a_at_beqs;
  input list<tuple<Integer, Integer, SimCode.SimEqSystem>> in_a_at_simJac;

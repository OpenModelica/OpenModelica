public function simulationFile_mixAndHeader
  input Tpl.Text txt;
  input SimCode.SimCode a_simCode;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text txt_3;
  Tpl.Text txt_2;
  Tpl.Text txt_1;
  Tpl.Text l_mixheader;
algorithm
  l_mixheader := Tpl.emptyTxt;
  (txt_1, l_mixheader) := simulationFile_mix(Tpl.emptyTxt, a_simCode, l_mixheader);
  txt_2 := Tpl.writeStr(Tpl.emptyTxt, a_modelNamePrefix);
  txt_2 := Tpl.writeTok(txt_2, Tpl.ST_STRING("_11mix.c"));
  Tpl.textFileConvertLines(txt_1, Tpl.textString(txt_2));
  txt_3 := Tpl.writeStr(Tpl.emptyTxt, a_modelNamePrefix);
  txt_3 := Tpl.writeTok(txt_3, Tpl.ST_STRING("_11mix.h"));
  Tpl.textFile(l_mixheader, Tpl.textString(txt_3));
  out_txt := txt;
end simulationFile_mixAndHeader;

public function simulationFile_syn
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode)
    local
      Tpl.Text txt;
      SimCode.SimCode i_simCode;
      list<SimCode.ClockedPartition> i_clockedPartitions;
      String i_simCode_fileNamePrefix;
      Tpl.Text txt_4;
      list<SimCode.SubPartition> ret_3;
      Tpl.Text txt_2;
      Tpl.Text txt_1;
      Tpl.Text txt_0;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(fileNamePrefix = i_simCode_fileNamePrefix, clockedPartitions = i_clockedPartitions)) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* Synchronous systems */\n"));
        txt = simulationFileHeader(txt, i_simCode_fileNamePrefix);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#if defined(__cplusplus)\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        txt_0 = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = functionInitSynchronous(txt, i_clockedPartitions, Tpl.textString(txt_0));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt_1 = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = functionUpdateSynchronous(txt, i_clockedPartitions, Tpl.textString(txt_1));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt_2 = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = functionSystemsSynchronous(txt, i_clockedPartitions, Tpl.textString(txt_2));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        ret_3 = SimCodeUtil.getSubPartitions(i_clockedPartitions);
        txt_4 = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = functionSavePreSynchronous(txt, ret_3, Tpl.textString(txt_4));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "#if defined(__cplusplus)\n",
                                    "}\n",
                                    "#endif\n"
                                }, true));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simulationFile_syn;


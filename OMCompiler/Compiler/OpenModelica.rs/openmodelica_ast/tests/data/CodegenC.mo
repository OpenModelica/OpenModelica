      list<SimCodeVar.SimVar> i_vars_inputVars;

    case ( txt,
           SimCode.MODELINFO(vars = SimCodeVar.SIMVARS(inputVars = i_vars_inputVars)),
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("if(file){\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_sub) = lm_900(txt, i_vars_inputVars, a_sub);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("}\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_sub) = lm_901(txt, i_vars_inputVars, a_sub);
        txt = Tpl.popIter(txt);
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub )
      then (txt, a_sub);
  end match;
end fun_902;


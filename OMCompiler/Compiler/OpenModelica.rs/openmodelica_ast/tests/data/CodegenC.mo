  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_items, in_a_sub)
    local
      Tpl.Text txt;
      list<SimCodeVar.SimVar> rest;
      Tpl.Text a_sub;
      Integer x_i0;
      DAE.ComponentRef i_name;

    case ( txt,
           {},
           a_sub )
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.SIMVAR(name = i_name) :: rest,
           a_sub )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_name, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = xloc["));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("];"));
        txt = Tpl.nextIter(txt);
        (txt, a_sub) = lm_279(txt, rest, a_sub);
      then (txt, a_sub);

    case ( txt,
           _ :: rest,
           a_sub )
      equation
        (txt, a_sub) = lm_279(txt, rest, a_sub);
      then (txt, a_sub);
  end match;
end lm_279;

protected function lm_280

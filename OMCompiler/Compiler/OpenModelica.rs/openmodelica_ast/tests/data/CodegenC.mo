        (l_initPntsT, l_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_initPnts, SimCodeFunction.contextSimulationNonDiscrete, l_preExp, a_varDecls, a_auxFunction);
        (l_initValsT, l_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_initVals, SimCodeFunction.contextSimulationNonDiscrete, l_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeText(txt, l_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("initSpatialDistribution(data, threadData, "));
        txt = Tpl.writeStr(txt, intString(i_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", &"));
        txt = Tpl.writeText(txt, l_initPntsT);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", &"));
        txt = Tpl.writeText(txt, l_initValsT);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(i_initSize));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(");"));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        (txt, a_auxFunction, a_varDecls) = lm_453(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           _ :: rest,
           a_auxFunction,
           a_varDecls )
      equation
        (txt, a_auxFunction, a_varDecls) = lm_453(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);
  end match;
end lm_453;


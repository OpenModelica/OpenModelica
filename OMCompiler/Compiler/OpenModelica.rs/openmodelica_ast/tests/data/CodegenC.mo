        txt_7 = Tpl.writeStr(Tpl.emptyTxt, i_fileNamePrefix);
        txt_7 = Tpl.writeTok(txt_7, Tpl.ST_STRING("_records.c"));
        l_records = Tpl.redirectToFile(l_records, Tpl.textString(txt_7));
        l_records = CodegenCFunctions.recordsFile(l_records, i_fileNamePrefix, i_recordDecls, true);
        l_records = Tpl.closeFile(l_records);
        ret_8 = Config.acceptParModelicaGrammar();
        txt = fun_48(txt, ret_8, i_modelInfo_functions, i_fileNamePrefix);
      then txt;

    case ( txt,
           _ )
      then txt;

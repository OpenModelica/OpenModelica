protected function lm_689
  input Tpl.Text in_txt;
  input list<list<Integer>> in_items;
  input String in_a_arrayName;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_arrayName)
    local
      Tpl.Text txt;
      list<list<Integer>> rest;
      String a_arrayName;
      Integer x_index0;
      list<Integer> i_indices;
      Tpl.Text l_ind__name;
      Integer ret_3;
      Tpl.Text l_index;
      Integer ret_1;
      Tpl.Text l_length;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_indices :: rest,
           a_arrayName )
      equation
        x_index0 = Tpl.getIteri_i0(txt);
        ret_1 = listLength(i_indices);
        l_length = Tpl.writeStr(Tpl.emptyTxt, intString(ret_1));
        ret_3 = intAdd(x_index0, 1);
        l_index = Tpl.writeStr(Tpl.emptyTxt, intString(ret_3));
        l_ind__name = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("indices_"));
        l_ind__name = Tpl.writeText(l_ind__name, l_index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* color "));
        txt = Tpl.writeText(txt, l_index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" with "));
        txt = Tpl.writeText(txt, l_length);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " columns */\n",
                                    "const int "
                                }, false));
        txt = Tpl.writeText(txt, l_ind__name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeText(txt, l_length);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = {"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING(", ")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_688(txt, i_indices);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "for(i=0; i<"
                                }, false));
        txt = Tpl.writeText(txt, l_length);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("; i++)\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeText(txt, l_ind__name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("[i]] = "));
        txt = Tpl.writeText(txt, l_index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.nextIter(txt);
        txt = lm_689(txt, rest, a_arrayName);
      then txt;
  end match;
end lm_689;


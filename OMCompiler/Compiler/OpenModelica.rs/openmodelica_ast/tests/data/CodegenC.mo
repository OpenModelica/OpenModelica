protected function fun_787
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_context)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      list<SimCodeVar.SimVar> i_at_vars;
      Integer i_at_indexLinearSystem;
      Integer i_ls_index;
      Integer i_at_index;
      Boolean ret_3;
      Integer ret_2;
      Boolean ret_1;
      Tpl.Text l_auxFunctions;

    case ( txt,
           SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(index = i_ls_index), alternativeTearing = SOME(SimCode.LINEARSYSTEM(index = i_at_index, indexLinearSystem = i_at_indexLinearSystem, vars = i_at_vars))),
           a_context )
      equation
        l_auxFunctions = Tpl.emptyTxt;
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* Linear equation system */\n",
                                    "int retValue;\n",
                                    "\n",
                                    "infoStreamPrint(OMC_LOG_DT, 0, \"Solving linear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" (CASUAL TEARING SET, strict: "));
        txt = Tpl.writeStr(txt, intString(i_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(") at time = %18.10e\", data->localData[0]->timeValue);\n"));
        ret_1 = Config.profileSome();
        txt = fun_783(txt, ret_1, i_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("if (data->simulationInfo->linearSystemData["));
        txt = Tpl.writeStr(txt, intString(i_at_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].checkConstraints(data, threadData) == 1)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("double aux_x["));
        ret_2 = listLength(i_at_vars);
        txt = Tpl.writeStr(txt, intString(ret_2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = { "));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING(",")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, l_auxFunctions) = lm_784(txt, i_at_vars, l_auxFunctions, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " };\n",
                                    "retValue = solve_linear_system(data, threadData, "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_at_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", &aux_x[0]);\n",
                                    "/* The casual tearing set found a solution */\n",
                                    "if (retValue == 0){\n",
                                    "  /* write solution */\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, l_auxFunctions) = lm_785(txt, i_at_vars, l_auxFunctions, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        ret_3 = Config.profileSome();
        txt = fun_786(txt, ret_3, i_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("}\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "else\n",
                                    "{\n",
                                    "  infoStreamPrint(OMC_LOG_DT, 0, \"Constraints of the casual tearing set are violated! Now the strict tearing set is used.\");\n",
                                    "  /* Global constraints are violated. Use the strict tearing set now. */\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->linearSystemData["));
        txt = Tpl.writeStr(txt, intString(i_at_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("].strictTearingFunctionCall(data, threadData);\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_787;


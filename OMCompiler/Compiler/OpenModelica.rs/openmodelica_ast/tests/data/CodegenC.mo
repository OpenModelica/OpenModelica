      then txt;

    case ( txt,
           SimCodeVar.SIMVAR(varKind = BackendDAE.OPT_TGRID()) :: rest )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("+1"));
        txt = Tpl.nextIter(txt);
        txt = lm_904(txt, rest);
      then txt;

    case ( txt,
           _ :: rest )
      equation
        txt = lm_904(txt, rest);
      then txt;
  end match;
end lm_904;

protected function lm_905
  input Tpl.Text in_txt;

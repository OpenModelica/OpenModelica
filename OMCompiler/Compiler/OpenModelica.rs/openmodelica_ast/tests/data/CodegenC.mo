  input Integer in_a_at_index;
  input Integer in_a_ls_indexLinearSystem;
  input Boolean in_a_ls_partOfJac;
  input Integer in_a_ls_index;
  input list<SimCode.SimEqSystem> in_a_at_residual;
  input list<SimCodeVar.SimVar> in_a_at_vars;
  input String in_a_modelNamePrefix;
  input list<SimCode.SimEqSystem> in_a_ls_residual;
  input list<SimCodeVar.SimVar> in_a_ls_vars;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_ls_jacobianMatrix, in_a_at_beqs, in_a_at_simJac, in_a_ls_beqs, in_a_ls_simJac, in_a_at_index, in_a_ls_indexLinearSystem, in_a_ls_partOfJac, in_a_ls_index, in_a_at_residual, in_a_at_vars, in_a_modelNamePrefix, in_a_ls_residual, in_a_ls_vars)
    local
      Tpl.Text txt;
      list<DAE.Exp> a_at_beqs;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> a_at_simJac;
      list<DAE.Exp> a_ls_beqs;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> a_ls_simJac;
      Integer a_at_index;
      Integer a_ls_indexLinearSystem;
      Boolean a_ls_partOfJac;
      Integer a_ls_index;
      list<SimCode.SimEqSystem> a_at_residual;
      list<SimCodeVar.SimVar> a_at_vars;
      String a_modelNamePrefix;
      list<SimCode.SimEqSystem> a_ls_residual;
      list<SimCodeVar.SimVar> a_ls_vars;
      Tpl.Text l_vectorb2;
      Tpl.Text l_varDecls4;
      Tpl.Text l_MatrixA2;
      Tpl.Text l_varDecls3;
      Tpl.Text l_vectorb;
      Tpl.Text l_varDecls2;
      Tpl.Text l_MatrixA;
      Tpl.Text l_varDecls;
      Boolean ret_18;
      Boolean ret_17;
      Boolean ret_16;
      Boolean ret_15;
      Boolean ret_14;
      Boolean ret_13;
      Tpl.Text l_body2;
      Tpl.Text l_prebody2;
      Tpl.Text l_xlocs2;
      Tpl.Text l_tmp2;
      Tpl.Text l_auxFunction2;
      Tpl.Text l_varDeclsRes2;
      Tpl.Text l_body;
      Tpl.Text l_prebody;
      Tpl.Text l_xlocs;
      Tpl.Text l_tmp;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDeclsRes;
      Tpl.Text l_sub;

    case ( txt,
           SOME(_),
           _,
           _,
           _,
           _,
           a_at_index,
           a_ls_indexLinearSystem,
           a_ls_partOfJac,
           a_ls_index,
           a_at_residual,
           a_at_vars,
           a_modelNamePrefix,
           a_ls_residual,
           a_ls_vars )
      equation
        l_sub = Tpl.emptyTxt;
        l_varDeclsRes = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        l_tmp = Tpl.emptyTxt;
        l_xlocs = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_xlocs, l_sub) = lm_293(l_xlocs, a_ls_vars, l_sub);
        l_xlocs = Tpl.popIter(l_xlocs);
        l_prebody = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_prebody, l_tmp) = lm_294(l_prebody, a_ls_residual, a_modelNamePrefix, l_tmp);
        l_prebody = Tpl.popIter(l_prebody);
        l_body = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_body, l_auxFunction, l_varDeclsRes) = lm_296(l_body, a_ls_residual, l_auxFunction, l_varDeclsRes);
        l_body = Tpl.popIter(l_body);
        l_varDeclsRes2 = Tpl.emptyTxt;
        l_auxFunction2 = Tpl.emptyTxt;
        l_tmp2 = Tpl.emptyTxt;
        l_xlocs2 = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_xlocs2, l_sub) = lm_297(l_xlocs2, a_at_vars, l_sub);
        l_xlocs2 = Tpl.popIter(l_xlocs2);
        l_prebody2 = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_prebody2, l_tmp2) = lm_298(l_prebody2, a_at_residual, a_modelNamePrefix, l_tmp2);
        l_prebody2 = Tpl.popIter(l_prebody2);
        l_body2 = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_body2, l_auxFunction2, l_varDeclsRes2) = lm_300(l_body2, a_at_residual, l_auxFunction2, l_varDeclsRes2);
        l_body2 = Tpl.popIter(l_body2);
        txt = Tpl.writeText(txt, l_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_tmp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "void residualFunc"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(RESIDUAL_USERDATA* userData, const double* xloc, double* res, const int* iflag)\n",
                                    "{\n",
                                    "  DATA *data = userData->data;\n",
                                    "  threadData_t *threadData = userData->threadData;\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_301(txt, a_ls_partOfJac, a_ls_indexLinearSystem);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("JACOBIAN* jacobian = NULL;\n"));
        txt = Tpl.writeText(txt, l_varDeclsRes);
        txt = Tpl.softNewLine(txt);
        ret_13 = Config.profileAll();
        txt = fun_302(txt, ret_13, a_ls_index);
        txt = Tpl.softNewLine(txt);
        ret_14 = Config.profileSome();
        txt = fun_303(txt, ret_14, a_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_xlocs);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_prebody);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_body);
        txt = Tpl.softNewLine(txt);
        ret_15 = Config.profileAll();
        txt = fun_304(txt, ret_15, a_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("threadData->lastEquationSolved = "));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n"
                                }, true));
        txt = CodegenCFunctions.initializeStaticLSVars(txt, a_ls_vars, a_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.writeText(txt, l_auxFunction2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_tmp2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "void residualFunc"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(RESIDUAL_USERDATA* userData, const double* xloc, double* res, const int* iflag)\n",
                                    "{\n",
                                    "  DATA *data = userData->data;\n",
                                    "  threadData_t *threadData = userData->threadData;\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_305(txt, a_ls_partOfJac, a_ls_indexLinearSystem);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("JACOBIAN* jacobian = NULL;\n"));
        txt = Tpl.writeText(txt, l_varDeclsRes2);
        txt = Tpl.softNewLine(txt);
        ret_16 = Config.profileAll();
        txt = fun_306(txt, ret_16, a_at_index);
        txt = Tpl.softNewLine(txt);
        ret_17 = Config.profileSome();
        txt = fun_307(txt, ret_17, a_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_xlocs2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_prebody2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_body2);
        txt = Tpl.softNewLine(txt);
        ret_18 = Config.profileAll();
        txt = fun_308(txt, ret_18, a_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("threadData->lastEquationSolved = "));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n"
                                }, true));
        txt = CodegenCFunctions.initializeStaticLSVars(txt, a_at_vars, a_at_index);
      then txt;

    case ( txt,
           _,
           a_at_beqs,
           a_at_simJac,
           a_ls_beqs,
           a_ls_simJac,
           a_at_index,
           _,
           a_ls_partOfJac,
           a_ls_index,
           _,
           a_at_vars,
           _,
           _,
           a_ls_vars )
      equation
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        l_MatrixA = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_MatrixA, l_auxFunction, l_varDecls) = lm_310(l_MatrixA, a_ls_simJac, l_auxFunction, l_varDecls);
        l_MatrixA = Tpl.popIter(l_MatrixA);
        l_varDecls2 = Tpl.emptyTxt;
        l_vectorb = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_vectorb, l_auxFunction, l_varDecls2) = lm_311(l_vectorb, a_ls_beqs, l_auxFunction, l_varDecls2);
        l_vectorb = Tpl.popIter(l_vectorb);
        l_varDecls3 = Tpl.emptyTxt;
        l_auxFunction2 = Tpl.emptyTxt;
        l_MatrixA2 = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_MatrixA2, l_auxFunction2, l_varDecls3) = lm_313(l_MatrixA2, a_at_simJac, l_auxFunction2, l_varDecls3);
        l_MatrixA2 = Tpl.popIter(l_MatrixA2);
        l_varDecls4 = Tpl.emptyTxt;
        l_vectorb2 = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_vectorb2, l_auxFunction2, l_varDecls4) = lm_314(l_vectorb2, a_at_beqs, l_auxFunction2, l_varDecls4);
        l_vectorb2 = Tpl.popIter(l_vectorb2);
        txt = Tpl.writeText(txt, l_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "OMC_DISABLE_OPT\n",
                                    "void setLinearMatrixA"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, LINEAR_SYSTEM_DATA *linearSystemData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_315(txt, a_ls_partOfJac);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_MatrixA);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n",
                                    "void setLinearVectorb"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, LINEAR_SYSTEM_DATA* linearSystemData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_316(txt, a_ls_partOfJac);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varDecls2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorb);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n"
                                }, true));
        txt = CodegenCFunctions.initializeStaticLSVars(txt, a_ls_vars, a_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.writeText(txt, l_auxFunction2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "OMC_DISABLE_OPT\n",
                                    "void setLinearMatrixA"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, LINEAR_SYSTEM_DATA* linearSystemData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_317(txt, a_ls_partOfJac);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varDecls3);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_MatrixA2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n",
                                    "void setLinearVectorb"
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, LINEAR_SYSTEM_DATA* linearSystemData)\n",
                                    "{\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(a_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("};\n"));
        txt = fun_318(txt, a_ls_partOfJac);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varDecls4);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_vectorb2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "OMC_DISABLE_OPT\n"
                                }, true));
        txt = CodegenCFunctions.initializeStaticLSVars(txt, a_at_vars, a_at_index);
      then txt;
  end match;
end fun_319;

protected function fun_320
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eqn;
  input Tpl.Text in_a_sub;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_eqn, in_a_sub, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      String a_modelNamePrefix;
      list<DAE.Exp> i_at_beqs;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> i_at_simJac;
      Integer i_at_index;
      list<SimCode.SimEqSystem> i_at_residual;
      list<SimCodeVar.SimVar> i_at_vars;
      list<DAE.Exp> i_ls_beqs;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> i_ls_simJac;
      Integer i_ls_indexLinearSystem;
      Integer i_ls_index;
      list<SimCode.SimEqSystem> i_ls_residual;
      Boolean i_ls_partOfJac;
      list<SimCodeVar.SimVar> i_ls_vars;
      Option<SimCode.JacobianMatrix> i_ls_jacobianMatrix;
      SimCode.SimEqSystem i_eq_cont;
      list<SimCode.SimEqSystem> ret_0;

    case ( txt,
           SimCode.SES_MIXED(cont = i_eq_cont),
           a_sub,
           a_modelNamePrefix )
      equation
        ret_0 = List.fill(i_eq_cont, 1);
        txt = functionSetupLinearSystems(txt, ret_0, a_modelNamePrefix);
      then (txt, a_sub);

    case ( txt,
           SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(jacobianMatrix = i_ls_jacobianMatrix, vars = i_ls_vars, partOfJac = i_ls_partOfJac, residual = i_ls_residual, index = i_ls_index, indexLinearSystem = i_ls_indexLinearSystem, simJac = i_ls_simJac, beqs = i_ls_beqs), alternativeTearing = NONE()),
           a_sub,
           a_modelNamePrefix )
      equation
        (txt, a_sub) = fun_292(txt, i_ls_jacobianMatrix, i_ls_beqs, i_ls_simJac, i_ls_indexLinearSystem, i_ls_index, a_modelNamePrefix, i_ls_residual, i_ls_partOfJac, a_sub, i_ls_vars);
      then (txt, a_sub);

    case ( txt,
           SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(jacobianMatrix = i_ls_jacobianMatrix, vars = i_ls_vars, residual = i_ls_residual, index = i_ls_index, partOfJac = i_ls_partOfJac, indexLinearSystem = i_ls_indexLinearSystem, simJac = i_ls_simJac, beqs = i_ls_beqs), alternativeTearing = SOME(SimCode.LINEARSYSTEM(vars = i_at_vars, residual = i_at_residual, index = i_at_index, simJac = i_at_simJac, beqs = i_at_beqs))),
           a_sub,
           a_modelNamePrefix )
      equation
        txt = fun_319(txt, i_ls_jacobianMatrix, i_at_beqs, i_at_simJac, i_ls_beqs, i_ls_simJac, i_at_index, i_ls_indexLinearSystem, i_ls_partOfJac, i_ls_index, i_at_residual, i_at_vars, a_modelNamePrefix, i_ls_residual, i_ls_vars);
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub,
           _ )
      then (txt, a_sub);
  end match;
end fun_320;

protected function lm_321
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_sub;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_items, in_a_sub, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_sub;
      String a_modelNamePrefix;
      SimCode.SimEqSystem i_eqn;

    case ( txt,
           {},
           a_sub,
           _ )
      then (txt, a_sub);

    case ( txt,
           i_eqn :: rest,
           a_sub,
           a_modelNamePrefix )
      equation
        (txt, a_sub) = fun_320(txt, i_eqn, a_sub, a_modelNamePrefix);
        txt = Tpl.nextIter(txt);
        (txt, a_sub) = lm_321(txt, rest, a_sub, a_modelNamePrefix);
      then (txt, a_sub);
  end match;
end lm_321;

public function functionSetupLinearSystems
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_linearSystems;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_sub;
algorithm
  l_sub := Tpl.emptyTxt;
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING_LIST({
                                                                    "\n",
                                                                    "\n"
                                                                }, true)), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (out_txt, l_sub) := lm_321(out_txt, a_linearSystems, l_sub, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
end functionSetupLinearSystems;

protected function lm_323
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      String a_modelNamePrefix;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           (i_eq as SimCode.SES_NONLINEAR(alternativeTearing = SOME(_))) :: rest,
           a_modelNamePrefix )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "eqFunction");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt = CodegenUtilSimulation.equationIndex(txt, i_eq);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("(DATA* data, threadData_t* threadData);"));
        txt = Tpl.nextIter(txt);
        txt = lm_323(txt, rest, a_modelNamePrefix);
      then txt;

    case ( txt,
           _ :: rest,
           a_modelNamePrefix )
      equation
        txt = lm_323(txt, rest, a_modelNamePrefix);
      then txt;
  end match;
end lm_323;

public function functionInitialNonLinearSystems
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_nonlinearSystems;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_nlsbody;
  Tpl.Text l_globalConstraintsFunctions;
  Tpl.Text l_tempeqns;
algorithm
  l_tempeqns := Tpl.emptyTxt;
  l_tempeqns := Tpl.pushIter(l_tempeqns, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_tempeqns := lm_323(l_tempeqns, a_nonlinearSystems, a_modelNamePrefix);
  l_tempeqns := Tpl.popIter(l_tempeqns);
  l_globalConstraintsFunctions := Tpl.emptyTxt;
  (l_nlsbody, l_globalConstraintsFunctions) := functionInitialNonLinearSystemsTemp(Tpl.emptyTxt, a_nonlinearSystems, a_modelNamePrefix, l_globalConstraintsFunctions);
  out_txt := Tpl.writeTok(txt, Tpl.ST_LINE("/* Prototypes for the strict sets (Dynamic Tearing) */\n"));
  out_txt := Tpl.writeText(out_txt, l_tempeqns);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "\n",
                                       "/* Global constraints for the casual sets */\n"
                                   }, true));
  out_txt := Tpl.writeText(out_txt, l_globalConstraintsFunctions);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "/* function initialize non-linear systems */\n",
                                       "void "
                                   }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "initialNonLinearSystem");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(int nNonLinearSystems, NONLINEAR_SYSTEM_DATA* nonLinearSystemData)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_nlsbody);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionInitialNonLinearSystems;

protected function fun_325
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eqn;
  input Tpl.Text in_a_globalConstraintsFunctions;
  input String in_a_modelPrefixName;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_globalConstraintsFunctions;
algorithm
  (out_txt, out_a_globalConstraintsFunctions) :=
  match(in_txt, in_a_eqn, in_a_globalConstraintsFunctions, in_a_modelPrefixName)
    local
      Tpl.Text txt;
      Tpl.Text a_globalConstraintsFunctions;
      String a_modelPrefixName;
      SimCode.SimEqSystem i_eq;
      Integer i_nls_index;
      SimCode.NonlinearSystem i_at;
      SimCode.NonlinearSystem i_nls;
      SimCode.SimEqSystem i_eq_cont;
      Tpl.Text l_systemCasual;
      Tpl.Text l_system;
      list<SimCode.SimEqSystem> ret_0;

    case ( txt,
           SimCode.SES_MIXED(cont = i_eq_cont),
           a_globalConstraintsFunctions,
           a_modelPrefixName )
      equation
        ret_0 = List.fill(i_eq_cont, 1);
        (txt, a_globalConstraintsFunctions) = functionInitialNonLinearSystemsTemp(txt, ret_0, a_modelPrefixName, a_globalConstraintsFunctions);
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(index = _)), alternativeTearing = NONE()),
           a_globalConstraintsFunctions,
           a_modelPrefixName )
      equation
        l_system = generateNonLinearSystemData(Tpl.emptyTxt, i_nls, 0, a_modelPrefixName);
        txt = Tpl.writeText(txt, l_system);
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           (i_eq as SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(index = i_nls_index)), alternativeTearing = SOME((i_at as SimCode.NONLINEARSYSTEM(index = _))))),
           a_globalConstraintsFunctions,
           a_modelPrefixName )
      equation
        l_system = generateNonLinearSystemData(Tpl.emptyTxt, i_nls, 0, a_modelPrefixName);
        l_systemCasual = generateNonLinearSystemData(Tpl.emptyTxt, i_at, i_nls_index, a_modelPrefixName);
        a_globalConstraintsFunctions = createGlobalConstraintsFunction(a_globalConstraintsFunctions, i_eq);
        txt = Tpl.writeText(txt, l_system);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_systemCasual);
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           _,
           a_globalConstraintsFunctions,
           _ )
      then (txt, a_globalConstraintsFunctions);
  end match;
end fun_325;

protected function lm_326
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_globalConstraintsFunctions;
  input String in_a_modelPrefixName;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_globalConstraintsFunctions;
algorithm
  (out_txt, out_a_globalConstraintsFunctions) :=
  match(in_txt, in_items, in_a_globalConstraintsFunctions, in_a_modelPrefixName)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_globalConstraintsFunctions;
      String a_modelPrefixName;
      SimCode.SimEqSystem i_eqn;

    case ( txt,
           {},
           a_globalConstraintsFunctions,
           _ )
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           i_eqn :: rest,
           a_globalConstraintsFunctions,
           a_modelPrefixName )
      equation
        (txt, a_globalConstraintsFunctions) = fun_325(txt, i_eqn, a_globalConstraintsFunctions, a_modelPrefixName);
        txt = Tpl.nextIter(txt);
        (txt, a_globalConstraintsFunctions) = lm_326(txt, rest, a_globalConstraintsFunctions, a_modelPrefixName);
      then (txt, a_globalConstraintsFunctions);
  end match;
end lm_326;

public function functionInitialNonLinearSystemsTemp
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_nonlinearSystems;
  input String a_modelPrefixName;
  input Tpl.Text a_globalConstraintsFunctions;

  output Tpl.Text out_txt;

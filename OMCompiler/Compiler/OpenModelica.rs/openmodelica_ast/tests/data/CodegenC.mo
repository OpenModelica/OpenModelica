public function equation_withProfile
  input Tpl.Text txt;
  input String a_index;
  input String a_body;

  output Tpl.Text out_txt;
protected
  Boolean ret_1;
  Boolean ret_0;
algorithm
  ret_0 := Config.profileAll();

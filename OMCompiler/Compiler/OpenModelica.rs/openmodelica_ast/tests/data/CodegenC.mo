    local
      Tpl.Text txt;
      list<SimCodeVar.SimVar> rest;
      SimCodeVar.SimVar i_var;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_var :: rest )
      equation
        txt = defineSimVarArray(txt, i_var, "auxiliaryVars");
        txt = Tpl.nextIter(txt);
        txt = lm_137(txt, rest);
      then txt;
  end match;
end lm_137;

public function simulationFile_dae_header
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode)
    local
      Tpl.Text txt;
      String i_fileNamePrefix;
      list<SimCodeVar.SimVar> i_auxiliaryVars;
      list<SimCodeVar.SimVar> i_residualVars;

    case ( txt,
           SimCode.SIMCODE(daeModeData = SOME(SimCode.DAEMODEDATA(residualVars = i_residualVars, auxiliaryVars = i_auxiliaryVars))) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* residual variable define for daeMode */\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_136(txt, i_residualVars);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* auxiliary variable define for daeMode */\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_137(txt, i_auxiliaryVars);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           SimCode.SIMCODE(fileNamePrefix = i_fileNamePrefix) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#ifndef "));
        txt = Tpl.writeStr(txt, i_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_16DAE_H\n",
                                    "#define "
                                }, false));
        txt = Tpl.writeStr(txt, i_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_16DAE_H\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simulationFile_dae_header;

protected function fun_139
  input Tpl.Text in_txt;
  input Option<SimCode.JacobianMatrix> in_a_sparsityPattern;
  input Tpl.Text in_a_modelNamePrefixStr;
  input list<SimCodeVar.SimVar> in_a_auxiliaryVars;
  input list<SimCodeVar.SimVar> in_a_algebraicVars;
  input list<SimCodeVar.SimVar> in_a_residualVars;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_sparsityPattern, in_a_modelNamePrefixStr, in_a_auxiliaryVars, in_a_algebraicVars, in_a_residualVars)
    local
      Tpl.Text txt;
      Tpl.Text a_modelNamePrefixStr;
      list<SimCodeVar.SimVar> a_auxiliaryVars;
      list<SimCodeVar.SimVar> a_algebraicVars;
      list<SimCodeVar.SimVar> a_residualVars;
      Integer i_maxColor;
      list<list<Integer>> i_colorList;
      SimCode.SparsityPattern i_sparse;
      Integer ret_1;
      Integer ret_0;

    case ( txt,
           SOME(SimCode.JAC_MATRIX(sparsity = i_sparse, coloredCols = i_colorList, maxColorCols = i_maxColor)),
           a_modelNamePrefixStr,
           a_auxiliaryVars,
           a_algebraicVars,
           a_residualVars )
      equation
        ret_0 = listLength(a_residualVars);
        ret_1 = listLength(a_auxiliaryVars);
        txt = initializeDAEmodeData(txt, ret_0, a_algebraicVars, ret_1, i_sparse, i_colorList, i_maxColor, Tpl.textString(a_modelNamePrefixStr));
      then txt;

    case ( txt,
           NONE(),
           a_modelNamePrefixStr,
           _,
           _,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int "));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(a_modelNamePrefixStr), "initializeDAEmodeData");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("(DATA* data, DAEMODE_DATA* daeModeData){ return -1; }"));
      then txt;

    case ( txt,
           _,
           _,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_139;

public function simulationFile_dae
  input Tpl.Text in_txt;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_simCode)
    local
      Tpl.Text txt;
      String i_fullPathPrefix;
      list<list<SimCode.SimEqSystem>> i_daeEquations;
      String i_fileNamePrefix;
      list<SimCodeVar.SimVar> i_auxiliaryVars;
      list<SimCodeVar.SimVar> i_algebraicVars;
      list<SimCodeVar.SimVar> i_residualVars;
      Option<SimCode.JacobianMatrix> i_sparsityPattern;
      SimCode.SimCode i_simCode;
      Tpl.Text txt_2;
      Tpl.Text l_initDAEmode;
      Tpl.Text l_modelNamePrefixStr;

    case ( txt,
           (i_simCode as SimCode.SIMCODE(modelInfo = SimCode.MODELINFO(vars = SimCodeVar.SIMVARS(stateVars = _)), daeModeData = SOME(SimCode.DAEMODEDATA(daeEquations = i_daeEquations, sparsityPattern = i_sparsityPattern, algebraicVars = i_algebraicVars, residualVars = i_residualVars, auxiliaryVars = i_auxiliaryVars)), fileNamePrefix = i_fileNamePrefix, fullPathPrefix = i_fullPathPrefix)) )
      equation
        l_modelNamePrefixStr = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        l_initDAEmode = fun_139(Tpl.emptyTxt, i_sparsityPattern, l_modelNamePrefixStr, i_auxiliaryVars, i_algebraicVars, i_residualVars);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* DAE residuals */\n"));
        txt = simulationFileHeader(txt, i_fileNamePrefix);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#include \"simulation/solver/dae_mode.h\"\n",
                                    "\n",
                                    "#ifdef __cplusplus\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "\n"
                                }, true));
        txt = evaluateDAEResiduals(txt, i_daeEquations, i_fileNamePrefix, i_fullPathPrefix, Tpl.textString(l_modelNamePrefixStr));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.writeText(txt, l_initDAEmode);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "#ifdef __cplusplus\n",
                                    "}\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           i_simCode )
      equation
        l_modelNamePrefixStr = CodegenUtilSimulation.modelNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* DAE residuals is empty */\n"));
        txt_2 = CodegenUtilSimulation.fileNamePrefix(Tpl.emptyTxt, i_simCode);
        txt = simulationFileHeader(txt, Tpl.textString(txt_2));
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#ifdef __cplusplus\n",
                                    "extern \"C\" {\n",
                                    "#endif\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, Tpl.textString(l_modelNamePrefixStr), "initializeDAEmodeData");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(DATA* data, DAEMODE_DATA* daeModeData){ return -1; }\n",
                                    "#ifdef __cplusplus\n",
                                    "}\n",
                                    "#endif"
                                }, false));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;
  end match;
end simulationFile_dae;


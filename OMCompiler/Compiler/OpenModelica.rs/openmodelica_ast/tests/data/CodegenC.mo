protected function fun_67
  input Tpl.Text in_txt;
  input SimCodeVar.SimVar in_a_simVar;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_simVar, in_a_sub)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      DAE.ComponentRef i_name;
      DAE.ComponentRef i_c;

    case ( txt,
           SimCodeVar.SIMVAR(arrayCref = SOME(i_c), aliasvar = SimCodeVar.NOALIAS()),
           a_sub )
      equation
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_c, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = "));
        txt = CodegenCFunctions.crefPre(txt, i_c);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.SIMVAR(aliasvar = SimCodeVar.NOALIAS(), name = i_name),
           a_sub )
      equation
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_name, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = "));
        txt = CodegenCFunctions.crefPre(txt, i_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub )
      then (txt, a_sub);
  end match;
end fun_67;


    local
      Tpl.Text txt;
      DAE.ComponentRef i_cref;
      DAE.ComponentRef i_cr;
      DAE.ComponentRef ret_1;
      DAE.ComponentRef ret_0;

    case ( txt,
           DAE.CREF_QUAL(componentRef = (i_cr as DAE.CREF_QUAL(ident = "$PRE"))) )
      equation
        ret_0 = ComponentReference.popCref(i_cr);
        txt = CodegenCFunctions.crefVarInfo(txt, ret_0);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(".name"));
      then txt;

    case ( txt,
           i_cref )
      equation
        ret_1 = ComponentReference.popCref(i_cref);

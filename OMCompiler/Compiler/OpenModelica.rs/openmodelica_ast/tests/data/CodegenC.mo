protected function fun_766
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input Integer in_a_i0;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_i0, in_a_context)
    local
      Tpl.Text txt;
      Integer a_i0;
      SimCodeFunction.Context a_context;
      Integer i_call__index;
      Tpl.Text l_sub__name;
      Tpl.Text l_jac;

    case ( txt,
           SimCode.SES_GENERIC_ASSIGN(call_index = i_call__index),
           a_i0,
           a_context )
      equation
        l_jac = fun_764(Tpl.emptyTxt, a_context);
        l_sub__name = fun_765(Tpl.emptyTxt, a_context);
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case "));
        txt = Tpl.writeStr(txt, intString(i_call__index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(":\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("genericCall_"));
        txt = Tpl.writeText(txt, l_sub__name);
        txt = Tpl.writeStr(txt, intString(i_call__index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("(data, threadData"));
        txt = Tpl.writeText(txt, l_jac);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", equationIndexes, idx_lst_"));
        txt = Tpl.writeStr(txt, intString(i_call__index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("[call_indices["));
        txt = Tpl.writeStr(txt, intString(a_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]]);\n",
                                    "call_indices["
                                }, false));
        txt = Tpl.writeStr(txt, intString(a_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]++;\n",
                                    "break;"
                                }, false));
        txt = Tpl.popBlock(txt);
        txt = Tpl.popBlock(txt);
      then txt;

    case ( txt,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_766;


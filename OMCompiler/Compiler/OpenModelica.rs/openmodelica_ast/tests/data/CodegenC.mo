  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("int "));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "functionRemovedInitialEquations");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",

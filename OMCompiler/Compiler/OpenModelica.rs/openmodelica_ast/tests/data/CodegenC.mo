    case ( txt,
           SimCode.CLOCKED_PARTITION(subPartitions = (i_subPartitions as _ :: _)),
           a_modelNamePrefix,
           a_base__idx )
      equation
        txt = functionSystemsSynchronousSubClocks(txt, i_subPartitions, a_base__idx, a_modelNamePrefix);
      then txt;

    case ( txt,
           _,
           a_modelNamePrefix,
           a_base__idx )
      equation
        l_name = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("functionEquationsSynchronous_system_"));
        l_name = Tpl.writeStr(l_name, intString(a_base__idx));
        l_name = Tpl.writeTok(l_name, Tpl.ST_STRING("_0"));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("case 0: // this is a fake function call for CLOCKED_PARTITION(subPartitions = {})\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("ret = "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, Tpl.textString(l_name));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(data, threadData);\n",
                                    "break;"
                                }, false));
        txt = Tpl.popBlock(txt);
      then txt;
  end match;
end fun_98;


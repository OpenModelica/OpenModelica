  (l_fncalls, l_file, out_a_eqFuncs) := lm_436(l_fncalls, ret_4, a_init, a_noOpt, a_static, a_fullPathPrefix, a_partName, a_fileNamePrefix, l_multiFile, l_file, a_eqFuncs, a_funcName, a_modelNamePrefix);

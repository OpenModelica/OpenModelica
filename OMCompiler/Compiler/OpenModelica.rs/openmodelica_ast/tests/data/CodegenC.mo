protected function lm_808
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_items, in_a_sub)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      Tpl.Text a_sub;
      DAE.ComponentRef i_e;

    case ( txt,
           {},
           a_sub )
      then (txt, a_sub);

    case ( txt,
           i_e :: rest,
           a_sub )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("("));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_e, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" && !"));
        txt = CodegenCFunctions.crefPre(txt, i_e);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" /* edge */)"));
        txt = Tpl.nextIter(txt);
        (txt, a_sub) = lm_808(txt, rest, a_sub);
      then (txt, a_sub);
  end match;
end lm_808;

protected function fun_809
  input Tpl.Text in_txt;
  input Boolean in_mArg;

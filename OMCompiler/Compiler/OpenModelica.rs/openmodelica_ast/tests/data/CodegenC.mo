    case ( txt,
           {},
           a_sub )
      then (txt, a_sub);

    case ( txt,
           SimCodeVar.SIMVAR(name = i_var_name) :: rest,
           a_sub )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_var_name, a_sub);

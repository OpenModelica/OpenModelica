protected function fun_806
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq)
    local
      Tpl.Text txt;
      Integer i_nls_indexNonLinearSystem;
      list<DAE.ComponentRef> i_at_crefs;
      Integer i_at_indexNonLinearSystem;
      Integer i_nls_index;
      Integer i_at_index;
      Boolean ret_1;
      Boolean ret_0;

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = SimCode.NONLINEARSYSTEM(index = i_nls_index, indexNonLinearSystem = i_nls_indexNonLinearSystem), alternativeTearing = SOME(SimCode.NONLINEARSYSTEM(index = i_at_index, indexNonLinearSystem = i_at_indexNonLinearSystem, crefs = i_at_crefs))) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "int retValue;\n",
                                    "infoStreamPrint(OMC_LOG_DT, 0, \"Solving nonlinear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_at_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" (CASUAL TEARING SET, strict: "));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(") at time = %18.10e\", data->localData[0]->timeValue);\n"));
        ret_0 = Config.profileSome();
        txt = fun_802(txt, ret_0, i_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "if (data->simulationInfo->nonlinearSystemData["
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_at_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "].checkConstraints(data, threadData) == 1)\n",
                                    "{\n",
                                    "  /* get old value */\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_803(txt, i_at_crefs, i_nls_indexNonLinearSystem);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("retValue = solve_nonlinear_system(data, threadData, "));
        txt = Tpl.writeStr(txt, intString(i_at_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "/* The casual tearing set found a solution */\n",
                                    "if (retValue == 0){\n",
                                    "  /* write solution */\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_804(txt, i_at_crefs, i_at_indexNonLinearSystem);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        ret_1 = Config.profileSome();
        txt = fun_805(txt, ret_1, i_at_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("}\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "else\n",
                                    "{\n",
                                    "  infoStreamPrint(OMC_LOG_DT, 0, \"Constraints of the casual tearing set are violated! Now the strict tearing set is used.\");\n",
                                    "  /* Global constraints are violated. Use the strict tearing set now. */\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->nonlinearSystemData["));
        txt = Tpl.writeStr(txt, intString(i_at_indexNonLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("].strictTearingFunctionCall(data, threadData);\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_806;


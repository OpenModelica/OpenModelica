  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("_model.h\"\n"));
  out_txt := Tpl.writeText(out_txt, l_daeHeader);
end simulationFileHeader;

protected function fun_181
  input Tpl.Text in_txt;
  input String in_a_isModelExchangeFMU;
  input String in_a_fileNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_isModelExchangeFMU, in_a_fileNamePrefix)
    local
      Tpl.Text txt;
      String a_fileNamePrefix;

    case ( txt,
           "1.0",
           a_fileNamePrefix )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "data->modelData->initXMLData = NULL;\n",
                                    "data->modelData->modelDataXml.infoXMLData =\n",
                                    "#if defined(OMC_MINIMAL_METADATA)\n",
                                    "  NULL;\n",
                                    "#else\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#include \""));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_info.c\"\n",
                                    ";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#endif\n",
                                    "data->modelData->modelDataXml.fileName = NULL;"
                                }, false));
      then txt;

    case ( txt,
           "",
           a_fileNamePrefix )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#if defined(OPENMODELICA_XML_FROM_FILE_AT_RUNTIME)\n",
                                    "data->modelData->initXMLData = NULL;\n",
                                    "data->modelData->modelDataXml.infoXMLData = NULL;\n",
                                    "#else\n",
                                    "#if defined(_MSC_VER) /* handle joke compilers */\n",
                                    "{\n",
                                    "/* for MSVC we encode a string like char x[] = {\'a\', \'b\', \'c\', \'\\0\'} */\n",
                                    "/* because the string constant limit is 65535 bytes */\n",
                                    "static const char contents_init[] =\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#include \""));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_init.c\"\n",
                                    ";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("static const char contents_info[] =\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#include \""));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_info.c\"\n",
                                    ";\n",
                                    "data->modelData->initXMLData = contents_init;\n",
                                    "data->modelData->modelDataXml.infoXMLData = contents_info;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "#else /* handle real compilers */\n",
                                    "data->modelData->initXMLData =\n",
                                    "#include \""
                                }, false));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_init.c\"\n",
                                    "  ;\n",
                                    "data->modelData->modelDataXml.infoXMLData =\n",
                                    "#include \""
                                }, false));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_info.c\"\n",
                                    "  ;\n",
                                    "#endif /* defined(_MSC_VER) */\n",
                                    "#endif /* defined(OPENMODELICA_XML_FROM_FILE_AT_RUNTIME) */\n",
                                    "data->modelData->modelDataXml.fileName = \""
                                }, false));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_info.json\";\n",
                                    "data->modelData->resourcesDir = NULL;"
                                }, false));
      then txt;

    case ( txt,
           _,
           a_fileNamePrefix )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "data->modelData->initXMLData = NULL;\n",
                                    "data->modelData->modelDataXml.infoXMLData = NULL;\n",
                                    "GC_asprintf(&data->modelData->modelDataXml.fileName, \"%s/"
                                }, false));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_info.json\", data->modelData->resourcesDir);"));
      then txt;
  end match;
end fun_181;


public function eqEval
  input Tpl.Text in_txt;
  input BackendDAE.EvaluationStages in_a_eqEval;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eqEval)
    local
      Tpl.Text txt;
      Boolean i_discreteEval;
      Boolean i_zerocrossEval;
      Boolean i_algebraicEval;
      Boolean i_dynamicEval;
      Tpl.Text l_di;
      Tpl.Text l_zc;
      Tpl.Text l_al;
      Tpl.Text l_dy;

    case ( txt,
           BackendDAE.EVALUATION_STAGES(dynamicEval = i_dynamicEval, algebraicEval = i_algebraicEval, zerocrossEval = i_zerocrossEval, discreteEval = i_discreteEval) )
      equation
        l_dy = fun_888(Tpl.emptyTxt, i_dynamicEval);
        l_al = fun_889(Tpl.emptyTxt, i_algebraicEval);
        l_zc = fun_890(Tpl.emptyTxt, i_zerocrossEval);
        l_di = fun_891(Tpl.emptyTxt, i_discreteEval);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("evalStages = 0"));
        txt = Tpl.writeText(txt, l_dy);
        txt = Tpl.writeText(txt, l_al);
        txt = Tpl.writeText(txt, l_zc);
        txt = Tpl.writeText(txt, l_di);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end eqEval;

protected function lm_893
  input Tpl.Text in_txt;
  input list<DAE.ClassAttributes> in_items;
  input String in_a_modelNamePrefixStr;
  input SimCode.SimCode in_a_simCode;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefixStr, in_a_simCode)
    local
      Tpl.Text txt;
      list<DAE.ClassAttributes> rest;
      String a_modelNamePrefixStr;
      SimCode.SimCode a_simCode;
      DAE.ClassAttributes i_classAttribute;

    case ( txt,
           {},
           _,
           _ )
      then txt;

    case ( txt,
           i_classAttribute :: rest,
           a_modelNamePrefixStr,
           a_simCode )
      equation
        txt = optimizationComponents1(txt, i_classAttribute, a_simCode, a_modelNamePrefixStr);
        txt = Tpl.nextIter(txt);
        txt = lm_893(txt, rest, a_modelNamePrefixStr, a_simCode);
      then txt;
  end match;
end lm_893;

public function optimizationComponents
  input Tpl.Text in_txt;
  input list<DAE.ClassAttributes> in_a_classAttributes;
  input SimCode.SimCode in_a_simCode;
  input String in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_classAttributes, in_a_simCode, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      SimCode.SimCode a_simCode;
      String a_modelNamePrefixStr;
      list<DAE.ClassAttributes> i_classAttributes;
      Tpl.Text l_fail;

    case ( txt,
           {},
           _,
           a_modelNamePrefixStr )
      equation
        l_fail = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("throwStreamPrint(NULL, \"The model was not compiled with -g=Optimica and the corresponding goal function. The optimization solver cannot be used.\");"));
        l_fail = Tpl.writeTok(l_fail, Tpl.ST_NEW_LINE());
        l_fail = Tpl.writeTok(l_fail, Tpl.ST_STRING("return 0;"));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("int "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "mayer");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA* data, modelica_real** res,short *i) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "lagrange");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA* data, modelica_real** res, short * i1, short*i2) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "getInputVarIndicesInOptimization");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA* data, int* input_var_indices) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "pickUpBoundsForInputsInOptimization");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA* data, modelica_real* min, modelica_real* max, modelica_real*nominal, modelica_boolean *useNominal, char ** name, modelica_real * start, modelica_real * startTimeOpt) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "setInputData");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA *data, const modelica_boolean file) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "int "
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefixStr, "getTimeGrid");
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("(DATA *data, modelica_integer * nsi, modelica_real**t) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_fail);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           i_classAttributes,
           a_simCode,
           a_modelNamePrefixStr )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_893(txt, i_classAttributes, a_modelNamePrefixStr, a_simCode);
        txt = Tpl.popIter(txt);
      then txt;
  end match;
end optimizationComponents;

protected function fun_895
  input Tpl.Text in_txt;
  input Boolean in_mArg;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_mArg)
    local
      Tpl.Text txt;
      DAE.ComponentRef ret_2;
      DAE.ComponentRef ret_1;
      DAE.ComponentRef ret_0;

    case ( txt,
           false )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("*index_Dres = "));
        ret_0 = ComponentReference.makeUntypedCrefIdent(BackendDAE.optimizationMayerTermName);
        ret_1 = ComponentReference.makeUntypedCrefIdent("dummyVarC");
        ret_2 = ComponentReference.createDifferentiatedCrefName(ret_0, ret_1, "C");
        txt = CodegenCFunctions.crefToIndex(txt, ret_2);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "return 0;"
                                }, false));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_895;

protected function fun_896
  input Tpl.Text in_txt;
  input Option<DAE.Exp> in_a_objetiveE;
  input Tpl.Text in_a_sub;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_objetiveE, in_a_sub)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      DAE.ComponentRef ret_6;
      Boolean ret_5;
      Tpl.Text txt_4;
      DAE.ComponentRef ret_3;
      DAE.ComponentRef ret_2;
      DAE.ComponentRef ret_1;
      Tpl.Text l_setMayerIndex;

    case ( txt,
           SOME(_),
           a_sub )
      equation
        ret_1 = ComponentReference.makeUntypedCrefIdent(BackendDAE.optimizationMayerTermName);
        ret_2 = ComponentReference.makeUntypedCrefIdent("dummyVarC");
        ret_3 = ComponentReference.createDifferentiatedCrefName(ret_1, ret_2, "C");
        txt_4 = CodegenCFunctions.crefToIndex(Tpl.emptyTxt, ret_3);
        ret_5 = stringEq(Tpl.textString(txt_4), "-2");
        l_setMayerIndex = fun_895(Tpl.emptyTxt, ret_5);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("*res = &"));
        ret_6 = ComponentReference.makeUntypedCrefIdent(BackendDAE.optimizationMayerTermName);
        (txt, a_sub) = CodegenCFunctions.cref(txt, ret_6, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.writeText(txt, l_setMayerIndex);
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub )
      then (txt, a_sub);
  end match;
end fun_896;

protected function fun_897
  input Tpl.Text in_txt;
  input Option<DAE.Exp> in_a_startTimeE;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_a_startTimeE, in_a_auxFunction, in_a_varDecls, in_a_preExp)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp i_exp;
      Tpl.Text l_startTimeOptExp;

    case ( txt,
           SOME(i_exp),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        (l_startTimeOptExp, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_exp, SimCodeFunction.contextOther, a_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("*startTimeOpt = "));
        txt = Tpl.writeText(txt, l_startTimeOptExp);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_897;


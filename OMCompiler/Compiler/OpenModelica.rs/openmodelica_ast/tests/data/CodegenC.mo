protected function fun_387
  input Tpl.Text in_txt;
  input SimCode.NonlinearSystem in_a_system;
  input Integer in_a_whichSet;
  input Tpl.Text in_a_sub;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
algorithm
  (out_txt, out_a_sub) :=
  match(in_txt, in_a_system, in_a_whichSet, in_a_sub, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      Integer a_whichSet;
      Tpl.Text a_sub;
      String a_modelNamePrefix;
      Option<Integer> i_clockIndex;
      Integer i_nls_index;
      list<DAE.ComponentRef> i_nls_crefs;
      list<SimCode.SimEqSystem> i_nls_eqs;
      Boolean ret_18;
      Boolean ret_17;
      Integer ret_16;
      Integer ret_15;
      Boolean ret_14;
      Boolean ret_13;
      Boolean ret_12;
      Tpl.Text l_returnValue;
      Boolean ret_10;
      Tpl.Text l_residualFunctionHeader;
      Tpl.Text l_body;
      Tpl.Text l_prebody;
      Tpl.Text l_xlocs;
      Tpl.Text l_restoreKnownOutputs;
      Tpl.Text l_backupOutputs;
      Tpl.Text l_innerNLSSystems;
      Tpl.Text l_dummyPrototypes;
      Tpl.Text l_innerEqns;
      Tpl.Text l_varDecls;

    case ( txt,
           SimCode.NONLINEARSYSTEM(eqs = i_nls_eqs, crefs = i_nls_crefs, index = i_nls_index, clockIndex = i_clockIndex),
           a_whichSet,
           a_sub,
           a_modelNamePrefix )
      equation
        l_varDecls = Tpl.emptyTxt;
        l_innerEqns = Tpl.emptyTxt;
        l_dummyPrototypes = Tpl.emptyTxt;
        (l_innerNLSSystems, l_dummyPrototypes) = functionNonLinearResiduals(Tpl.emptyTxt, i_nls_eqs, a_modelNamePrefix, l_dummyPrototypes);
        (l_backupOutputs, a_sub, l_varDecls) = fun_358(Tpl.emptyTxt, i_nls_eqs, a_sub, l_varDecls);
        (l_restoreKnownOutputs, a_sub) = fun_360(Tpl.emptyTxt, i_nls_eqs, a_sub);
        l_xlocs = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_xlocs, a_sub) = lm_361(l_xlocs, i_nls_crefs, a_sub);
        l_xlocs = Tpl.popIter(l_xlocs);
        l_prebody = Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (l_prebody, l_innerEqns) = lm_362(l_prebody, i_nls_eqs, a_modelNamePrefix, l_innerEqns);
        l_prebody = Tpl.popIter(l_prebody);
        (l_body, l_innerEqns, l_varDecls, a_sub) = fun_378(Tpl.emptyTxt, i_nls_eqs, l_innerEqns, l_varDecls, a_sub, i_nls_crefs);
        ret_10 = intEq(a_whichSet, 0);
        l_residualFunctionHeader = fun_379(Tpl.emptyTxt, ret_10, i_nls_index);
        ret_12 = intEq(a_whichSet, 1);
        l_returnValue = fun_380(Tpl.emptyTxt, ret_12);
        txt = Tpl.writeText(txt, l_innerNLSSystems);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "/* inner equations */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_innerEqns);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.writeText(txt, l_residualFunctionHeader);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "{\n",
                                    "  DATA *data = userData->data;\n",
                                    "  threadData_t *threadData = userData->threadData;\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "int i,j;"
                                }, false));
        txt = fun_382(txt, i_clockIndex);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        ret_13 = Config.profileAll();
        txt = fun_383(txt, ret_13, i_nls_index);
        txt = Tpl.softNewLine(txt);
        ret_14 = Config.profileSome();
        txt = fun_384(txt, ret_14, i_nls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* iteration variables */\n",
                                    "for (i=0; i<"
                                }, false));
        ret_15 = listLength(i_nls_crefs);
        txt = Tpl.writeStr(txt, intString(ret_15));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "; i++) {\n",
                                    "  if (isinf(xloc[i]) || isnan(xloc[i])) {\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(4));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("errorStreamPrint(OMC_LOG_NLS, 0, \"residualFunc"));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(": Iteration variable `%s` is inf or nan.\",\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("modelInfoGetEquation(&data->modelData->modelDataXml, "));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(").vars[i]);\n"));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("for (j=0; j<"));
        ret_16 = listLength(i_nls_crefs);
        txt = Tpl.writeStr(txt, intString(ret_16));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "; j++) {\n",
                                    "  res[j] = NAN;\n",
                                    "}\n",
                                    "throwStreamPrintWithEquationIndexes(threadData, omc_dummyFileInfo, equationIndexes, \"residualFunc"
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" failed at time=%.15g.\\nFor more information please use -lv LOG_NLS.\", data->localData[0]->timeValue);\n"));
        ret_17 = intEq(a_whichSet, 0);
        txt = fun_385(txt, ret_17);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "  }\n",
                                    "}\n"
                                }, true));
        txt = Tpl.writeText(txt, l_xlocs);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* backup outputs */\n"));
        txt = Tpl.writeText(txt, l_backupOutputs);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* pre body */\n"));
        txt = Tpl.writeText(txt, l_prebody);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* body */\n"));
        txt = Tpl.writeText(txt, l_body);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* restore known outputs */\n"));
        txt = Tpl.writeText(txt, l_restoreKnownOutputs);
        txt = Tpl.softNewLine(txt);
        ret_18 = Config.profileAll();
        txt = fun_386(txt, ret_18, i_nls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("threadData->lastEquationSolved = "));
        txt = Tpl.writeStr(txt, intString(i_nls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.writeText(txt, l_returnValue);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then (txt, a_sub);

    case ( txt,
           _,
           _,
           a_sub,
           _ )
      then (txt, a_sub);
  end match;
end fun_387;

public function generateNonLinearResidualFunction
  input Tpl.Text txt;
  input SimCode.NonlinearSystem a_system;
  input String a_modelNamePrefix;
  input Integer a_whichSet;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_sub;
algorithm
  System.tmpTickReset(0);
  l_sub := Tpl.emptyTxt;
  (out_txt, l_sub) := fun_387(txt, a_system, a_whichSet, l_sub, a_modelNamePrefix);
end generateNonLinearResidualFunction;

public function generateStaticEmptySparseData
  input Tpl.Text txt;
  input String a_indexName;
  input String a_systemType;

  output Tpl.Text out_txt;
algorithm
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING("void initializeSparsePattern"));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("("));
  out_txt := Tpl.writeStr(out_txt, a_systemType);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "* inSysData)\n",
                                       "{\n",
                                       "  /* no sparsity pattern available */\n",
                                       "  inSysData->isPatternAvailable = FALSE;\n",
                                       "}\n",
                                       "\n",
                                       "void freeSparsePattern"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, a_indexName);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("("));
  out_txt := Tpl.writeStr(out_txt, a_systemType);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "* inSysData)\n",
                                       "{\n",
                                       "  /* nothing to free */\n",
                                       "}"
                                   }, false));
end generateStaticEmptySparseData;

protected function fun_390
  input Tpl.Text in_txt;
  input SimCode.SparsityPattern in_a_sparsepattern;
  input String in_a_indexName;
  input String in_a_systemType;
  input list<list<Integer>> in_a_colorList;
  input Integer in_a_maxColor;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_sparsepattern, in_a_indexName, in_a_systemType, in_a_colorList, in_a_maxColor)
    local
      Tpl.Text txt;
      String a_indexName;
      String a_systemType;
      list<list<Integer>> a_colorList;
      Integer a_maxColor;
      SimCode.SparsityPattern i_sparsepattern;
      Tpl.Text l_colorString;
      Integer ret_9;
      list<list<Integer>> ret_8;
      Tpl.Text l_rowIndex;
      Integer ret_6;
      Tpl.Text l_colPtr;
      Integer ret_4;
      Tpl.Text l_sizeleadindex;
      Integer ret_2;
      list<list<Integer>> ret_1;
      Tpl.Text l_sp__size__index;

    case ( txt,
           {},
           a_indexName,
           a_systemType,
           _,
           _ )
      equation
        txt = generateStaticEmptySparseData(txt, a_indexName, a_systemType);
      then txt;

    case ( txt,
           i_sparsepattern,
           a_indexName,
           a_systemType,
           a_colorList,
           a_maxColor )
      equation
        ret_1 = List.unzipSecond(i_sparsepattern);
        ret_2 = List.lengthListElements(ret_1);
        l_sp__size__index = Tpl.writeStr(Tpl.emptyTxt, intString(ret_2));
        ret_4 = listLength(i_sparsepattern);
        l_sizeleadindex = Tpl.writeStr(Tpl.emptyTxt, intString(ret_4));
        ret_6 = listLength(i_sparsepattern);
        l_colPtr = genSPCRSPtr(Tpl.emptyTxt, ret_6, i_sparsepattern, "colPtrIndex");
        ret_8 = List.unzipSecond(i_sparsepattern);
        ret_9 = List.lengthListElements(ret_8);
        l_rowIndex = genSPCRSRows(Tpl.emptyTxt, ret_9, i_sparsepattern, "rowIndex");
        l_colorString = genSPColors(Tpl.emptyTxt, a_colorList, "inSysData->sparsePattern->colorCols");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "OMC_DISABLE_OPT\n",
                                    "void initializeSparsePattern"
                                }, false));
        txt = Tpl.writeStr(txt, a_indexName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("("));
        txt = Tpl.writeStr(txt, a_systemType);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "* inSysData)\n",
                                    "{\n",
                                    "  int i=0;\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_colPtr);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_rowIndex);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* sparsity pattern available */\n",
                                    "inSysData->isPatternAvailable = TRUE;\n",
                                    "inSysData->sparsePattern = allocSparsePattern("
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(a_maxColor));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ");\n",
                                    "\n",
                                    "/* write lead index of compressed sparse column */\n",
                                    "memcpy(inSysData->sparsePattern->leadindex, colPtrIndex, ("
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1)*sizeof(unsigned int));\n",
                                    "\n",
                                    "for(i=2;i<"
                                }, false));
        txt = Tpl.writeText(txt, l_sizeleadindex);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "+1;++i)\n",
                                    "  inSysData->sparsePattern->leadindex[i] += inSysData->sparsePattern->leadindex[i-1];\n",
                                    "\n",
                                    "/* call sparse index */\n",
                                    "memcpy(inSysData->sparsePattern->index, rowIndex, "
                                }, false));
        txt = Tpl.writeText(txt, l_sp__size__index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "*sizeof(unsigned int));\n",
                                    "\n",
                                    "/* write color array */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_colorString);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "\n",
                                    "void freeSparsePattern"
                                }, false));
        txt = Tpl.writeStr(txt, a_indexName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("("));
        txt = Tpl.writeStr(txt, a_systemType);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "* inSysData)\n",
                                    "{\n",
                                    "  if (inSysData->isPatternAvailable) {\n",
                                    "    freeSparsePattern(inSysData->sparsePattern);\n",
                                    "    free(inSysData->sparsePattern);\n",
                                    "    inSysData->sparsePattern = NULL;\n",
                                    "    inSysData->isPatternAvailable = FALSE;\n",
                                    "  }\n",
                                    "}"
                                }, false));
      then txt;
  end match;
end fun_390;

public function generateStaticSparseData
  input Tpl.Text txt;
  input String a_indexName;
  input String a_systemType;
  input SimCode.SparsityPattern a_sparsepattern;
  input list<list<Integer>> a_colorList;

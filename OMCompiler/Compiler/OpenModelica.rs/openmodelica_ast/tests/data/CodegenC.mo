        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* local constraints */\n"));
        txt = createLocalConstraints(txt, i_eq);
        txt = Tpl.softNewLine(txt);
        txt = equation_call(txt, i_eq, a_modelNamePrefixStr, SimCodeFunction.contextJacobian);
      then (txt, a_eqs);

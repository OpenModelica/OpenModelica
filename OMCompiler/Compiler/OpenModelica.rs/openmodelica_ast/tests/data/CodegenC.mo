      Tpl.Text a_sub__name;
      SimCodeFunction.Context a_context;
      SimCode.SimGenericCall i_call;

    case ( txt,
           {},
           _,
           _,
           _ )
      then txt;

    case ( txt,
           i_call :: rest,
           a_jac,
           a_sub__name,
           a_context )
      equation
        txt = fun_977(txt, i_call, a_jac, a_sub__name, a_context);
        txt = Tpl.nextIter(txt);
        txt = lm_978(txt, rest, a_jac, a_sub__name, a_context);
      then txt;
  end match;

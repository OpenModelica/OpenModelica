public function functionUpdateBoundVariableAttributes
  input Tpl.Text txt;
  input SimCode.SimCode a_simCode;
  input list<SimCode.SimEqSystem> a_startValueEquations;
  input list<SimCode.SimEqSystem> a_nominalValueEquations;
  input list<SimCode.SimEqSystem> a_minValueEquations;
  input list<SimCode.SimEqSystem> a_maxValueEquations;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_sub;
algorithm
  l_sub := Tpl.emptyTxt;
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_409(out_txt, a_startValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_410(out_txt, a_nominalValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_411(out_txt, a_minValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_412(out_txt, a_maxValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "OMC_DISABLE_OPT\n",
                                       "int "
                                   }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "updateBoundVariableAttributes");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData)\n",
                                       "{\n",
                                       "  /* min ******************************************************** */\n",
                                       "  infoStreamPrint(OMC_LOG_INIT, 1, \"updating min-values\");\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_413(out_txt, a_minValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "messageClose(OMC_LOG_INIT);\n",
                                       "\n",
                                       "/* max ******************************************************** */\n",
                                       "infoStreamPrint(OMC_LOG_INIT, 1, \"updating max-values\");\n"
                                   }, true));
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_414(out_txt, a_maxValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "messageClose(OMC_LOG_INIT);\n",
                                       "\n",
                                       "/* nominal **************************************************** */\n",
                                       "infoStreamPrint(OMC_LOG_INIT, 1, \"updating nominal-values\");\n"
                                   }, true));
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_415(out_txt, a_nominalValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "messageClose(OMC_LOG_INIT);\n",
                                       "\n",
                                       "/* start ****************************************************** */\n",
                                       "infoStreamPrint(OMC_LOG_INIT, 1, \"updating primary start-values\");\n"
                                   }, true));
  out_txt := Tpl.pushIter(out_txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_416(out_txt, a_startValueEquations, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "messageClose(OMC_LOG_INIT);\n",
                                       "\n",
                                       "return 0;\n"
                                   }, true));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionUpdateBoundVariableAttributes;

protected function fun_418
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq)
    local
      Tpl.Text txt;

    case ( txt,
           SimCode.SES_LINEAR(lSystem = _) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("OMC_DISABLE_OPT"));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_418;

protected function fun_419
  input Tpl.Text in_txt;
  input Boolean in_a_noOpt;
  input SimCode.SimEqSystem in_a_eq;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_noOpt, in_a_eq)
    local
      Tpl.Text txt;
      SimCode.SimEqSystem a_eq;

    case ( txt,
           false,
           a_eq )
      equation
        txt = fun_418(txt, a_eq);
      then txt;

    case ( txt,
           _,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("OMC_DISABLE_OPT"));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
      then txt;
  end match;
end fun_419;


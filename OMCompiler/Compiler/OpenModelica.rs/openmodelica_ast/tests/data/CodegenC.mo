                                   }, true));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("#if !defined(OMC_MINIMAL_RUNTIME)\n"));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  ret_6 := Config.profileFunctions();
  out_txt := fun_585(out_txt, ret_6);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("rt_tick(SIM_TIMER_ZC);\n"));

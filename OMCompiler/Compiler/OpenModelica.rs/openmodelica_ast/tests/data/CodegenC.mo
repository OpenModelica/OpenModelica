  input Tpl.Text in_txt;
  input list<BackendDAE.SimIterator> in_items;
  input Tpl.Text in_a_sub;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_sub, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_items, in_a_sub, in_a_auxFunction, in_a_varDecls, in_a_preExp)
    local
      Tpl.Text txt;
      list<BackendDAE.SimIterator> rest;
      Tpl.Text a_sub;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      BackendDAE.SimIterator i_it;

    case ( txt,
           {},
           a_sub,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      then (txt, a_sub, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           i_it :: rest,
           a_sub,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        (txt, a_preExp, a_varDecls, a_auxFunction, a_sub) = forIterator(txt, i_it, SimCodeFunction.contextZeroCross, a_preExp, a_varDecls, a_auxFunction, a_sub);
        txt = Tpl.nextIter(txt);
        (txt, a_sub, a_auxFunction, a_varDecls, a_preExp) = lm_608(txt, rest, a_sub, a_auxFunction, a_varDecls, a_preExp);
      then (txt, a_sub, a_auxFunction, a_varDecls, a_preExp);
  end match;
end lm_608;


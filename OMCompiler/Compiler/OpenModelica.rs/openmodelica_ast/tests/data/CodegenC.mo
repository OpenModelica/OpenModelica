        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("];"));
        txt = Tpl.nextIter(txt);
        (txt, a_sub) = lm_293(txt, rest, a_sub);
      then (txt, a_sub);

    case ( txt,
           _ :: rest,
           a_sub )
      equation
        (txt, a_sub) = lm_293(txt, rest, a_sub);
      then (txt, a_sub);
  end match;
end lm_293;


protected function fun_347
  input Tpl.Text in_txt;
  input DAE.Constraint in_a_con;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_con)
    local
      Tpl.Text txt;
      DAE.Exp i_c;
      Tpl.Text l_condition;
      Tpl.Text l_auxFunction;
      Tpl.Text l_varDecls;
      Tpl.Text l_preExp;

    case ( txt,
           DAE.CONSTRAINT_DT(constraint = i_c, localCon = true) )
      equation
        l_preExp = Tpl.emptyTxt;
        l_varDecls = Tpl.emptyTxt;
        l_auxFunction = Tpl.emptyTxt;
        (l_condition, l_preExp, l_varDecls, l_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, i_c, SimCodeFunction.contextSimulationDiscrete, l_preExp, l_varDecls, l_auxFunction);
        txt = Tpl.writeText(txt, l_varDecls);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_auxFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("if (!"));
        txt = Tpl.writeText(txt, l_condition);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("){\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("debugString(OMC_LOG_DT_CONS, \"The following local constraint is violated:\\n"));
        txt = ExpressionDumpTpl.dumpExp(txt, i_c, "\"");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\");\n",
                                    "debugString(OMC_LOG_DT, \"Local constraints of the casual tearing set are violated! Let\'s fail...\");\n",
                                    "return 1;\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("}"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_347;

protected function lm_348
  input Tpl.Text in_txt;
  input BackendDAE.Constraints in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      BackendDAE.Constraints rest;
      DAE.Constraint i_con;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_con :: rest )
      equation
        txt = fun_347(txt, i_con);
        txt = Tpl.nextIter(txt);
        txt = lm_348(txt, rest);
      then txt;
  end match;
end lm_348;

public function createLocalConstraints
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq)
    local
      Tpl.Text txt;
      BackendDAE.Constraints i_e_cons;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(cons = i_e_cons) )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_348(txt, i_e_cons);
        txt = Tpl.popIter(txt);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end createLocalConstraints;

public function functionNonLinearResidualsMultiFile
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_nonlinearSystems;
  input Integer a_equationsPerFile;
  input String a_fullPathPrefix;
  input String a_fileNamePrefix;
  input String a_partName;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  list<list<SimCode.SimEqSystem>> ret_1;
  list<SimCode.SimEqSystem> ret_0;
algorithm
  ret_0 := SimCodeUtil.selectNLEqSys(a_nonlinearSystems);
  ret_1 := SimCodeUtil.unbalancedEqSystemPartition(ret_0, a_equationsPerFile);
  out_txt := functionNonLinearResidualsMultiFile2(txt, ret_1, a_fullPathPrefix, a_fileNamePrefix, a_partName, a_modelNamePrefix);
end functionNonLinearResidualsMultiFile;

protected function lm_351
  input Tpl.Text in_txt;
  input list<list<SimCode.SimEqSystem>> in_items;
  input Tpl.Text in_a_prototypes;
  input String in_a_modelNamePrefix;
  input String in_a_fullPathPrefix;
  input String in_a_partName;
  input String in_a_fileNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_prototypes;
algorithm
  (out_txt, out_a_prototypes) :=
  match(in_txt, in_items, in_a_prototypes, in_a_modelNamePrefix, in_a_fullPathPrefix, in_a_partName, in_a_fileNamePrefix)
    local
      Tpl.Text txt;
      list<list<SimCode.SimEqSystem>> rest;
      Tpl.Text a_prototypes;
      String a_modelNamePrefix;
      String a_fullPathPrefix;
      String a_partName;
      String a_fileNamePrefix;
      list<SimCode.SimEqSystem> i_eqs;
      Tpl.Text txt_3;
      String ret_2;
      Tpl.Text txt_1;
      Tpl.Text l_fileName;

    case ( txt,
           {},
           a_prototypes,
           _,
           _,
           _,
           _ )
      then (txt, a_prototypes);

    case ( txt,
           i_eqs :: rest,
           a_prototypes,
           a_modelNamePrefix,
           a_fullPathPrefix,
           a_partName,
           a_fileNamePrefix )
      equation
        txt_1 = Tpl.writeStr(Tpl.emptyTxt, a_fileNamePrefix);
        txt_1 = Tpl.writeTok(txt_1, Tpl.ST_STRING("_"));
        txt_1 = Tpl.writeStr(txt_1, a_partName);
        txt_1 = Tpl.writeTok(txt_1, Tpl.ST_STRING("_part"));
        ret_2 = SimCodeUtil.addFunctionIndex(Tpl.textString(txt_1), ".c");
        l_fileName = Tpl.writeStr(Tpl.emptyTxt, ret_2);
        txt_3 = Tpl.writeStr(Tpl.emptyTxt, a_fullPathPrefix);
        txt_3 = Tpl.writeText(txt_3, l_fileName);
        txt = Tpl.redirectToFile(txt, Tpl.textString(txt_3));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Non Linear Systems "));
        txt = Tpl.writeStr(txt, a_fullPathPrefix);
        txt = Tpl.writeText(txt, l_fileName);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" */\n"));
        txt = simulationFileHeader(txt, a_fileNamePrefix);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("#include \""));
        txt = Tpl.writeStr(txt, a_fileNamePrefix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "_12jac.h\"\n",
                                    "#include \"simulation/arrayIndex.h\"\n",
                                    "\n",
                                    "#if defined(__cplusplus)\n",
                                    "extern \"C\" {\n",
                                    "#endif\n"
                                }, true));
        (txt, a_prototypes) = functionNonLinearResiduals(txt, i_eqs, a_modelNamePrefix, a_prototypes);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "#if defined(__cplusplus)\n",
                                    "}\n",
                                    "#endif\n"
                                }, true));
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.closeFile(txt);
        (txt, a_prototypes) = lm_351(txt, rest, a_prototypes, a_modelNamePrefix, a_fullPathPrefix, a_partName, a_fileNamePrefix);
      then (txt, a_prototypes);
  end match;
end lm_351;

public function functionNonLinearResidualsMultiFile2
  input Tpl.Text in_txt;
  input list<list<SimCode.SimEqSystem>> in_a_nonlinearSystems;
  input String in_a_fullPathPrefix;
  input String in_a_fileNamePrefix;
  input String in_a_partName;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_nonlinearSystems, in_a_fullPathPrefix, in_a_fileNamePrefix, in_a_partName, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      String a_fullPathPrefix;
      String a_fileNamePrefix;
      String a_partName;
      String a_modelNamePrefix;
      list<list<SimCode.SimEqSystem>> i_nonlinearSystems;
      list<SimCode.SimEqSystem> i_eqs;
      Tpl.Text l_file;
      Tpl.Text l_prototypes;

    case ( txt,
           {},
           _,
           _,
           _,
           _ )
      then txt;

    case ( txt,
           {i_eqs},
           _,
           _,
           _,
           a_modelNamePrefix )
      equation
        l_prototypes = Tpl.emptyTxt;
        (txt, l_prototypes) = functionNonLinearResiduals(txt, i_eqs, a_modelNamePrefix, l_prototypes);
      then txt;

    case ( txt,
           i_nonlinearSystems,
           a_fullPathPrefix,
           a_fileNamePrefix,
           a_partName,
           a_modelNamePrefix )
      equation
        l_prototypes = Tpl.emptyTxt;
        l_file = Tpl.emptyTxt;
        (l_file, l_prototypes) = lm_351(l_file, i_nonlinearSystems, l_prototypes, a_modelNamePrefix, a_fullPathPrefix, a_partName, a_fileNamePrefix);
        txt = Tpl.writeText(txt, l_prototypes);
        txt = Tpl.writeText(txt, l_file);
      then txt;
  end match;
end functionNonLinearResidualsMultiFile2;

public function getNLSPrototypes
  input Tpl.Text txt;
  input Integer a_index;

  output Tpl.Text out_txt;
algorithm
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING("void residualFunc"));
  out_txt := Tpl.writeStr(out_txt, intString(a_index));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(RESIDUAL_USERDATA* userData, const double* xloc, double* res, const int* iflag);\n",
                                       "void initializeStaticDataNLS"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, intString(a_index));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA* data, threadData_t *threadData, NONLINEAR_SYSTEM_DATA *inSystemData, modelica_boolean initSparsePattern, modelica_boolean initNonlinearPattern);\n",
                                       "void freeSparsePatternNLS"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, intString(a_index));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(NONLINEAR_SYSTEM_DATA *inSystemData);\n",
                                       "void freeStaticDataNLS"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, intString(a_index));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA* data, threadData_t *threadData, NONLINEAR_SYSTEM_DATA *inSystemData);\n",
                                       "void getIterationVarsNLS"
                                   }, false));
  out_txt := Tpl.writeStr(out_txt, intString(a_index));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("(DATA* data, double *array);"));
end getNLSPrototypes;

protected function fun_354
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eqn;
  input Tpl.Text in_a_prototypes;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_prototypes;
algorithm
  (out_txt, out_a_prototypes) :=
  match(in_txt, in_a_eqn, in_a_prototypes, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      Tpl.Text a_prototypes;
      String a_modelNamePrefix;
      list<DAE.ComponentRef> i_at_crefs;
      Integer i_at_index;
      SimCode.NonlinearSystem i_at;
      list<DAE.ComponentRef> i_nls_crefs;
      SimCode.NonlinearPattern i_nonlinearPatternT;
      SimCode.NonlinearPattern i_nonlinearPattern;
      Integer i_maxColor;
      list<list<Integer>> i_colorList;
      SimCode.SparsityPattern i_sparsePattern;
      Integer i_nls_index;
      SimCode.NonlinearSystem i_nls;
      SimCode.SimEqSystem i_eq_cont;
      Tpl.Text l_updateIterationVarsCasual;
      Tpl.Text l_bodyStaticDataCasual;
      Tpl.Text l_nonlinearDataCasual;
      Tpl.Text l_sparseDataCasual;
      Tpl.Text l_indexName_1;
      Tpl.Text l_residualFunctionCasual;
      Tpl.Text l_updateIterationVars;
      Tpl.Text l_bodyStaticData;
      Tpl.Text l_nonlinearData;
      Tpl.Text l_sparseData;
      Tpl.Text l_indexName;
      Tpl.Text l_residualFunction;
      list<SimCode.SimEqSystem> ret_0;

    case ( txt,
           SimCode.SES_MIXED(cont = i_eq_cont),
           a_prototypes,
           a_modelNamePrefix )
      equation
        ret_0 = List.fill(i_eq_cont, 1);
        (txt, a_prototypes) = functionNonLinearResiduals(txt, ret_0, a_modelNamePrefix, a_prototypes);
      then (txt, a_prototypes);

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(jacobianMatrix = SOME(SimCode.JAC_MATRIX(sparsity = i_sparsePattern, nonlinear = i_nonlinearPattern, nonlinearT = i_nonlinearPatternT, coloredCols = i_colorList, maxColorCols = i_maxColor)), index = i_nls_index, crefs = i_nls_crefs)), alternativeTearing = NONE()),
           a_prototypes,
           a_modelNamePrefix )
      equation
        l_residualFunction = generateNonLinearResidualFunction(Tpl.emptyTxt, i_nls, a_modelNamePrefix, 0);
        l_indexName = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName = Tpl.writeStr(l_indexName, intString(i_nls_index));
        l_sparseData = generateStaticSparseData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA", i_sparsePattern, i_colorList, i_maxColor);
        l_nonlinearData = generateStaticNonlinearData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA", i_nonlinearPattern, i_nonlinearPatternT);
        l_bodyStaticData = generateStaticInitialData(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_updateIterationVars = getIterationVars(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        a_prototypes = getNLSPrototypes(a_prototypes, i_nls_index);
        txt = Tpl.writeText(txt, l_residualFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_nonlinearData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVars);
      then (txt, a_prototypes);

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(index = i_nls_index, crefs = i_nls_crefs)), alternativeTearing = NONE()),
           a_prototypes,
           a_modelNamePrefix )
      equation
        l_residualFunction = generateNonLinearResidualFunction(Tpl.emptyTxt, i_nls, a_modelNamePrefix, 0);
        l_indexName = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName = Tpl.writeStr(l_indexName, intString(i_nls_index));
        l_sparseData = generateStaticEmptySparseData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA");
        l_nonlinearData = generateStaticEmptyNonlinearData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA");
        l_bodyStaticData = generateStaticInitialData(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_updateIterationVars = getIterationVars(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        a_prototypes = getNLSPrototypes(a_prototypes, i_nls_index);
        txt = Tpl.writeText(txt, l_residualFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_nonlinearData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVars);
      then (txt, a_prototypes);

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(jacobianMatrix = SOME(SimCode.JAC_MATRIX(sparsity = i_sparsePattern, nonlinear = i_nonlinearPattern, nonlinearT = i_nonlinearPatternT, coloredCols = i_colorList, maxColorCols = i_maxColor)), index = i_nls_index, crefs = i_nls_crefs)), alternativeTearing = SOME((i_at as SimCode.NONLINEARSYSTEM(jacobianMatrix = SOME(SimCode.JAC_MATRIX(sparsity = _, coloredCols = _, maxColorCols = _)), index = i_at_index, crefs = i_at_crefs)))),
           a_prototypes,
           a_modelNamePrefix )
      equation
        l_residualFunction = generateNonLinearResidualFunction(Tpl.emptyTxt, i_nls, a_modelNamePrefix, 0);
        l_indexName = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName = Tpl.writeStr(l_indexName, intString(i_nls_index));
        l_sparseData = generateStaticSparseData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA", i_sparsePattern, i_colorList, i_maxColor);
        l_nonlinearData = generateStaticNonlinearData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA", i_nonlinearPattern, i_nonlinearPatternT);
        l_bodyStaticData = generateStaticInitialData(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_updateIterationVars = getIterationVars(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_residualFunctionCasual = generateNonLinearResidualFunction(Tpl.emptyTxt, i_at, a_modelNamePrefix, 1);
        l_indexName_1 = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName_1 = Tpl.writeStr(l_indexName_1, intString(i_at_index));
        l_sparseDataCasual = generateStaticSparseData(Tpl.emptyTxt, Tpl.textString(l_indexName_1), "NONLINEAR_SYSTEM_DATA", i_sparsePattern, i_colorList, i_maxColor);
        l_nonlinearDataCasual = generateStaticNonlinearData(Tpl.emptyTxt, Tpl.textString(l_indexName_1), "NONLINEAR_SYSTEM_DATA", i_nonlinearPattern, i_nonlinearPatternT);
        l_bodyStaticDataCasual = generateStaticInitialData(Tpl.emptyTxt, i_at_crefs, Tpl.textString(l_indexName_1));
        l_updateIterationVarsCasual = getIterationVars(Tpl.emptyTxt, i_at_crefs, Tpl.textString(l_indexName_1));
        a_prototypes = getNLSPrototypes(a_prototypes, i_nls_index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* start residuals for dynamic tearing sets */\n",
                                    "/* strict tearing set */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_residualFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_nonlinearData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVars);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* casual tearing set */\n"));
        txt = Tpl.writeText(txt, l_residualFunctionCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseDataCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_nonlinearDataCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticDataCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVarsCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* end residuals for dynamic tearing sets */"));
      then (txt, a_prototypes);

    case ( txt,
           SimCode.SES_NONLINEAR(nlSystem = (i_nls as SimCode.NONLINEARSYSTEM(index = i_nls_index, crefs = i_nls_crefs)), alternativeTearing = SOME((i_at as SimCode.NONLINEARSYSTEM(index = i_at_index, crefs = i_at_crefs)))),
           a_prototypes,
           a_modelNamePrefix )
      equation
        l_residualFunction = generateNonLinearResidualFunction(Tpl.emptyTxt, i_nls, a_modelNamePrefix, 0);
        l_indexName = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName = Tpl.writeStr(l_indexName, intString(i_nls_index));
        l_sparseData = generateStaticEmptySparseData(Tpl.emptyTxt, Tpl.textString(l_indexName), "NONLINEAR_SYSTEM_DATA");
        l_bodyStaticData = generateStaticInitialData(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_updateIterationVars = getIterationVars(Tpl.emptyTxt, i_nls_crefs, Tpl.textString(l_indexName));
        l_residualFunctionCasual = generateNonLinearResidualFunction(Tpl.emptyTxt, i_at, a_modelNamePrefix, 1);
        l_indexName_1 = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("NLS"));
        l_indexName_1 = Tpl.writeStr(l_indexName_1, intString(i_at_index));
        l_sparseDataCasual = generateStaticEmptySparseData(Tpl.emptyTxt, Tpl.textString(l_indexName_1), "NONLINEAR_SYSTEM_DATA");
        l_bodyStaticDataCasual = generateStaticInitialData(Tpl.emptyTxt, i_at_crefs, Tpl.textString(l_indexName_1));
        l_updateIterationVarsCasual = getIterationVars(Tpl.emptyTxt, i_at_crefs, Tpl.textString(l_indexName_1));
        a_prototypes = getNLSPrototypes(a_prototypes, i_nls_index);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* start residuals for dynamic tearing sets */\n",
                                    "/* strict tearing set */\n"
                                }, true));
        txt = Tpl.writeText(txt, l_residualFunction);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticData);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVars);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* casual tearing set */\n"));
        txt = Tpl.writeText(txt, l_residualFunctionCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_sparseDataCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_bodyStaticDataCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeText(txt, l_updateIterationVarsCasual);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* end residuals for dynamic tearing sets */"));
      then (txt, a_prototypes);

    case ( txt,
           _,
           a_prototypes,
           _ )
      then (txt, a_prototypes);
  end match;
end fun_354;

protected function lm_355
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_prototypes;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_prototypes;
algorithm
  (out_txt, out_a_prototypes) :=
  match(in_txt, in_items, in_a_prototypes, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_prototypes;
      String a_modelNamePrefix;
      SimCode.SimEqSystem i_eqn;

    case ( txt,
           {},
           a_prototypes,
           _ )
      then (txt, a_prototypes);

    case ( txt,
           i_eqn :: rest,
           a_prototypes,
           a_modelNamePrefix )
      equation
        System.tmpTickReset(0);
        (txt, a_prototypes) = fun_354(txt, i_eqn, a_prototypes, a_modelNamePrefix);
        txt = Tpl.nextIter(txt);
        (txt, a_prototypes) = lm_355(txt, rest, a_prototypes, a_modelNamePrefix);
      then (txt, a_prototypes);
  end match;
end lm_355;


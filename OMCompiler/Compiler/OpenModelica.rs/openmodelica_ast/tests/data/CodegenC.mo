protected function fun_276
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eqn;
  input Tpl.Text in_a_globalConstraintsFunctions;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_globalConstraintsFunctions;
algorithm
  (out_txt, out_a_globalConstraintsFunctions) :=
  match(in_txt, in_a_eqn, in_a_globalConstraintsFunctions, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      Tpl.Text a_globalConstraintsFunctions;
      String a_modelNamePrefix;
      Option<SimCode.JacobianMatrix> i_at_jacobianMatrix;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> i_at_simJac;
      list<SimCodeVar.SimVar> i_at_vars;
      Integer i_at_index;
      Integer i_at_indexLinearSystem;
      SimCode.SimEqSystem i_eq;
      list<tuple<Integer, Integer, SimCode.SimEqSystem>> i_ls_simJac;
      list<SimCodeVar.SimVar> i_ls_vars;
      Integer i_ls_index;
      Integer i_ls_indexLinearSystem;
      Option<SimCode.JacobianMatrix> i_ls_jacobianMatrix;
      SimCode.SimEqSystem i_eq_cont;
      list<SimCode.SimEqSystem> ret_0;

    case ( txt,
           SimCode.SES_MIXED(cont = i_eq_cont),
           a_globalConstraintsFunctions,
           a_modelNamePrefix )
      equation
        ret_0 = List.fill(i_eq_cont, 1);
        (txt, _) = functionInitialLinearSystemsTemp(txt, ret_0, a_modelNamePrefix, Tpl.strTokText(Tpl.ST_STRING("")));
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(jacobianMatrix = i_ls_jacobianMatrix, indexLinearSystem = i_ls_indexLinearSystem, index = i_ls_index, vars = i_ls_vars, simJac = i_ls_simJac), alternativeTearing = NONE()),
           a_globalConstraintsFunctions,
           a_modelNamePrefix )
      equation
        txt = fun_271(txt, i_ls_jacobianMatrix, a_modelNamePrefix, i_ls_simJac, i_ls_vars, i_ls_index, i_ls_indexLinearSystem);
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           (i_eq as SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(jacobianMatrix = i_ls_jacobianMatrix, indexLinearSystem = i_ls_indexLinearSystem, index = i_ls_index, vars = i_ls_vars, simJac = i_ls_simJac), alternativeTearing = SOME(SimCode.LINEARSYSTEM(indexLinearSystem = i_at_indexLinearSystem, index = i_at_index, vars = i_at_vars, simJac = i_at_simJac, jacobianMatrix = i_at_jacobianMatrix)))),
           a_globalConstraintsFunctions,
           a_modelNamePrefix )
      equation
        a_globalConstraintsFunctions = createGlobalConstraintsFunction(a_globalConstraintsFunctions, i_eq);
        txt = fun_275(txt, i_ls_jacobianMatrix, i_at_jacobianMatrix, a_modelNamePrefix, i_at_simJac, i_at_vars, i_at_index, i_at_indexLinearSystem, i_ls_simJac, i_ls_vars, i_ls_index, i_ls_indexLinearSystem);
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           _,
           a_globalConstraintsFunctions,
           _ )
      then (txt, a_globalConstraintsFunctions);
  end match;
end fun_276;

protected function lm_277
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;
  input Tpl.Text in_a_globalConstraintsFunctions;
  input String in_a_modelNamePrefix;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_globalConstraintsFunctions;
algorithm
  (out_txt, out_a_globalConstraintsFunctions) :=
  match(in_txt, in_items, in_a_globalConstraintsFunctions, in_a_modelNamePrefix)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      Tpl.Text a_globalConstraintsFunctions;
      String a_modelNamePrefix;
      SimCode.SimEqSystem i_eqn;

    case ( txt,
           {},
           a_globalConstraintsFunctions,
           _ )
      then (txt, a_globalConstraintsFunctions);

    case ( txt,
           i_eqn :: rest,
           a_globalConstraintsFunctions,
           a_modelNamePrefix )
      equation
        (txt, a_globalConstraintsFunctions) = fun_276(txt, i_eqn, a_globalConstraintsFunctions, a_modelNamePrefix);
        txt = Tpl.nextIter(txt);
        (txt, a_globalConstraintsFunctions) = lm_277(txt, rest, a_globalConstraintsFunctions, a_modelNamePrefix);
      then (txt, a_globalConstraintsFunctions);
  end match;
end lm_277;

public function functionInitialLinearSystemsTemp
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_linearSystems;
  input String a_modelNamePrefix;
  input Tpl.Text a_globalConstraintsFunctions;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_globalConstraintsFunctions;
algorithm
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING_LIST({
                                                                    "\n",
                                                                    "\n"
                                                                }, true)), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (out_txt, out_a_globalConstraintsFunctions) := lm_277(out_txt, a_linearSystems, a_globalConstraintsFunctions, a_modelNamePrefix);
  out_txt := Tpl.popIter(out_txt);
end functionInitialLinearSystemsTemp;


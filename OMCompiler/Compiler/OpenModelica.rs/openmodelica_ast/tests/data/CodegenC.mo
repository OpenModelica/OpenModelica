        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, SOME(Tpl.ST_STRING("")), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_sub, a_auxFunction, a_varDecls, a_preExp) = lm_608(txt, i_iter__, a_sub, a_auxFunction, a_varDecls, a_preExp);
        txt = Tpl.popIter(txt);
      then (txt, a_sub, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_sub,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      then (txt, a_sub, a_auxFunction, a_varDecls, a_preExp);
  end match;

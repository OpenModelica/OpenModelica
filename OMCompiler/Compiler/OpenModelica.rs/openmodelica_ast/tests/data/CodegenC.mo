algorithm
  out_txt :=
  match(in_txt, in_a_baseClock)
    local
      Tpl.Text txt;

    case ( txt,
           DAE.INFERRED_CLOCK() )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("warningStreamPrint(OMC_LOG_STDOUT, 0, \"Inferred clock, using default clock \\\'Clock(intervalCounter=1, resolution=1)\\\'\");"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_83;

public function baseClockInit
  input Tpl.Text txt;
  input DAE.ClockKind a_baseClock;
  input Integer a_baseClockIdx;
  input list<SimCode.SubPartition> a_subPartitions;
  input Tpl.Text a_varDecls;
  input Tpl.Text a_auxFunction;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_auxFunction;
protected
  Integer ret_9;
  Integer ret_8;
  Tpl.Text l_warning;
  Tpl.Text l_subClocksInfo;
  Tpl.Text l_computeInterval;
  Tpl.Text l_interval;
  Tpl.Text l_startInterval;
  Tpl.Text l_resolution;
  Tpl.Text l_intervalCounter;
  Tpl.Text l_preExp;
algorithm
  l_preExp := Tpl.emptyTxt;
  (l_intervalCounter, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_75(Tpl.emptyTxt, a_baseClock, a_auxFunction, a_varDecls, l_preExp);
  (l_resolution, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_76(Tpl.emptyTxt, a_baseClock, out_a_auxFunction, out_a_varDecls, l_preExp);
  (l_startInterval, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_77(Tpl.emptyTxt, a_baseClock, out_a_auxFunction, out_a_varDecls, l_preExp);
  (l_interval, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_79(Tpl.emptyTxt, a_baseClock, out_a_auxFunction, out_a_varDecls, l_preExp);
  l_computeInterval := fun_81(Tpl.emptyTxt, a_baseClock, a_baseClockIdx);
  l_subClocksInfo := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_subClocksInfo := lm_82(l_subClocksInfo, a_subPartitions, a_baseClockIdx);
  l_subClocksInfo := Tpl.popIter(l_subClocksInfo);
  l_warning := fun_83(Tpl.emptyTxt, a_baseClock);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING("/* Base-Clock "));
  out_txt := Tpl.writeStr(out_txt, intString(a_baseClockIdx));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE(" */\n"));
  out_txt := Tpl.writeText(out_txt, l_warning);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("data->simulationInfo->baseClocks["));
  out_txt := Tpl.writeStr(out_txt, intString(a_baseClockIdx));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("] = (BASECLOCK_DATA){\n"));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING(".resolution = "));
  out_txt := Tpl.writeText(out_txt, l_resolution);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ",\n",
                                       ".intervalCounter = "
                                   }, false));
  out_txt := Tpl.writeText(out_txt, l_intervalCounter);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ",\n",
                                       ".interval = "
                                   }, false));
  out_txt := Tpl.writeText(out_txt, l_interval);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ",\n",
                                       ".nSubClocks = "
                                   }, false));
  ret_8 := listLength(a_subPartitions);
  out_txt := Tpl.writeStr(out_txt, intString(ret_8));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ",\n",
                                       ".isEventClock = "
                                   }, false));
  out_txt := isEventClock(out_txt, a_baseClock);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ",\n",
                                       ".stats = (CLOCK_STATS){"
                                   }, false));
  out_txt := Tpl.writeText(out_txt, l_startInterval);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE(", 0, -1}};\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeText(out_txt, l_computeInterval);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("data->simulationInfo->baseClocks["));
  out_txt := Tpl.writeStr(out_txt, intString(a_baseClockIdx));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("].subClocks = calloc("));
  ret_9 := listLength(a_subPartitions);
  out_txt := Tpl.writeStr(out_txt, intString(ret_9));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE(", sizeof(SUBCLOCK_DATA));\n"));
  out_txt := Tpl.writeText(out_txt, l_subClocksInfo);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_NEW_LINE());
end baseClockInit;

protected function fun_85
  input Tpl.Text in_txt;
  input Option<String> in_a_subClock_solver;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_subClock_solver)
    local
      Tpl.Text txt;

    case ( txt,
           NONE() )
      then txt;

    case ( txt,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("External"));
      then txt;
  end match;
end fun_85;

public function subPartitionStr
  input Tpl.Text in_txt;
  input SimCode.SubPartition in_a_subPartition;
  input Integer in_a_baseClockIdx;
  input Integer in_a_subClockIdx;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_subPartition, in_a_baseClockIdx, in_a_subClockIdx)
    local
      Tpl.Text txt;
      Integer a_baseClockIdx;
      Integer a_subClockIdx;
      Boolean i_holdEvents;
      MMath.Rational i_subClock_factor;
      MMath.Rational i_subClock_shift;
      Option<String> i_subClock_solver;
      Tpl.Text l_methodStr;

    case ( txt,
           SimCode.SUBPARTITION(subClock = BackendDAE.SUBCLOCK(solver = i_subClock_solver, shift = i_subClock_shift, factor = i_subClock_factor), holdEvents = i_holdEvents),
           a_baseClockIdx,
           a_subClockIdx )
      equation
        l_methodStr = fun_85(Tpl.emptyTxt, i_subClock_solver);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->baseClocks["));
        txt = Tpl.writeStr(txt, intString(a_baseClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("].subClocks["));
        txt = Tpl.writeStr(txt, intString(a_subClockIdx));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("] = (SUBCLOCK_DATA) {\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(".shift = "));
        txt = makeCRational(txt, i_subClock_shift);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",\n",
                                    ".factor = "
                                }, false));
        txt = makeCRational(txt, i_subClock_factor);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",\n",
                                    ".solverMethod = \""
                                }, false));
        txt = Tpl.writeText(txt, l_methodStr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\",\n",
                                    ".holdEvents = "
                                }, false));
        txt = CodegenCFunctions.boolStrC(txt, i_holdEvents);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ",\n",
                                    ".stats = (CLOCK_STATS) {0, 0, -1}};"
                                }, false));
        txt = Tpl.popBlock(txt);
      then txt;

    case ( txt,
           _,
           _,
           _ )
      then txt;
  end match;
end subPartitionStr;

public function makeCRational
  input Tpl.Text in_txt;
  input MMath.Rational in_a_rational;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_rational)
    local
      Tpl.Text txt;
      Integer i_denom;
      Integer i_nom;

    case ( txt,
           MMath.RATIONAL(nom = i_nom, denom = i_denom) )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("makeRATIONAL("));
        txt = Tpl.writeStr(txt, intString(i_nom));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(", "));
        txt = Tpl.writeStr(txt, intString(i_denom));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(")"));
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end makeCRational;

protected function fun_88
  input Tpl.Text in_txt;
  input SimCode.ClockedPartition in_a_partition;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Integer in_a_i;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls) :=
  match(in_txt, in_a_partition, in_a_auxFunction, in_a_varDecls, in_a_i)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Integer a_i;
      DAE.ClockKind i_baseClock;
      Tpl.Text l_caseBody;

    case ( txt,
           SimCode.CLOCKED_PARTITION(baseClock = i_baseClock),
           a_auxFunction,
           a_varDecls,
           a_i )
      equation
        (l_caseBody, a_varDecls, a_auxFunction) = updatePartition(Tpl.emptyTxt, a_i, i_baseClock, a_varDecls, a_auxFunction);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case "));
        txt = Tpl.writeStr(txt, intString(a_i));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(":\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeText(txt, l_caseBody);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("break;"));
        txt = Tpl.popBlock(txt);
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           _ )
      then (txt, a_auxFunction, a_varDecls);
  end match;
end fun_88;

protected function lm_89
  input Tpl.Text in_txt;
  input list<SimCode.ClockedPartition> in_items;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls) :=
  match(in_txt, in_items, in_a_auxFunction, in_a_varDecls)
    local
      Tpl.Text txt;
      list<SimCode.ClockedPartition> rest;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Integer x_i;
      SimCode.ClockedPartition i_partition;

    case ( txt,
           {},
           a_auxFunction,
           a_varDecls )
      then (txt, a_auxFunction, a_varDecls);

    case ( txt,
           i_partition :: rest,
           a_auxFunction,
           a_varDecls )
      equation
        x_i = Tpl.getIteri_i0(txt);
        (txt, a_auxFunction, a_varDecls) = fun_88(txt, i_partition, a_auxFunction, a_varDecls, x_i);
        txt = Tpl.nextIter(txt);
        (txt, a_auxFunction, a_varDecls) = lm_89(txt, rest, a_auxFunction, a_varDecls);
      then (txt, a_auxFunction, a_varDecls);
  end match;
end lm_89;

public function functionUpdateSynchronous
  input Tpl.Text txt;
  input list<SimCode.ClockedPartition> a_clockedPartitions;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_body;
  Tpl.Text l_auxFunction;
  Tpl.Text l_varDecls;
algorithm
  l_varDecls := Tpl.emptyTxt;
  l_auxFunction := Tpl.emptyTxt;
  l_body := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  (l_body, l_auxFunction, l_varDecls) := lm_89(l_body, a_clockedPartitions, l_auxFunction, l_varDecls);
  l_body := Tpl.popIter(l_body);
  out_txt := Tpl.writeText(txt, l_auxFunction);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "/* Update base-clock. */\n",
                                       "void "
                                   }, false));
  out_txt := CodegenUtil.symbolName(out_txt, a_modelNamePrefix, "function_updateSynchronous");
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "(DATA *data, threadData_t *threadData, long base_idx)\n",
                                       "{\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_varDecls);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "modelica_boolean ret;\n",
                                       "switch (base_idx) {\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(2));
  out_txt := Tpl.writeText(out_txt, l_body);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "default:\n",
                                       "  throwStreamPrint(NULL, \"Internal Error: unknown base partition %ld\", base_idx);\n",
                                       "  break;\n"
                                   }, true));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_LINE("}\n"));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING("}"));
end functionUpdateSynchronous;

protected function fun_91
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;
  input DAE.Exp in_a_intervalCounter;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_mArg, in_a_auxFunction, in_a_varDecls, in_a_preExp, in_a_intervalCounter)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp a_intervalCounter;
      Tpl.Text l_intervalCounterStr;

    case ( txt,
           false,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           a_intervalCounter )
      equation
        (l_intervalCounterStr, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, a_intervalCounter, SimCodeFunction.contextOther, a_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeText(txt, a_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->baseClocks[base_idx].intervalCounter = "));
        txt = Tpl.writeText(txt, l_intervalCounterStr);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "data->simulationInfo->baseClocks[base_idx].interval = DIVISION((modelica_real)data->simulationInfo->baseClocks[base_idx].intervalCounter, (modelica_real)data->simulationInfo->baseClocks[base_idx].resolution, \"intervalCounter/resolution\");"
                                }, false));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Nothing to do */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_91;

protected function fun_92
  input Tpl.Text in_txt;
  input Boolean in_mArg;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;
  input DAE.Exp in_a_interval;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_mArg, in_a_auxFunction, in_a_varDecls, in_a_preExp, in_a_interval)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp a_interval;
      Tpl.Text l_interval__;

    case ( txt,
           false,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           a_interval )
      equation
        (l_interval__, a_preExp, a_varDecls, a_auxFunction) = CodegenCFunctions.daeExp(Tpl.emptyTxt, a_interval, SimCodeFunction.contextOther, a_preExp, a_varDecls, a_auxFunction);
        txt = Tpl.writeText(txt, a_preExp);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("data->simulationInfo->baseClocks[base_idx].interval = "));
        txt = Tpl.writeText(txt, l_interval__);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Nothing to do */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_92;

protected function fun_93
  input Tpl.Text in_txt;
  input DAE.ClockKind in_a_baseClock;
  input Tpl.Text in_a_auxFunction;
  input Tpl.Text in_a_varDecls;
  input Tpl.Text in_a_preExp;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_auxFunction;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_preExp;
algorithm
  (out_txt, out_a_auxFunction, out_a_varDecls, out_a_preExp) :=
  match(in_txt, in_a_baseClock, in_a_auxFunction, in_a_varDecls, in_a_preExp)
    local
      Tpl.Text txt;
      Tpl.Text a_auxFunction;
      Tpl.Text a_varDecls;
      Tpl.Text a_preExp;
      DAE.Exp i_interval;
      DAE.Exp i_intervalCounter;
      Boolean ret_1;
      Boolean ret_0;

    case ( txt,
           DAE.RATIONAL_CLOCK(intervalCounter = i_intervalCounter),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        ret_0 = Expression.isConst(i_intervalCounter);
        (txt, a_auxFunction, a_varDecls, a_preExp) = fun_91(txt, ret_0, a_auxFunction, a_varDecls, a_preExp, i_intervalCounter);
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           DAE.REAL_CLOCK(interval = i_interval),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        ret_1 = Expression.isConst(i_interval);
        (txt, a_auxFunction, a_varDecls, a_preExp) = fun_92(txt, ret_1, a_auxFunction, a_varDecls, a_preExp, i_interval);
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           DAE.INFERRED_CLOCK(),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Nothing to do */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           DAE.SOLVER_CLOCK(c = _),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Nothing to do */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           DAE.EVENT_CLOCK(condition = _),
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("/* Nothing to do */"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);

    case ( txt,
           _,
           a_auxFunction,
           a_varDecls,
           a_preExp )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("ERROR in updatePartition"));
      then (txt, a_auxFunction, a_varDecls, a_preExp);
  end match;
end fun_93;

public function updatePartition
  input Tpl.Text txt;
  input Integer a_i;
  input DAE.ClockKind a_baseClock;
  input Tpl.Text a_varDecls;
  input Tpl.Text a_auxFunction;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_varDecls;
  output Tpl.Text out_a_auxFunction;
protected
  Tpl.Text l_preExp;
algorithm
  l_preExp := Tpl.emptyTxt;
  (out_txt, out_a_auxFunction, out_a_varDecls, l_preExp) := fun_93(txt, a_baseClock, a_auxFunction, a_varDecls, l_preExp);
end updatePartition;

protected function fun_95
  input Tpl.Text in_txt;
  input SimCode.SubPartition in_a_subPartition;
  input String in_a_modelNamePrefix;
  input Integer in_a_sub__idx;
  input Integer in_a_base__idx;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_subPartition, in_a_modelNamePrefix, in_a_sub__idx, in_a_base__idx)
    local
      Tpl.Text txt;
      String a_modelNamePrefix;
      Integer a_sub__idx;
      Integer a_base__idx;
      Tpl.Text l_name;

    case ( txt,
           SimCode.SUBPARTITION(vars = _),
           a_modelNamePrefix,
           a_sub__idx,
           a_base__idx )
      equation
        l_name = Tpl.writeTok(Tpl.emptyTxt, Tpl.ST_STRING("functionEquationsSynchronous_system_"));
        l_name = Tpl.writeStr(l_name, intString(a_base__idx));
        l_name = Tpl.writeTok(l_name, Tpl.ST_STRING("_"));
        l_name = Tpl.writeStr(l_name, intString(a_sub__idx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("case "));
        txt = Tpl.writeStr(txt, intString(a_sub__idx));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(":\n"));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("ret = "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, Tpl.textString(l_name));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(data, threadData);\n",
                                    "break;"
                                }, false));
        txt = Tpl.popBlock(txt);
      then txt;

    case ( txt,
           _,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_95;

protected function lm_96
  input Tpl.Text in_txt;
  input list<SimCode.SubPartition> in_items;
  input String in_a_modelNamePrefix;
  input Integer in_a_base__idx;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_modelNamePrefix, in_a_base__idx)
    local
      Tpl.Text txt;
      list<SimCode.SubPartition> rest;
      String a_modelNamePrefix;
      Integer a_base__idx;
      Integer x_sub_idx;
      SimCode.SubPartition i_subPartition;

    case ( txt,
           {},
           _,
           _ )
      then txt;

    case ( txt,
           i_subPartition :: rest,
           a_modelNamePrefix,
           a_base__idx )
      equation
        x_sub_idx = Tpl.getIteri_i0(txt);
        txt = fun_95(txt, i_subPartition, a_modelNamePrefix, x_sub_idx, a_base__idx);
        txt = Tpl.nextIter(txt);
        txt = lm_96(txt, rest, a_modelNamePrefix, a_base__idx);
      then txt;
  end match;
end lm_96;

public function functionSystemsSynchronousSubClocks
  input Tpl.Text txt;
  input list<SimCode.SubPartition> a_subPartitions;
  input Integer a_base__idx;
  input String a_modelNamePrefix;

  output Tpl.Text out_txt;
protected
  Tpl.Text l_subCases;
algorithm
  l_subCases := Tpl.pushIter(Tpl.emptyTxt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  l_subCases := lm_96(l_subCases, a_subPartitions, a_modelNamePrefix, a_base__idx);
  l_subCases := Tpl.popIter(l_subCases);
  out_txt := Tpl.writeTok(txt, Tpl.ST_STRING("case "));
  out_txt := Tpl.writeStr(out_txt, intString(a_base__idx));
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       ":\n",
                                       "  switch (sub_idx) {\n"
                                   }, true));
  out_txt := Tpl.pushBlock(out_txt, Tpl.BT_INDENT(4));
  out_txt := Tpl.writeText(out_txt, l_subCases);
  out_txt := Tpl.softNewLine(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "default:\n",
                                       "  throwStreamPrint(NULL, \"Internal Error: unknown sub-clock partition %ld\", sub_idx);\n",
                                       "  ret = 1;\n",
                                       "  break;\n"
                                   }, true));
  out_txt := Tpl.popBlock(out_txt);
  out_txt := Tpl.writeTok(out_txt, Tpl.ST_STRING_LIST({
                                       "  }\n",
                                       "  break;"
                                   }, false));
end functionSystemsSynchronousSubClocks;

protected function fun_98
  input Tpl.Text in_txt;
  input SimCode.ClockedPartition in_a_partition;

protected function fun_705
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input Boolean in_a_init;
  input String in_a_modelNamePrefix;
  input Tpl.Text in_a_tempeqns;
  input Tpl.Text in_a_varD;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_tempeqns;
  output Tpl.Text out_a_varD;
algorithm
  (out_txt, out_a_tempeqns, out_a_varD) :=
  match(in_txt, in_a_eq, in_a_init, in_a_modelNamePrefix, in_a_tempeqns, in_a_varD, in_a_context)
    local
      Tpl.Text txt;
      Boolean a_init;
      String a_modelNamePrefix;
      Tpl.Text a_tempeqns;
      Tpl.Text a_varD;
      SimCodeFunction.Context a_context;
      list<SimCode.SimEqSystem> i_nls_eqs;
      SimCode.SimEqSystem i_e;
      Tpl.Text l_res;
      Tpl.Text l_eqs;

    case ( txt,
           (i_e as SimCode.SES_SIMPLE_ASSIGN(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationSimpleAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationSimpleAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ARRAY_CALL_ASSIGN(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationArrayCallAssign(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_RESIZABLE_ASSIGN(index = _)),
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationGenericAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_GENERIC_ASSIGN(index = _)),
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationGenericAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ENTWINED_ASSIGN(index = _)),
           _,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationEntwinedAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_IFEQUATION(index = _)),
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationIfEquationAssign(txt, i_e, a_context, a_varD, a_tempeqns, a_modelNamePrefix, a_init);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_ALGORITHM(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationAlgorithm(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_INVERSE_ALGORITHM(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationAlgorithm(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_LINEAR(lSystem = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD) = equationLinear(txt, i_e, a_context, a_varD);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_NONLINEAR(nlSystem = SimCode.NONLINEARSYSTEM(eqs = i_nls_eqs))),
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        a_tempeqns = Tpl.pushIter(a_tempeqns, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        a_tempeqns = lm_704(a_tempeqns, i_nls_eqs, a_modelNamePrefix);
        a_tempeqns = Tpl.popIter(a_tempeqns);
        txt = equationNonlinear(txt, i_e, a_context, a_modelNamePrefix, a_init);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_WHEN(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationWhen(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           SimCode.SES_RESIDUAL(index = _),
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION SES_RESIDUAL"));
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION SES_FOR_RESIDUAL"));
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           SimCode.SES_GENERIC_RESIDUAL(index = _),
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION SES_GENERIC_RESIDUAL"));
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_MIXED(index = _)),
           a_init,
           a_modelNamePrefix,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        l_eqs = Tpl.emptyTxt;
        (l_res, l_eqs) = equationMixed(Tpl.emptyTxt, i_e, a_context, l_eqs, a_modelNamePrefix, a_init);
        txt = Tpl.writeText(txt, l_eqs);
        txt = Tpl.writeText(txt, l_res);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           (i_e as SimCode.SES_FOR_LOOP(index = _)),
           _,
           _,
           a_tempeqns,
           a_varD,
           a_context )
      equation
        (txt, a_varD, a_tempeqns) = equationForLoop(txt, i_e, a_context, a_varD, a_tempeqns);
      then (txt, a_tempeqns, a_varD);

    case ( txt,
           _,
           _,
           _,
           a_tempeqns,
           a_varD,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("NOT IMPLEMENTED EQUATION equation_"));
      then (txt, a_tempeqns, a_varD);
  end match;
end fun_705;


protected function fun_781
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input SimCodeFunction.Context in_a_context;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq, in_a_context)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      Integer i_ls_indexLinearSystem;
      Boolean i_ls_partOfJac;
      Integer i_ls_index;
      list<SimCodeVar.SimVar> i_ls_vars;
      Option<SimCode.LinearSystem> i_at;
      Boolean ret_5;
      Boolean ret_4;
      Integer ret_3;
      Tpl.Text l_auxFunctions;
      Tpl.Text l_returnval2;
      Tpl.Text l_returnval;

    case ( txt,
           SimCode.SES_LINEAR(lSystem = SimCode.LINEARSYSTEM(vars = i_ls_vars, index = i_ls_index, partOfJac = i_ls_partOfJac, indexLinearSystem = i_ls_indexLinearSystem), alternativeTearing = i_at),
           a_context )
      equation
        l_returnval = fun_774(Tpl.emptyTxt, i_at);
        l_returnval2 = fun_775(Tpl.emptyTxt, i_at);
        l_auxFunctions = Tpl.emptyTxt;
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "/* Linear equation system */\n",
                                    "int retValue;\n",
                                    "double aux_x["
                                }, false));
        ret_3 = listLength(i_ls_vars);
        txt = Tpl.writeStr(txt, intString(ret_3));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] = { "));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING(",")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, l_auxFunctions) = lm_776(txt, i_ls_vars, l_auxFunctions, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    " };\n",
                                    "infoStreamPrint(OMC_LOG_DT, 0, \"Solving linear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" (STRICT TEARING SET if tearing enabled) at time = %18.10e\", data->localData[0]->timeValue);\n"));
        ret_4 = Config.profileSome();
        txt = fun_777(txt, ret_4, i_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = fun_778(txt, i_ls_partOfJac, i_ls_indexLinearSystem);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "\n",
                                    "retValue = solve_linear_system(data, threadData, "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_ls_indexLinearSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ", &aux_x[0]);\n",
                                    "\n",
                                    "/* check if solution process was successful */\n",
                                    "if (retValue > 0){\n"
                                }, true));
        txt = Tpl.pushBlock(txt, Tpl.BT_INDENT(2));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("const int indexes[2] = {1,"));
        txt = Tpl.writeStr(txt, intString(i_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "};\n",
                                    "throwStreamPrintWithEquationIndexes(threadData, omc_dummyFileInfo, indexes, \"Solving linear system "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_ls_index));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(" failed at time=%.15g.\\nFor more information please use -lv LOG_LS.\", data->localData[0]->timeValue);\n"));
        txt = Tpl.writeText(txt, l_returnval2);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "/* write solution */\n"
                                }, true));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, l_auxFunctions) = lm_779(txt, i_ls_vars, l_auxFunctions, a_context);
        txt = Tpl.popIter(txt);
        txt = Tpl.softNewLine(txt);
        ret_5 = Config.profileSome();
        txt = fun_780(txt, ret_5, i_ls_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_NEW_LINE());
        txt = Tpl.writeText(txt, l_returnval);
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end fun_781;


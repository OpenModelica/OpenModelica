protected function lm_588
  input Tpl.Text in_txt;
  input list<Integer> in_items;
  input Tpl.Text in_a_descStr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_descStr)
    local
      Tpl.Text txt;
      list<Integer> rest;
      Tpl.Text a_descStr;
      Integer i_idx;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_idx :: rest,
           a_descStr )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"["));
        txt = Tpl.writeStr(txt, intString(i_idx));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("] "));
        txt = Tpl.writeText(txt, a_descStr);
        txt = Tpl.nextIter(txt);
        txt = lm_588(txt, rest, a_descStr);
      then txt;
  end match;
end lm_588;


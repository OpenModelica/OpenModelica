      BackendDAE.Constraints i_innerEqn_cons;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(cons = i_innerEqn_cons) )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_339(txt, i_innerEqn_cons);
        txt = Tpl.popIter(txt);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end fun_340;

protected function lm_341
  input Tpl.Text in_txt;
  input list<SimCode.SimEqSystem> in_items;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items)
    local
      Tpl.Text txt;
      list<SimCode.SimEqSystem> rest;
      SimCode.SimEqSystem i_innerEqn;

    case ( txt,
           {} )
      then txt;

    case ( txt,
           i_innerEqn :: rest )
      equation
        txt = fun_340(txt, i_innerEqn);
        txt = Tpl.nextIter(txt);
        txt = lm_341(txt, rest);
      then txt;
  end match;
end lm_341;

public function createGlobalConstraints
  input Tpl.Text txt;
  input list<SimCode.SimEqSystem> a_innerEqns;

  output Tpl.Text out_txt;
algorithm
  out_txt := Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
  out_txt := lm_341(out_txt, a_innerEqns);
  out_txt := Tpl.popIter(out_txt);
end createGlobalConstraints;

protected function fun_343
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input Tpl.Text in_a_eqs;
  input String in_a_modelNamePrefixStr;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_eqs;
algorithm
  (out_txt, out_a_eqs) :=
  match(in_txt, in_a_eq, in_a_eqs, in_a_modelNamePrefixStr)
    local
      Tpl.Text txt;
      Tpl.Text a_eqs;
      String a_modelNamePrefixStr;
      SimCode.SimEqSystem i_eq;

    case ( txt,
           SimCode.SES_RESIDUAL(index = _),
           a_eqs,
           _ )
      then (txt, a_eqs);

    case ( txt,
           SimCode.SES_FOR_RESIDUAL(index = _),
           a_eqs,
           _ )
      then (txt, a_eqs);

    case ( txt,
           SimCode.SES_GENERIC_RESIDUAL(index = _),
           a_eqs,
           _ )
      then (txt, a_eqs);

    case ( txt,
           i_eq,
           a_eqs,
           a_modelNamePrefixStr )
      equation
        a_eqs = equation_impl(a_eqs, -1, -1, i_eq, SimCodeFunction.contextSimulationDiscrete, a_modelNamePrefixStr, false);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* local constraints */\n"));
        txt = createLocalConstraints(txt, i_eq);
        txt = Tpl.softNewLine(txt);
        txt = equation_call(txt, i_eq, a_modelNamePrefixStr, SimCodeFunction.contextSimulationDiscrete);
      then (txt, a_eqs);
  end match;
end fun_343;

public function functionExtraResidualsPreBody
  input Tpl.Text txt;
  input SimCode.SimEqSystem a_eq;
  input Tpl.Text a_eqs;
  input String a_modelNamePrefixStr;

  output Tpl.Text out_txt;

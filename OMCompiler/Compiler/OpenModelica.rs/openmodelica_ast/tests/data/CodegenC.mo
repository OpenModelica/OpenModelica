public function equationMixed
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input SimCodeFunction.Context in_a_context;
  input Tpl.Text in_a_tmp;
  input String in_a_modelNamePrefixStr;
  input Boolean in_a_init;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_tmp;
algorithm
  (out_txt, out_a_tmp) :=
  match(in_txt, in_a_eq, in_a_context, in_a_tmp, in_a_modelNamePrefixStr, in_a_init)
    local
      Tpl.Text txt;
      SimCodeFunction.Context a_context;
      Tpl.Text a_tmp;
      String a_modelNamePrefixStr;
      Boolean a_init;
      Integer i_indexMixedSystem;
      Integer i_eqn_indexMixedSystem;
      list<SimCodeVar.SimVar> i_discVars;
      Integer i_index;
      SimCode.SimEqSystem i_cont;
      Boolean ret_2;
      Boolean ret_1;
      Tpl.Text l_sub;

    case ( txt,
           SimCode.SES_MIXED(cont = i_cont, index = i_index, discVars = i_discVars, indexMixedSystem = (i_indexMixedSystem as i_eqn_indexMixedSystem)),
           a_context,
           a_tmp,
           a_modelNamePrefixStr,
           a_init )
      equation
        l_sub = Tpl.emptyTxt;
        a_tmp = equation_impl(a_tmp, -1, -1, i_cont, a_context, a_modelNamePrefixStr, a_init);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE("/* Continuous equation part */\n"));
        ret_1 = Config.profileSome();
        txt = fun_789(txt, ret_1, i_index);
        txt = Tpl.softNewLine(txt);
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, l_sub) = lm_790(txt, i_discVars, l_sub, i_eqn_indexMixedSystem);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(";\n"));
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_NEW_LINE()), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        txt = lm_791(txt, i_discVars, i_eqn_indexMixedSystem);
        txt = Tpl.popIter(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    ";\n",
                                    "solve_mixed_system(data, "
                                }, false));
        txt = Tpl.writeStr(txt, intString(i_indexMixedSystem));
        txt = Tpl.writeTok(txt, Tpl.ST_LINE(");\n"));
        ret_2 = Config.profileSome();
        txt = fun_792(txt, ret_2, i_index);
      then (txt, a_tmp);

    case ( txt,
           _,
           _,
           a_tmp,
           _,
           _ )
      then (txt, a_tmp);
  end match;
end equationMixed;


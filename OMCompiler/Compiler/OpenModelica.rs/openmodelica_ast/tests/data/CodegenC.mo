      Tpl.Text txt_7;
      Tpl.Text l_records;
      Tpl.Text txt_5;
      Tpl.Text l_includes;
      Tpl.Text txt_3;
      Tpl.Text l_functionsHeader;
      Tpl.Text txt_1;
      Tpl.Text l_literalsFile;

    case ( txt,
           SimCode.SIMCODE(modelInfo = SimCode.MODELINFO(functions = i_modelInfo_functions), fileNamePrefix = i_fileNamePrefix, literals = i_literals, recordDecls = i_recordDecls, generic_loop_calls = i_sc_generic__loop__calls, externalFunctionIncludes = i_sc_externalFunctionIncludes) )
      equation

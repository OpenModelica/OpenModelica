end fun_697;

public function equation_arrayFormat
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;
  input String in_a_name;
  input SimCodeFunction.Context in_a_context;
  input Integer in_a_arrayIndex;
  input Tpl.Text in_a_eqArray;
  input Tpl.Text in_a_eqfuncs;
  input String in_a_modelNamePrefix;
  input Boolean in_a_init;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_eqArray;
  output Tpl.Text out_a_eqfuncs;
algorithm
  (out_txt, out_a_eqArray, out_a_eqfuncs) :=
  match(in_txt, in_a_eq, in_a_name, in_a_context, in_a_arrayIndex, in_a_eqArray, in_a_eqfuncs, in_a_modelNamePrefix, in_a_init)
    local
      Tpl.Text txt;
      String a_name;
      SimCodeFunction.Context a_context;
      Integer a_arrayIndex;
      Tpl.Text a_eqArray;
      Tpl.Text a_eqfuncs;
      String a_modelNamePrefix;
      Boolean a_init;
      SimCode.SimEqSystem i_eq;
      list<SimCode.SimEqSystem> ret_7;
      Tpl.Text l_x;
      Tpl.Text l_disc;
      Tpl.Text l_OMC__DISABLE__OPT;
      Tpl.Text l_tempeqns;
      Tpl.Text l_varD;
      Tpl.Text l_tmp;
      Tpl.Text l_ix;

    case ( txt,
           SimCode.SES_ALGORITHM(statements = {}),
           _,
           _,
           _,
           a_eqArray,
           a_eqfuncs,
           _,
           _ )
      then (txt, a_eqArray, a_eqfuncs);

    case ( txt,
           i_eq,
           a_name,
           a_context,
           a_arrayIndex,
           a_eqArray,
           a_eqfuncs,
           a_modelNamePrefix,
           a_init )
      equation
        l_ix = CodegenUtilSimulation.equationIndex(Tpl.emptyTxt, i_eq);
        l_tmp = Tpl.emptyTxt;
        l_varD = Tpl.emptyTxt;
        l_tempeqns = Tpl.emptyTxt;
        l_OMC__DISABLE__OPT = Tpl.emptyTxt;
        System.tmpTickResetIndex(0, 1);
        l_disc = fun_693(Tpl.emptyTxt, a_context);
        (l_x, a_eqfuncs, l_OMC__DISABLE__OPT, l_tempeqns, l_varD) = fun_697(Tpl.emptyTxt, i_eq, a_eqfuncs, l_OMC__DISABLE__OPT, a_init, a_modelNamePrefix, l_tempeqns, l_varD, a_context);
        a_eqArray = CodegenUtil.symbolName(a_eqArray, a_modelNamePrefix, "eqFunction");
        a_eqArray = Tpl.writeTok(a_eqArray, Tpl.ST_STRING("_"));
        a_eqArray = Tpl.writeText(a_eqArray, l_ix);
        a_eqArray = Tpl.writeTok(a_eqArray, Tpl.ST_STRING(", "));
        a_eqArray = Tpl.writeTok(a_eqArray, Tpl.ST_NEW_LINE());
        l_varD = CodegenCFunctions.addRootsTempArray(l_varD);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_NEW_LINE());
        a_eqfuncs = Tpl.writeText(a_eqfuncs, l_tempeqns);
        a_eqfuncs = Tpl.softNewLine(a_eqfuncs);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_LINE("/*\n"));
        a_eqfuncs = Tpl.pushBlock(a_eqfuncs, Tpl.BT_INDENT(1));
        ret_7 = List.fill(i_eq, 1);
        a_eqfuncs = CodegenUtilSimulation.dumpEqs(a_eqfuncs, ret_7);
        a_eqfuncs = Tpl.softNewLine(a_eqfuncs);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_LINE("*/\n"));
        a_eqfuncs = Tpl.popBlock(a_eqfuncs);
        a_eqfuncs = Tpl.writeText(a_eqfuncs, l_OMC__DISABLE__OPT);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_STRING("void "));
        a_eqfuncs = CodegenUtil.symbolName(a_eqfuncs, a_modelNamePrefix, "eqFunction");
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_STRING("_"));
        a_eqfuncs = Tpl.writeText(a_eqfuncs, l_ix);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_STRING_LIST({
                                                "(DATA *data, threadData_t *threadData)\n",
                                                "{\n"
                                            }, true));
        a_eqfuncs = Tpl.pushBlock(a_eqfuncs, Tpl.BT_INDENT(2));
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_STRING("const int equationIndexes[2] = {1,"));
        a_eqfuncs = Tpl.writeText(a_eqfuncs, l_ix);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_LINE("};\n"));
        a_eqfuncs = Tpl.writeText(a_eqfuncs, l_varD);
        a_eqfuncs = Tpl.softNewLine(a_eqfuncs);
        a_eqfuncs = equation_withProfile(a_eqfuncs, Tpl.textString(l_ix), Tpl.textString(l_x));
        a_eqfuncs = Tpl.softNewLine(a_eqfuncs);
        a_eqfuncs = Tpl.popBlock(a_eqfuncs);
        a_eqfuncs = Tpl.writeTok(a_eqfuncs, Tpl.ST_STRING("}"));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("// "));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "eqFunction");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt = Tpl.writeText(txt, l_ix);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "(data, threadData);\n",
                                    "function"
                                }, false));
        txt = Tpl.writeStr(txt, a_name);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_systems["));
        txt = Tpl.writeStr(txt, intString(a_arrayIndex));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("](data, threadData);"));
      then (txt, a_eqArray, a_eqfuncs);
  end match;
end equation_arrayFormat;


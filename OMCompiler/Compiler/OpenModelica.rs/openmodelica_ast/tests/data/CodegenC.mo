  match(in_txt, in_mArg, in_a_sub, in_a_conditions)
    local
      Tpl.Text txt;
      Tpl.Text a_sub;
      list<DAE.ComponentRef> a_conditions;

    case ( txt,
           false,
           a_sub,
           a_conditions )
      equation
        txt = Tpl.pushIter(txt, Tpl.ITER_OPTIONS(0, NONE(), SOME(Tpl.ST_STRING(" || ")), 0, 0, Tpl.ST_NEW_LINE(), 0, Tpl.ST_NEW_LINE()));
        (txt, a_sub) = lm_808(txt, a_conditions, a_sub);
        txt = Tpl.popIter(txt);
      then (txt, a_sub);

    case ( txt,
           _,
           a_sub,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("0"));
      then (txt, a_sub);
  end match;
end fun_809;


algorithm
  txt_0 := CodegenUtil.getGeneralTarget(Tpl.emptyTxt, a_target);
  str_1 := Tpl.textString(txt_0);
  out_txt := fun_880(txt, str_1, a_target, a_simCode, a_extraFiles);
end simulationMakefile;

public function crefM
  input Tpl.Text in_txt;
  input DAE.ComponentRef in_a_cr;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_cr)
    local
      Tpl.Text txt;
      DAE.ComponentRef i_cr;

    case ( txt,
           (i_cr as DAE.CREF_IDENT(ident = "xloc")) )
      equation
        txt = CodegenUtil.crefStr(txt, i_cr);
      then txt;

    case ( txt,
           DAE.CREF_IDENT(ident = "time") )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("time"));
      then txt;

    case ( txt,
           i_cr )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("P"));
        txt = CodegenCFunctions.crefToMStr(txt, i_cr);
      then txt;
  end match;
end crefM;

public function simEqAttrIsDiscreteKind
  input Tpl.Text in_txt;
  input SimCode.SimEqSystem in_a_eq;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eq)
    local
      Tpl.Text txt;
      BackendDAE.EquationAttributes i_eqAttr;

    case ( txt,
           SimCode.SES_RESIDUAL(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_FOR_RESIDUAL(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_GENERIC_RESIDUAL(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_SIMPLE_ASSIGN_CONSTRAINTS(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_ARRAY_CALL_ASSIGN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_RESIZABLE_ASSIGN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_GENERIC_ASSIGN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_ENTWINED_ASSIGN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_IFEQUATION(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_ALGORITHM(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_LINEAR(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_NONLINEAR(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_MIXED(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_WHEN(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           SimCode.SES_FOR_LOOP(eqAttr = i_eqAttr) )
      equation
        txt = eqAttributeIsDiscreteKind(txt, i_eqAttr);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end simEqAttrIsDiscreteKind;

public function eqAttributeIsDiscreteKind
  input Tpl.Text in_txt;
  input BackendDAE.EquationAttributes in_a_eqAtt;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eqAtt)
    local
      Tpl.Text txt;
      BackendDAE.EquationKind i_kind;

    case ( txt,
           BackendDAE.EQUATION_ATTRIBUTES(kind = i_kind) )
      equation
        txt = eqIsDiscreteKind(txt, i_kind);
      then txt;

    case ( txt,
           _ )
      then txt;
  end match;
end eqAttributeIsDiscreteKind;

public function eqIsDiscreteKind
  input Tpl.Text in_txt;
  input BackendDAE.EquationKind in_a_eqKind;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_eqKind)
    local
      Tpl.Text txt;

    case ( txt,
           BackendDAE.DISCRETE_EQUATION() )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("1"));
      then txt;

    case ( txt,
           _ )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("0"));
      then txt;
  end match;
end eqIsDiscreteKind;


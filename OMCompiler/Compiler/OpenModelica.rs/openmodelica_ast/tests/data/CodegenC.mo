                                    "\"    inputVars  = ["
                                }, false));
        txt = getVarNamePython(txt, i_vars_inputVars, "u0");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]\\n\"\n",
                                    "\"    outputVars = ["
                                }, false));
        txt = getVarNamePython(txt, i_vars_outputVars, "y0");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "]\\n\"\n",
                                    "\"\\n\"\n",
                                    "\"    return (n, m, p, x0, u0, A, B, C, D, stateVars, inputVars, outputVars)\\n\";\n"
                                }, true));
        txt = Tpl.popBlock(txt);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "}\n",
                                    "const char *"
                                }, false));
        txt = CodegenUtil.symbolName(txt, a_modelNamePrefix, "linear_model_datarecovery_frame");
        txt = Tpl.writeTok(txt, Tpl.ST_STRING_LIST({
                                    "()\n",
                                    "{\n",
                                    "  errorStreamPrint(OMC_LOG_STDOUT, 0, \"Linearization with data recovery not implemented for Python.\");\n",
                                    "  return \"\";\n",
                                    "}"
                                }, false));
      then txt;

    case ( txt,
           _,
           _ )
      then txt;
  end match;
end functionlinearmodelPython;

protected function fun_628
  input Tpl.Text in_txt;
  input SimCodeVar.SimVar in_a_var;
  input Integer in_a_arrindex;
  input String in_a_arrayName;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_a_var, in_a_arrindex, in_a_arrayName)
    local
      Tpl.Text txt;
      Integer a_arrindex;
      String a_arrayName;
      DAE.ComponentRef i_name;
      String ret_2;
      Tpl.Text txt_1;
      Tpl.Text txt_0;

    case ( txt,
           SimCodeVar.SIMVAR(name = i_name),
           a_arrindex,
           a_arrayName )
      equation
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\"  Real \'"));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("_"));
        txt_0 = CodegenUtil.crefStrNoUnderscore(Tpl.emptyTxt, i_name);
        txt_1 = CodegenUtil.escapeSingleQuoteIdent(Tpl.emptyTxt, Tpl.textString(txt_0));
        ret_2 = Util.escapeModelicaStringToCString(Tpl.textString(txt_1));
        txt = Tpl.writeStr(txt, ret_2);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("\' = "));
        txt = Tpl.writeStr(txt, a_arrayName);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("["));
        txt = Tpl.writeStr(txt, intString(a_arrindex));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("];\\n\""));
      then txt;

    case ( txt,
           _,
           _,
           _ )
      then txt;
  end match;
end fun_628;

protected function lm_629
  input Tpl.Text in_txt;
  input list<SimCodeVar.SimVar> in_items;
  input String in_a_arrayName;

  output Tpl.Text out_txt;
algorithm
  out_txt :=
  match(in_txt, in_items, in_a_arrayName)
    local
      Tpl.Text txt;
      list<SimCodeVar.SimVar> rest;
      String a_arrayName;
      Integer x_arrindex;
      SimCodeVar.SimVar i_var;

    case ( txt,
           {},
           _ )
      then txt;

    case ( txt,
           i_var :: rest,
           a_arrayName )
      equation
        x_arrindex = Tpl.getIteri_i0(txt);
        txt = fun_628(txt, i_var, x_arrindex, a_arrayName);
        txt = Tpl.nextIter(txt);
        txt = lm_629(txt, rest, a_arrayName);
      then txt;
  end match;
end lm_629;


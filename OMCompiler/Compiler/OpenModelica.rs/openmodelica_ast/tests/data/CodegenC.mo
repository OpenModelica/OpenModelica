protected function lm_357
  input Tpl.Text in_txt;
  input list<DAE.ComponentRef> in_items;
  input Tpl.Text in_a_sub;
  input Tpl.Text in_a_varDecls;

  output Tpl.Text out_txt;
  output Tpl.Text out_a_sub;
  output Tpl.Text out_a_varDecls;
algorithm
  (out_txt, out_a_sub, out_a_varDecls) :=
  match(in_txt, in_items, in_a_sub, in_a_varDecls)
    local
      Tpl.Text txt;
      list<DAE.ComponentRef> rest;
      Tpl.Text a_sub;
      Tpl.Text a_varDecls;
      Integer x_i0;
      DAE.ComponentRef i_cr;

    case ( txt,
           {},
           a_sub,
           a_varDecls )
      then (txt, a_sub, a_varDecls);

    case ( txt,
           i_cr :: rest,
           a_sub,
           a_varDecls )
      equation
        x_i0 = Tpl.getIteri_i0(txt);
        a_varDecls = crefType(a_varDecls, i_cr);
        a_varDecls = Tpl.writeTok(a_varDecls, Tpl.ST_STRING(" OLD_"));
        a_varDecls = Tpl.writeStr(a_varDecls, intString(x_i0));
        a_varDecls = Tpl.writeTok(a_varDecls, Tpl.ST_STRING(";"));
        a_varDecls = Tpl.writeTok(a_varDecls, Tpl.ST_NEW_LINE());
        txt = Tpl.writeTok(txt, Tpl.ST_STRING("OLD_"));
        txt = Tpl.writeStr(txt, intString(x_i0));
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(" = "));
        (txt, a_sub) = CodegenCFunctions.cref(txt, i_cr, a_sub);
        txt = Tpl.writeTok(txt, Tpl.ST_STRING(";"));
        txt = Tpl.nextIter(txt);
        (txt, a_sub, a_varDecls) = lm_357(txt, rest, a_sub, a_varDecls);
      then (txt, a_sub, a_varDecls);
  end match;
end lm_357;

protected function fun_358
  input Tpl.Text in_txt;
